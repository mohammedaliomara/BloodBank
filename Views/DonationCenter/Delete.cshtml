@model BloodBank.Models.BloodCenter

@{
    ViewData["Title"] = "Delete Center";
}

<div class="page-header mt-4">
    <div>
        <h2 class="page-title d-flex align-items-center gap-2 text-danger">
            <i class="fa-solid fa-triangle-exclamation"></i> Delete Center
        </h2>
        <p class="text-muted mb-0">This action cannot be undone</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="fa-solid fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="alert alert-danger d-flex gap-2">
            <i class="fa-solid fa-triangle-exclamation fa-lg mt-1"></i>
            <div>
                <strong>Are you sure?</strong> You are about to permanently delete center <strong>@Model?.Name</strong>.
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-house-medical-circle-xmark text-danger me-2"></i>Center to Delete</span>
            </div>
            <div class="card-body">
                <dl class="row g-0">
                    <dt class="col-sm-4 text-muted fw-semibold py-2 border-bottom" style="font-size:0.875rem;">Center Name</dt>
                    <dd class="col-sm-8 py-2 border-bottom fw-bold">@Html.DisplayFor(m => m.Name)</dd>

                    <dt class="col-sm-4 text-muted fw-semibold py-2 border-bottom" style="font-size:0.875rem;">Address</dt>
                    <dd class="col-sm-8 py-2 border-bottom">@Html.DisplayFor(m => m.Address)</dd>

                    <dt class="col-sm-4 text-muted fw-semibold py-2 border-bottom" style="font-size:0.875rem;">Governorate</dt>
                    <dd class="col-sm-8 py-2 border-bottom">@Html.DisplayFor(m => m.Governorate)</dd>

                    <dt class="col-sm-4 text-muted fw-semibold py-2" style="font-size:0.875rem;">Phone</dt>
                    <dd class="col-sm-8 py-2">@Html.DisplayFor(m => m.PhoneNumber)</dd>
                </dl>
            </div>
        </div>

        <form asp-action="Delete" class="d-flex gap-2 mt-3">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Yes, Delete Permanently" class="btn btn-danger flex-grow-1" />
            <a asp-action="Index" class="btn btn-outline-primary">Cancel</a>
        </form>
    </div>
</div>
