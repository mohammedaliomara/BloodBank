@model BloodBank.Models.BloodCenter

@{
    ViewData["Title"] = "Add Donation Center";
}

<div class="page-header mt-4">
    <div>
        <h2 class="page-title d-flex align-items-center gap-2">
            <i class="fa-solid fa-house-medical-circle-check text-primary-brand"></i> Add Donation Center
        </h2>
        <p class="text-muted mb-0">Register a new blood donation center</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="fa-solid fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-house-medical text-primary-brand me-2"></i>Center Information</span>
            </div>
            <div class="card-body">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g. Cairo Central Blood Center" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label"></label>
                        <input asp-for="Address" class="form-control" placeholder="Full street address" />
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Governorate" class="form-label"></label>
                        <input asp-for="Governorate" class="form-control" placeholder="e.g. Cairo" />
                        <span asp-validation-for="Governorate" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="PhoneNumber" class="form-label"></label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="e.g. 02-12345678" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <input type="submit" value="Add Center" class="btn btn-primary flex-grow-1" />
                        <a asp-action="Index" class="btn btn-outline-primary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
