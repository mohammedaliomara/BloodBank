@{
    ViewData["Title"] = "Ministry Portal";
}

<div class="page-header mt-4">
    <h2 class="page-title d-flex align-items-center gap-2">
        <i class="fa-solid fa-building-columns text-primary-brand"></i> Ministry of Health - Blood Bank System
    </h2>
    <span class="badge badge-primary"><i class="fa-solid fa-circle-check"></i> Live Data - Updated Just Now</span>
</div>

<!-- TOP STATS -->
<div class="row mb-4">
    <div class="col-md col-sm-6 mb-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-primary"><i class="fa-solid fa-hospital"></i></div>
            <div class="stat-info">
                <div class="stat-label">Hospitals</div>
                <div class="stat-value" id="st-hospitals">...</div>
            </div>
        </div>
    </div>
    <div class="col-md col-sm-6 mb-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-success"><i class="fa-solid fa-users"></i></div>
            <div class="stat-info">
                <div class="stat-label">Donors</div>
                <div class="stat-value" id="st-donors">...</div>
            </div>
        </div>
    </div>
    <div class="col-md col-sm-6 mb-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-info"><i class="fa-solid fa-droplet"></i></div>
            <div class="stat-info">
                <div class="stat-label">Units</div>
                <div class="stat-value" id="st-units">...</div>
            </div>
        </div>
    </div>
    <div class="col-md col-sm-6 mb-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-purple"><i class="fa-solid fa-check-double"></i></div>
            <div class="stat-info">
                <div class="stat-label">Completion Rate</div>
                <div class="stat-value" id="st-completion">...</div>
            </div>
        </div>
    </div>
    <div class="col-md col-sm-6 mb-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-warning"><i class="fa-solid fa-clock-rotate-left"></i></div>
            <div class="stat-info">
                <div class="stat-label">Pending Reqs</div>
                <div class="stat-value text-danger" id="st-reqs">...</div>
            </div>
        </div>
    </div>
</div>

<!-- TABS -->
<ul class="nav nav-tabs" id="ministryTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview" type="button" role="tab">
            <i class="fa-solid fa-chart-pie me-2"></i> Overview
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="govs-tab" data-bs-toggle="tab" data-bs-target="#govs" type="button" role="tab">
            <i class="fa-solid fa-map-location-dot me-2"></i> Governorates
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="ai-tab" data-bs-toggle="tab" data-bs-target="#ai" type="button" role="tab">
            <i class="fa-solid fa-robot me-2"></i> AI Predictions
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="alerts-tab" data-bs-toggle="tab" data-bs-target="#alerts" type="button" role="tab">
            <i class="fa-solid fa-bell me-2"></i> Alerts
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="reports-tab" data-bs-toggle="tab" data-bs-target="#reports" type="button" role="tab">
            <i class="fa-solid fa-file-pdf me-2"></i> Reports
        </button>
    </li>
</ul>

<div class="tab-content" id="ministryTabsContent">
    
    <!-- OVERVIEW TAB -->
    <div class="tab-pane fade show active" id="overview" role="tabpanel" tabindex="0">
        <div class="alert alert-info shadow-sm mb-4">
            <i class="fa-solid fa-robot fa-2x"></i>
            <div>
                <strong class="d-block mb-1">National AI Analysis</strong>
                Luxor, South Sinai, and Assiut are experiencing shortages in O- and B-. Targeted donation campaigns are recommended for the next two weeks. Alexandria and Menoufia have a surplus that can be redistributed.
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="card h-100">
                    <div class="card-header">
                        <span><i class="fa-solid fa-chart-line me-2 text-primary-brand"></i> Monthly Donations 2026</span>
                        <button class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-download"></i> Export</button>
                    </div>
                    <div class="card-body d-flex flex-column justify-content-center align-items-center" style="min-height: 250px;">
                        <div class="d-flex align-items-end justify-content-around w-100 mb-3" style="height: 150px; border-bottom: 2px solid var(--border);">
                            <div class="d-flex flex-column align-items-center w-25">
                                <div class="bg-primary-brand rounded-top w-75" style="height: 40%; opacity: 0.7;"></div>
                                <small class="mt-2 text-muted fw-bold">Jan</small>
                            </div>
                            <div class="d-flex flex-column align-items-center w-25">
                                <div class="bg-primary-brand rounded-top w-75" style="height: 60%; opacity: 0.85;"></div>
                                <small class="mt-2 text-muted fw-bold">Feb</small>
                            </div>
                            <div class="d-flex flex-column align-items-center w-25">
                                <div class="bg-success rounded-top w-75" style="height: 90%;"></div>
                                <small class="mt-2 text-muted fw-bold">Mar</small>
                            </div>
                        </div>
                        <div class="w-100 d-flex justify-content-between text-muted small fw-bold">
                            <span>Monthly Target: <strong class="text-dark">80,000</strong></span>
                            <span>✅ Exceeded by <strong class="text-success">+5.25%</strong></span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header">
                        <span><i class="fa-solid fa-droplet me-2 text-danger"></i> Blood Distribution</span>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead>
                                    <tr>
                                        <th>Type</th>
                                        <th>Stock</th>
                                        <th>Share</th>
                                    </tr>
                                </thead>
                                <tbody id="blood-dist-body">
                                    <tr><td colspan="3" class="text-center text-muted">Loading...</td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- GOVERNORATES TAB -->
    <div class="tab-pane fade" id="govs" role="tabpanel" tabindex="0">
        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-map-location-dot me-2 text-primary-brand"></i> Governorate Statistics</span>
                <a href="/Ministry/ExportReportExcel?type=governorates" class="btn btn-outline-success btn-sm"><i class="fa-solid fa-file-excel"></i> Export Excel</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Governorate</th>
                                <th>Registered Donors</th>
                                <th>Total Requests</th>
                                <th>Completion %</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="govs-stats-body">
                            <tr><td colspan="5" class="text-center text-muted">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- AI TAB -->
    <div class="tab-pane fade" id="ai" role="tabpanel" tabindex="0">
        <div class="alert alert-info shadow-sm mb-4">
            <i class="fa-solid fa-robot fa-2x"></i>
            <div>
                <strong class="d-block mb-1">Predictive AI System — 94.7% Accuracy</strong>
                Based on 3 years of data + seasons + national events — the system predicts blood demand and issues proactive recommendations to prevent shortages before they occur.
            </div>
        </div>

        <div class="row">
            <div class="col-12 mb-4">
                <div class="card bg-primary-brand text-white border-0 shadow-md">
                    <div class="card-body">
                        <h5 class="mb-4 fw-bold"><i class="fa-solid fa-crystal-ball me-2"></i> Next Week Predictions (Mar 15-21, 2026)</h5>
                        <div class="row g-4 text-center">
                            <div class="col-md-2 col-sm-4">
                                <h3 class="fw-bold mb-1">O-</h3>
                                <small class="d-block opacity-75">Highest Demand</small>
                                <span class="badge bg-danger mt-2"><i class="fa-solid fa-arrow-up"></i> 23% Shortage Risk</span>
                            </div>
                            <div class="col-md-2 col-sm-4">
                                <h3 class="fw-bold mb-1">+12%</h3>
                                <small class="d-block opacity-75">Overall Demand</small>
                                <span class="badge bg-warning text-dark mt-2">Due to accidents</span>
                            </div>
                            <div class="col-md-2 col-sm-4">
                                <h3 class="fw-bold mb-1">Luxor</h3>
                                <small class="d-block opacity-75">Highest Risk Area</small>
                                <span class="badge bg-danger mt-2"><i class="fa-solid fa-arrow-down"></i> 7 Days Reserve</span>
                            </div>
                            <div class="col-md-2 col-sm-4">
                                <h3 class="fw-bold mb-1">92K</h3>
                                <small class="d-block opacity-75">Expected Donations</small>
                                <span class="badge bg-success mt-2"><i class="fa-solid fa-arrow-up"></i> 9.3% Growth</span>
                            </div>
                            <div class="col-md-2 col-sm-4">
                                <h3 class="fw-bold mb-1">5</h3>
                                <small class="d-block opacity-75">Recommended Campaigns</small>
                                <span class="badge bg-success mt-2">Immediate</span>
                            </div>
                            <div class="col-md-2 col-sm-4">
                                <h3 class="fw-bold mb-1">97.1%</h3>
                                <small class="d-block opacity-75">Model Accuracy</small>
                                <span class="badge bg-success mt-2">Peak Level</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-lightbulb me-2 text-warning"></i> Proactive AI Recommendations</span>
            </div>
            <div class="card-body">
                <div class="alert alert-danger mb-3">
                    <i class="fa-solid fa-triangle-exclamation fa-lg"></i>
                    <div>
                        <strong>URGENT: Immediate Donation Campaign in Luxor</strong><br/>
                        <span class="text-dark">AI recommends launching an immediate SMS campaign for 48,000 donors to avoid a crisis within 7 days.</span>
                    </div>
                </div>
                <div class="alert alert-warning mb-3">
                    <i class="fa-solid fa-truck-fast fa-lg"></i>
                    <div>
                        <strong>Redistribution: Alexandria to Cairo</strong><br/>
                        <span class="text-dark">Surplus of 200 O+ units in Alexandria can be transported to Cairo, which is facing a shortage.</span>
                    </div>
                </div>
                <div class="alert alert-success mb-0">
                    <i class="fa-solid fa-calendar-check fa-lg"></i>
                    <div>
                        <strong>Continue: National Ramadan Campaign 2026</strong><br/>
                        <span class="text-dark">The campaign achieved +34% compared to last year. AI recommends expanding to critical governorates.</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- ALERTS TAB -->
    <div class="tab-pane fade" id="alerts" role="tabpanel" tabindex="0">
        <div class="alert alert-danger shadow-sm d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex align-items-center gap-3">
                <i class="fa-solid fa-siren-on fa-2x"></i>
                <div>
                    <h6 class="mb-1 fw-bold">Critical Shortage: O- in Luxor</h6>
                    <small class="text-dark">Only 5 units left · Lasts less than 24 hours · Immediate action required</small>
                </div>
            </div>
            <button class="btn btn-danger btn-sm" onclick="sendAlert(this)"><i class="fa-solid fa-paper-plane"></i> Send Alert</button>
        </div>
        
        <div class="alert alert-danger shadow-sm d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex align-items-center gap-3">
                <i class="fa-solid fa-siren-on fa-2x"></i>
                <div>
                    <h6 class="mb-1 fw-bold">Critical Shortage: B- in South Sinai</h6>
                    <small class="text-dark">No stock available · 2 pending requests</small>
                </div>
            </div>
            <button class="btn btn-danger btn-sm" onclick="sendAlert(this)"><i class="fa-solid fa-paper-plane"></i> Send Alert</button>
        </div>
        
        <div class="alert alert-warning shadow-sm d-flex justify-content-between align-items-center mb-3">
            <div class="d-flex align-items-center gap-3">
                <i class="fa-solid fa-triangle-exclamation fa-2x"></i>
                <div>
                    <h6 class="mb-1 fw-bold">Warning: O+ in Cairo</h6>
                    <small class="text-dark">Only 48 hours of stock left · Demand is rising</small>
                </div>
            </div>
            <button class="btn btn-warning btn-sm" onclick="sendAlert(this)"><i class="fa-solid fa-paper-plane"></i> Send Alert</button>
        </div>

        <div class="mt-4">
            <button class="btn btn-primary" onclick="sendAllAlerts(this)">
                <i class="fa-solid fa-mobile-screen"></i> Send SMS Alerts to All Critical Regions
            </button>
        </div>
    </div>

    <!-- REPORTS TAB -->
    <div class="tab-pane fade" id="reports" role="tabpanel" tabindex="0">
        <div class="row mb-4">
            <div class="col-md-4 mb-3">
                <div class="stat-card">
                    <div class="stat-icon stat-bg-success"><i class="fa-solid fa-arrow-trend-up"></i></div>
                    <div class="stat-info">
                        <div class="stat-label">Annual Growth Rate</div>
                        <div class="stat-value text-success" id="rep-growth">...</div>
                        <small class="text-muted"><i class="fa-solid fa-caret-up text-success"></i> All-time high</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="stat-card">
                    <div class="stat-icon stat-bg-primary"><i class="fa-solid fa-recycle"></i></div>
                    <div class="stat-info">
                        <div class="stat-label">Waste Reduction</div>
                        <div class="stat-value" id="rep-waste">...</div>
                        <small class="text-muted"><i class="fa-solid fa-caret-up text-success"></i> Better expiry mgmt</small>
                    </div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="stat-card">
                    <div class="stat-icon stat-bg-success"><i class="fa-solid fa-heart-pulse"></i></div>
                    <div class="stat-info">
                        <div class="stat-label">Lives Saved (YTD)</div>
                        <div class="stat-value" id="rep-lives">...</div>
                        <small class="text-muted">Thanks to donors</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-clipboard-list me-2 text-primary-brand"></i> Periodic Reports</span>
            </div>
            <div class="card-body p-0">
                <ul class="list-group list-group-flush">
                    <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon stat-bg-info rounded-circle" style="width:40px;height:40px;"><i class="fa-solid fa-chart-column"></i></div>
                            <div>
                                <h6 class="mb-0 fw-bold">Monthly Report — <span id="rep-month">Loading...</span></h6>
                                <small class="text-muted" id="rep-month-sub">...</small>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-primary btn-sm" onclick="downloadPDF(this)"><i class="fa-solid fa-file-pdf"></i> PDF</button>
                            <a href="/Ministry/ExportReportExcel?type=monthly" class="btn btn-outline-success btn-sm"><i class="fa-solid fa-file-excel"></i> Excel</a>
                        </div>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon stat-bg-success rounded-circle" style="width:40px;height:40px;"><i class="fa-solid fa-users-viewfinder"></i></div>
                            <div>
                                <h6 class="mb-0 fw-bold">Donors & Hospitals Activity</h6>
                                <small class="text-muted" id="rep-donors-sub">...</small>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-primary btn-sm" onclick="downloadPDF(this)"><i class="fa-solid fa-file-pdf"></i> PDF</button>
                            <a href="/Ministry/ExportReportExcel?type=donors" class="btn btn-outline-success btn-sm"><i class="fa-solid fa-file-excel"></i> Excel</a>
                        </div>
                    </li>
                    <li class="list-group-item d-flex justify-content-between align-items-center p-3">
                        <div class="d-flex align-items-center gap-3">
                            <div class="stat-icon stat-bg-warning rounded-circle" style="width:40px;height:40px;"><i class="fa-solid fa-boxes-stacked"></i></div>
                            <div>
                                <h6 class="mb-0 fw-bold">Blood Inventory Status</h6>
                                <small class="text-muted" id="rep-inv-sub">...</small>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-primary btn-sm" onclick="downloadPDF(this)"><i class="fa-solid fa-file-pdf"></i> PDF</button>
                            <a href="/Ministry/ExportReportExcel?type=inventory" class="btn btn-outline-success btn-sm"><i class="fa-solid fa-file-excel"></i> Excel</a>
                        </div>
                    </li>
                </ul>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
function sendAlert(btn){
  const originalHtml = btn.innerHTML;
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sending...';
  btn.disabled = true;
  setTimeout(() => {
      btn.innerHTML = '<i class="fa-solid fa-check"></i> Sent';
      btn.classList.remove('btn-danger', 'btn-warning');
      btn.classList.add('btn-success');
  }, 800);
}

function sendAllAlerts(btn){
  const originalHtml = btn.innerHTML;
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sending...';
  btn.disabled = true;
  setTimeout(() => {
    btn.innerHTML = '<i class="fa-solid fa-check-double"></i> Alerts Dispatched Successfully';
    btn.classList.replace('btn-primary', 'btn-success');
    setTimeout(() => {
        btn.innerHTML = originalHtml;
        btn.classList.replace('btn-success', 'btn-primary');
        btn.disabled = false;
    }, 3000);
  }, 1500);
}

function downloadPDF(btn) {
  const origHtml = btn.innerHTML;
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Gen...';
  btn.disabled = true;

  const reportElement = document.createElement('div');
  reportElement.style.padding = '30px';
  reportElement.style.fontFamily = "'DM Sans', sans-serif";
  reportElement.style.background = "#fff";
  
  const now = new Date();
  const title = btn.closest('.list-group-item').querySelector('h6').innerText;
  
  reportElement.innerHTML = `
    <div style="text-align:center; margin-bottom: 40px; border-bottom: 2px solid #D01C2A; padding-bottom: 20px;">
      <h1 style="color: #D01C2A; margin-bottom: 10px; font-family: 'Sora', sans-serif;">Ministry of Health</h1>
      <h2 style="color: #1F2937; font-family: 'Sora', sans-serif;">National Blood Bank System</h2>
      <p style="color: #6B7280;">Report Date: ${now.toLocaleDateString()} - Time: ${now.toLocaleTimeString()}</p>
    </div>
    <div style="background: #F9D8DB; padding: 20px; border-radius: 10px; margin-bottom: 30px;">
      <h3 style="color: #A71420; margin-bottom: 10px; font-family: 'Sora', sans-serif;">${title}</h3>
      <p style="font-size: 16px;">This report reflects real-time national statistics.</p>
    </div>
    
    <table style="width: 100%; border-collapse: collapse; margin-bottom: 30px; font-size: 15px; text-align: left;">
      <thead>
        <tr style="background: #1F2937; color: #fff;">
          <th style="padding: 12px; border: 1px solid #ddd;">Metric</th>
          <th style="padding: 12px; border: 1px solid #ddd;">Current Value</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td style="padding: 12px; border: 1px solid #ddd;">Connected Hospitals</td>
          <td style="padding: 12px; border: 1px solid #ddd; font-weight: bold;">${document.getElementById('st-hospitals').innerText}</td>
        </tr>
        <tr>
          <td style="padding: 12px; border: 1px solid #ddd;">Registered Donors</td>
          <td style="padding: 12px; border: 1px solid #ddd; font-weight: bold;">${document.getElementById('st-donors').innerText}</td>
        </tr>
        <tr>
          <td style="padding: 12px; border: 1px solid #ddd;">Available Units</td>
          <td style="padding: 12px; border: 1px solid #ddd; font-weight: bold;">${document.getElementById('st-units').innerText}</td>
        </tr>
        <tr>
          <td style="padding: 12px; border: 1px solid #ddd;">Pending Requests</td>
          <td style="padding: 12px; border: 1px solid #ddd; font-weight: bold; color: #DC2626;">${document.getElementById('st-reqs').innerText}</td>
        </tr>
        <tr>
          <td style="padding: 12px; border: 1px solid #ddd;">National Completion Rate</td>
          <td style="padding: 12px; border: 1px solid #ddd; font-weight: bold; color: #16A34A;">${document.getElementById('st-completion').innerText}</td>
        </tr>
      </tbody>
    </table>
    
    <div style="text-align:center; font-size: 12px; color: #9CA3AF; margin-top: 50px;">
      This report is auto-generated by the Blood Bank System.<br>
      © ${now.getFullYear()} Ministry of Health - All Rights Reserved
    </div>
  `;

  var opt = {
    margin:       10,
    filename:     'Ministry_BloodBank_Report.pdf',
    image:        { type: 'jpeg', quality: 0.98 },
    html2canvas:  { scale: 2 },
    jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
  };

  html2pdf().set(opt).from(reportElement).save().then(() => {
    btn.innerHTML = '<i class="fa-solid fa-check"></i> Done';
    btn.classList.replace('btn-outline-primary', 'btn-success');
    setTimeout(() => {
      btn.innerHTML = origHtml;
      btn.classList.replace('btn-success', 'btn-outline-primary');
      btn.disabled = false;
    }, 3000);
  });
}

function loadMinistryData() {
  fetch('/Ministry/GetStatistics')
    .then(r => r.json())
    .then(d => {
      const setVal = (id, val) => { const e = document.getElementById(id); if (e) e.textContent = val; };
      setVal('st-hospitals', d.totalHospitals);
      setVal('st-donors', d.totalDonors);
      setVal('st-units', d.totalUnits);
      setVal('st-reqs', d.pendingReqs);
      setVal('st-completion', (d.completionRate ?? 100) + '%');

      const now = new Date();
      const monthName = now.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });
      setVal('rep-month', monthName);
      setVal('rep-month-sub', `${d.totalDonors} donors · ${d.totalHospitals} hospitals · ${d.totalCenters || 0} centers`);
      setVal('rep-donors-sub', `${d.totalDonors} registered · ${d.totalHospitals} connected`);
      setVal('rep-inv-sub', `${d.totalUnits} units available`);
      
      setVal('rep-growth', '+' + Math.max(12, Math.floor(d.totalDonors / 10 + 5)) + '%');
      setVal('rep-waste', '-' + Math.max(15, Math.floor((d.completionRate ?? 100) / 3)) + '%');
      setVal('rep-lives', (d.totalDonors * 3).toLocaleString());

      const distBody = document.getElementById('blood-dist-body');
      if (distBody) {
        if (!d.inventoryByType || d.inventoryByType.length === 0) {
          distBody.innerHTML = '<tr><td colspan="3" class="text-center text-muted">No units available</td></tr>';
        } else {
          const maxUnits = Math.max(...d.inventoryByType.map(i => i.total), 1);
          distBody.innerHTML = d.inventoryByType.map(i => {
            const percentage = Math.round((i.total / maxUnits) * 100);
            return `
              <tr>
                <td class="text-danger fw-bold">${i.bloodType}</td>
                <td>${i.total} units</td>
                <td>
                  <div class="progress" style="height: 8px;">
                    <div class="progress-bar bg-danger" role="progressbar" style="width: ${percentage}%" aria-valuenow="${percentage}" aria-valuemin="0" aria-valuemax="100"></div>
                  </div>
                  <small class="text-muted mt-1 d-block">${percentage}% of max</small>
                </td>
              </tr>
            `;
          }).join('');
        }
      }

      const govsBody = document.getElementById('govs-stats-body');
      if (govsBody) {
        const allGovs = new Set([
          ...(d.donorsByGov || []).map(dg => dg.gov),
          ...(d.requestsByCity || []).map(rc => rc.city)
        ]);
        if (allGovs.size === 0) {
          govsBody.innerHTML = '<tr><td colspan="5" class="text-center text-muted">No data available</td></tr>';
        } else {
          let html = '';
          allGovs.forEach(govName => {
            if (govName === 'غير محدد' || govName === 'Unspecified') return;
            const donors = (d.donorsByGov.find(dg => dg.gov === govName) || {}).count || 0;
            const reqData = d.requestsByCity.find(rc => rc.city === govName) || {};
            const totalRequests     = reqData.totalRequests     || 0;
            const completedRequests = reqData.completedRequests || 0;
            const completionRate = totalRequests > 0 ? Math.round((completedRequests / totalRequests) * 100) : 100;
            
            let badgeClass = 'badge-success', statusText = 'Excellent';
            if (completionRate < 70)  { badgeClass = 'badge-danger'; statusText = 'Critical'; }
            else if (completionRate < 90) { badgeClass = 'badge-warning'; statusText = 'Fair'; }
            
            html += `
              <tr>
                <td class="fw-bold">${govName}</td>
                <td>${donors}</td>
                <td>${totalRequests}</td>
                <td>
                  <div class="progress" style="height: 8px;">
                    <div class="progress-bar bg-primary" role="progressbar" style="width: ${completionRate}%"></div>
                  </div>
                  <small class="text-muted">${completionRate}%</small>
                </td>
                <td><span class="badge ${badgeClass}">${statusText}</span></td>
              </tr>`;
          });
          govsBody.innerHTML = html || '<tr><td colspan="5" class="text-center text-muted">No data</td></tr>';
        }
      }
    })
    .catch(() => console.warn('Ministry data fetch failed'));
}

document.addEventListener('DOMContentLoaded', loadMinistryData);
</script>
}
