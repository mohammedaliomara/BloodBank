@using BloodBank.Models
@{
    ViewData["Title"] = "Hospital Portal";
    var hospital = ViewBag.Hospital as Hospital;
    var activeRequestsCount = ViewBag.ActiveRequests ?? 0;
    var totalUnitsCount = ViewBag.TotalUnits ?? 0;
    var inventory = ViewBag.BloodInventory as Dictionary<string, int> ?? new Dictionary<string, int>();
    var recentRequests = ViewBag.RecentRequests as List<Request> ?? new List<Request>();
}

<div class="page-header mt-4">
    <div>
        <h2 class="page-title d-flex align-items-center gap-2">
            <i class="fa-solid fa-hospital text-primary-brand"></i>
            @(hospital?.Name ?? "Hospital Portal")
        </h2>
        <p class="text-muted mb-0 mt-1">
            <i class="fa-solid fa-location-dot me-1"></i>@(hospital?.Address ?? "—")
            @if (!string.IsNullOrEmpty(hospital?.Phone))
            {
                <span class="ms-3"><i class="fa-solid fa-phone me-1"></i>@hospital.Phone</span>
            }
        </p>
    </div>
    <div class="d-flex align-items-center gap-2">
        <span class="badge badge-success d-flex align-items-center gap-1">
            <span style="width:7px;height:7px;background:var(--color-success);border-radius:50%;animation:pulse 2s infinite;display:inline-block;"></span>
            Connected
        </span>
    </div>
</div>

<!-- Stats Row -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-primary"><i class="fa-solid fa-file-medical"></i></div>
            <div class="stat-info">
                <div class="stat-label">Active Requests</div>
                <div class="stat-value">@activeRequestsCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-success"><i class="fa-solid fa-droplet"></i></div>
            <div class="stat-info">
                <div class="stat-label">Units in Stock</div>
                <div class="stat-value">@totalUnitsCount</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-info"><i class="fa-solid fa-circle-check"></i></div>
            <div class="stat-info">
                <div class="stat-label">Completion Rate</div>
                <div class="stat-value" id="stat-pct">—</div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-warning"><i class="fa-solid fa-clock"></i></div>
            <div class="stat-info">
                <div class="stat-label">Avg. Delivery</div>
                <div class="stat-value">30 min</div>
            </div>
        </div>
    </div>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs" id="hospitalTabs">
    <li class="nav-item">
        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-new">
            <i class="fa-solid fa-plus me-1"></i> New Request
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-track">
            <i class="fa-solid fa-location-dot me-1"></i> Track Requests
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-inv">
            <i class="fa-solid fa-warehouse me-1"></i> Our Inventory
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-stats">
            <i class="fa-solid fa-chart-bar me-1"></i> Statistics
        </button>
    </li>
</ul>

<div class="tab-content">
    <!-- NEW REQUEST -->
    <div class="tab-pane fade show active" id="tab-new">
        <div class="alert alert-success d-flex align-items-start gap-2 mb-3">
            <i class="fa-solid fa-robot mt-1"></i>
            <div>
                <strong style="font-size:0.75rem;text-transform:uppercase;letter-spacing:.05em;">AI — National Inventory Analysis</strong><br>
                <small>Based on expected demand, AI found <strong>22 O- units</strong> at the nearest center (1.2 km) — estimated arrival within <strong>38 minutes</strong> of approval.</small>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-file-waveform text-primary-brand me-2"></i>Blood Request Details</span>
            </div>
            <div class="card-body">
                <div class="row g-3 mb-3">
                    <div class="col-md-6">
                        <label class="form-label">Patient Name</label>
                        <input class="form-control" id="patName" placeholder="Ahmed Mohamed">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Patient File No.</label>
                        <input class="form-control" id="patId" placeholder="P-2024-XXXX">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Department / Floor</label>
                        <input class="form-control" id="dept" placeholder="Cardiology — Floor 3">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Responsible Doctor</label>
                        <input class="form-control" id="doctor" placeholder="Dr. Mahmoud Riad">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Quantity (units)</label>
                        <input class="form-control" id="qty" type="number" placeholder="3" min="1" max="20">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label">Required By</label>
                        <input class="form-control" id="needed" type="datetime-local">
                    </div>
                    <div class="col-12">
                        <label class="form-label">Medical Notes</label>
                        <input class="form-control" id="notes" placeholder="Open-heart surgery — urgent case">
                    </div>
                </div>

                <!-- Blood Type Selector -->
                <div class="mb-3">
                    <label class="form-label">Required Blood Type</label>
                    <div class="d-flex flex-wrap gap-2 mt-1" id="bloodTypeGrid">
                        @foreach (var bt in new[]{"A+","A-","B+","B-","O+","O-","AB+","AB-"})
                        {
                            <button type="button" class="btn-blood-type @(bt == "A+" ? "selected" : "")" onclick="selB(this)">@bt</button>
                        }
                    </div>
                </div>

                <!-- Priority Selector -->
                <div class="mb-4">
                    <label class="form-label">Priority</label>
                    <div class="d-flex gap-2 mt-1" id="priorityGrid">
                        <button type="button" class="btn-priority selected priority-normal" onclick="selP(this,'n')">
                            <i class="fa-solid fa-circle-check me-1"></i>Normal
                        </button>
                        <button type="button" class="btn-priority priority-urgent" onclick="selP(this,'u')">
                            <i class="fa-solid fa-triangle-exclamation me-1"></i>Urgent
                        </button>
                        <button type="button" class="btn-priority priority-critical" onclick="selP(this,'c')">
                            <i class="fa-solid fa-heart-pulse me-1"></i>Critical / Emergency
                        </button>
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary flex-grow-1" id="submitBtn" onclick="submitReq()">
                        <i class="fa-solid fa-paper-plane me-2"></i>Submit Request
                    </button>
                    <button class="btn btn-outline-primary" onclick="clearForm()">
                        <i class="fa-solid fa-xmark me-1"></i>Clear
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- TRACK REQUESTS -->
    <div class="tab-pane fade" id="tab-track">
        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-location-dot text-primary-brand me-2"></i>Active Requests (@activeRequestsCount)</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead>
                            <tr>
                                <th>Request #</th>
                                <th>Blood Type</th>
                                <th>Quantity</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th>Track</th>
                            </tr>
                        </thead>
                        <tbody id="requestsTableBody">
                            @if (recentRequests != null && recentRequests.Any())
                            {
                                foreach (var r in recentRequests)
                                {
                                    var urgClass = (r.UrgencyLevel == "Critical" || r.UrgencyLevel == "Urgent") ? "badge-danger" : "badge-warning";
                                    var stClass = (r.Status == "Approved" || r.Status == "Completed") ? "badge-success" : "badge-info";
                                    <tr>
                                        <td><strong>#@r.RequestId</strong></td>
                                        <td><span class="badge badge-danger">@r.BloodType</span></td>
                                        <td>@r.QuantityNeeded units</td>
                                        <td><span class="badge @urgClass">@r.UrgencyLevel</span></td>
                                        <td><span class="badge @stClass">@r.Status</span></td>
                                        <td><button class="btn btn-outline-primary btn-sm" onclick="showTrack()"><i class="fa-solid fa-eye me-1"></i>Details</button></td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="6" class="text-center text-muted py-4">No active requests</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="card" id="trackDetail" style="display:none;">
            <div class="card-header">
                <span><i class="fa-solid fa-route text-primary-brand me-2"></i>Tracking Request #2401 — O- (3 units)</span>
            </div>
            <div class="card-body">
                <div class="alert alert-success mb-4">
                    <i class="fa-solid fa-robot"></i>
                    <div><strong>Live AI Update:</strong> Unit BU-2024-00814 en route from nearest center — ETA: 12 min. Vehicle: BB-47. Storage temp: 4°C ✅</div>
                </div>
                <div class="track-timeline">
                    <div class="track-step done"><div class="track-dot"><i class="fa-solid fa-check"></i></div><div class="track-info"><div class="track-title">Request Received</div><div class="track-sub">System began searching inventory immediately</div><div class="track-time">Mar 8, 10:14 AM</div></div></div>
                    <div class="track-step done"><div class="track-dot"><i class="fa-solid fa-check"></i></div><div class="track-info"><div class="track-title">Admin Approved</div><div class="track-sub">Unit BU-2024-00814 allocated (O- · 28 days remaining)</div><div class="track-time">Mar 8, 10:18 AM</div></div></div>
                    <div class="track-step active"><div class="track-dot"><i class="fa-solid fa-truck"></i></div><div class="track-info"><div class="track-title">In Transit</div><div class="track-sub">Vehicle BB-47 · 4°C · ETA: 12 min</div><div class="track-time">Now</div></div></div>
                    <div class="track-step pending"><div class="track-dot"><i class="fa-solid fa-hospital"></i></div><div class="track-info"><div class="track-title">Delivery</div><div class="track-sub">Awaiting arrival</div><div class="track-time">—</div></div></div>
                    <div class="track-step pending"><div class="track-dot"><i class="fa-solid fa-syringe"></i></div><div class="track-info"><div class="track-title">Transfusion</div><div class="track-sub">Pending</div><div class="track-time">—</div></div></div>
                </div>
            </div>
        </div>
    </div>

    <!-- INVENTORY -->
    <div class="tab-pane fade" id="tab-inv">
        <div class="alert alert-warning mb-3">
            <i class="fa-solid fa-robot"></i>
            <div><strong>AI — Inventory Analysis:</strong> Groups highlighted in red require immediate replenishment.</div>
        </div>
        <div class="row g-3 mb-3">
            @{
                var bloodTypes = new[] { "A+", "A-", "B+", "B-", "O+", "O-", "AB+", "AB-" };
                foreach (var bt in bloodTypes)
                {
                    var qty = inventory.ContainsKey(bt) ? inventory[bt] : 0;
                    var percent = Math.Min(100, (qty * 100) / 100);
                    var isLow = qty < 10;
                    var barColor = qty < 10 ? "var(--color-danger)" : (qty < 30 ? "var(--color-warning)" : "var(--color-success)");
                    var cardBorder = isLow ? "border-color: var(--color-danger); background: var(--color-danger-light);" : "";

                    <div class="col-6 col-md-3">
                        <div class="card mb-0 text-center p-3" style="@cardBorder">
                            <div style="font-size:1.4rem;font-weight:800;font-family:'Sora',sans-serif;">@bt</div>
                            <div class="text-muted" style="font-size:0.8rem;">@qty units @(qty < 5 ? "🚨" : qty < 10 ? "⚠️" : "")</div>
                            <div style="height:4px;background:var(--border);border-radius:2px;overflow:hidden;margin-top:8px;">
                                <div style="height:100%;width:@(percent)%;background:@barColor;border-radius:2px;"></div>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
        <button class="btn btn-primary" onclick="requestRefill(this)">
            <i class="fa-solid fa-boxes-stacking me-2"></i>Request Refill for Low Stock
        </button>
    </div>

    <!-- STATISTICS -->
    <div class="tab-pane fade" id="tab-stats">
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="stat-card"><div class="stat-icon stat-bg-info"><i class="fa-solid fa-calendar"></i></div><div class="stat-info"><div class="stat-label">Requests This Month</div><div class="stat-value" id="stat-total">—</div></div></div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card"><div class="stat-icon stat-bg-success"><i class="fa-solid fa-circle-check"></i></div><div class="stat-info"><div class="stat-label">Completed</div><div class="stat-value" id="stat-completed">—</div></div></div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card"><div class="stat-icon stat-bg-primary"><i class="fa-solid fa-droplet"></i></div><div class="stat-info"><div class="stat-label">Units Used</div><div class="stat-value" id="stat-units">—</div></div></div>
            </div>
            <div class="col-6 col-md-3">
                <div class="stat-card"><div class="stat-icon stat-bg-warning"><i class="fa-solid fa-percent"></i></div><div class="stat-info"><div class="stat-label">Success Rate</div><div class="stat-value" id="stat-rate">—</div></div></div>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-chart-bar text-primary-brand me-2"></i>Requests by Blood Type</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table mb-0">
                        <thead><tr><th>Blood Type</th><th>Requests</th><th>Completed</th><th>Success Rate</th></tr></thead>
                        <tbody id="stats-blood-tbody">
                            <tr><td colspan="4" class="text-center text-muted py-4"><i class="fa-solid fa-spinner fa-spin me-2"></i>Loading data...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.btn-blood-type {
    padding: 8px 14px; border-radius: var(--radius-sm); border: 1.5px solid var(--border);
    background: var(--color-bg); font-weight: 700; cursor: pointer; font-family: 'Sora', sans-serif;
    color: var(--text-secondary); transition: all var(--transition); min-width: 52px;
}
.btn-blood-type:hover { border-color: var(--color-primary); color: var(--color-primary); }
.btn-blood-type.selected { background: var(--color-primary); border-color: var(--color-primary); color: white; }
.btn-priority {
    flex: 1; padding: 10px 12px; border-radius: var(--radius-sm); border: 1.5px solid var(--border);
    background: var(--color-bg); font-weight: 600; cursor: pointer; font-family: 'DM Sans', sans-serif;
    color: var(--text-secondary); transition: all var(--transition); font-size: 0.875rem;
}
.btn-priority.selected.priority-normal { background: var(--color-success-light); border-color: var(--color-success); color: var(--color-success); }
.btn-priority.selected.priority-urgent { background: var(--color-warning-light); border-color: var(--color-warning); color: #b45309; }
.btn-priority.selected.priority-critical { background: var(--color-danger-light); border-color: var(--color-danger); color: var(--color-danger); }
/* Track Timeline */
.track-timeline { display: flex; flex-direction: column; gap: 0; }
.track-step { display: flex; gap: 16px; padding: 12px 0; position: relative; }
.track-step:not(:last-child)::after { content: ''; position: absolute; left: 16px; top: 44px; bottom: 0; width: 2px; background: var(--border); }
.track-dot { width: 34px; height: 34px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 13px; flex-shrink: 0; z-index: 1; }
.track-step.done .track-dot { background: var(--color-success-light); border: 2px solid var(--color-success); color: var(--color-success); }
.track-step.active .track-dot { background: var(--color-info-light); border: 2px solid var(--color-info); color: var(--color-info); animation: pulse 2s infinite; }
.track-step.pending .track-dot { background: var(--color-bg); border: 2px solid var(--border); color: var(--text-muted); }
.track-info { padding-top: 4px; }
.track-title { font-weight: 700; font-size: 0.9rem; }
.track-sub { font-size: 0.8rem; color: var(--text-secondary); margin-top: 2px; }
.track-time { font-size: 0.75rem; color: var(--text-muted); margin-top: 3px; }
@@keyframes pulse { 0%,100%{opacity:1;} 50%{opacity:0.4;} }
</style>

<script>
function selB(el) {
    document.querySelectorAll('.btn-blood-type').forEach(b => b.classList.remove('selected'));
    el.classList.add('selected');
}
function selP(el, t) {
    document.querySelectorAll('.btn-priority').forEach(b => { b.classList.remove('selected'); });
    el.classList.add('selected');
}
function clearForm() {
    ['patName','patId','dept','doctor','qty','needed','notes'].forEach(id => { const e = document.getElementById(id); if(e) e.value = ''; });
}
function submitReq() {
    const btn = document.getElementById('submitBtn');
    const bEl = document.querySelector('.btn-blood-type.selected');
    const bloodType = bEl ? bEl.textContent.trim() : 'A+';
    const qty = document.getElementById('qty').value || 1;
    const pEl = document.querySelector('.btn-priority.selected');
    let urgency = 'Normal';
    if (pEl) {
        if (pEl.classList.contains('priority-urgent')) urgency = 'Urgent';
        else if (pEl.classList.contains('priority-critical')) urgency = 'Critical';
    }
    const notes = document.getElementById('notes').value || '';
    const needed = document.getElementById('needed').value || new Date().toISOString();

    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>Sending...';
    btn.disabled = true;

    const formData = new URLSearchParams();
    formData.append('bloodType', bloodType);
    formData.append('quantity', qty);
    formData.append('urgencyLevel', urgency);
    formData.append('notes', notes);
    formData.append('neededAt', needed);

    fetch('/Hospital/SubmitRequest', {
        method: 'POST', body: formData,
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
    })
    .then(r => r.ok ? r.json() : Promise.reject())
    .then(() => {
        btn.innerHTML = '<i class="fa-solid fa-check me-2"></i>Submitted! AI is searching inventory...';
        btn.style.background = 'var(--color-success)';
        setTimeout(() => {
            btn.innerHTML = '<i class="fa-solid fa-paper-plane me-2"></i>Submit Request';
            btn.style.background = ''; btn.disabled = false;
            clearForm(); loadHospitalData();
        }, 3000);
    }).catch(() => {
        btn.innerHTML = '<i class="fa-solid fa-xmark me-2"></i>Submission Error';
        btn.style.background = 'var(--color-danger)';
        setTimeout(() => { btn.innerHTML = '<i class="fa-solid fa-paper-plane me-2"></i>Submit Request'; btn.style.background = ''; btn.disabled = false; }, 3000);
    });
}
function loadHospitalData() {
    fetch('/Hospital/GetMyRequests').then(r => r.json()).then(data => {
        const tbody = document.getElementById('requestsTableBody');
        if (tbody) {
            tbody.innerHTML = data.length === 0
                ? '<tr><td colspan="6" class="text-center text-muted py-4">No active requests</td></tr>'
                : data.map(r => {
                    const urg = (r.urgencyLevel === 'High' || r.urgencyLevel === 'Critical') ? 'badge-danger' : 'badge-warning';
                    const st = (r.status === 'Approved' || r.status === 'Completed') ? 'badge-success' : 'badge-info';
                    return `<tr>
                        <td><strong>#${r.requestId}</strong></td>
                        <td><span class="badge badge-danger">${r.bloodType}</span></td>
                        <td>${r.quantityNeeded} units</td>
                        <td><span class="badge ${urg}">${r.urgencyLevel}</span></td>
                        <td><span class="badge ${st}">${r.status}</span></td>
                        <td><button class="btn btn-outline-primary btn-sm" onclick="showTrack()"><i class="fa-solid fa-eye me-1"></i>Details</button></td>
                    </tr>`;
                }).join('');
            // Blood type stats
            const grouped = {};
            data.forEach(r => {
                if (!grouped[r.bloodType]) grouped[r.bloodType] = { total: 0, done: 0 };
                grouped[r.bloodType].total++;
                if (r.status === 'Approved' || r.status === 'Completed') grouped[r.bloodType].done++;
            });
            const statsTbody = document.getElementById('stats-blood-tbody');
            if (statsTbody) {
                const keys = Object.keys(grouped);
                statsTbody.innerHTML = keys.length === 0
                    ? '<tr><td colspan="4" class="text-center text-muted py-4">No data</td></tr>'
                    : keys.map(bt => {
                        const g = grouped[bt];
                        const pct = g.total > 0 ? Math.round(g.done / g.total * 100) : 100;
                        const cls = pct >= 90 ? 'badge-success' : pct >= 70 ? 'badge-warning' : 'badge-danger';
                        return `<tr><td><span class="badge badge-danger">${bt}</span></td><td>${g.total}</td><td>${g.done}</td><td><span class="badge ${cls}">${pct}%</span></td></tr>`;
                    }).join('');
            }
        }
    }).catch(() => {});
    fetch('/Hospital/GetStats').then(r => r.json()).then(d => {
        const rate = d.completionRate ?? 100;
        const el = id => document.getElementById(id);
        if(el('stat-total'))     el('stat-total').textContent     = d.totalThisMonth ?? 0;
        if(el('stat-completed')) el('stat-completed').textContent = d.completedThisMonth ?? 0;
        if(el('stat-units'))     el('stat-units').textContent     = d.totalUnitsUsed ?? 0;
        if(el('stat-pct'))       el('stat-pct').textContent       = rate + '%';
        if(el('stat-rate'))      el('stat-rate').textContent      = rate + '%';
    }).catch(() => {});
}
function showTrack() {
    const d = document.getElementById('trackDetail');
    d.style.display = d.style.display === 'none' ? 'block' : 'none';
    if (d.style.display === 'block') d.scrollIntoView({ behavior: 'smooth' });
}
function requestRefill(btn) {
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i>Sending...';
    btn.disabled = true;
    setTimeout(() => {
        btn.innerHTML = '<i class="fa-solid fa-check me-2"></i>Done — Expected within 24 hours';
        btn.style.background = 'var(--color-success)';
        setTimeout(() => { btn.innerHTML = '<i class="fa-solid fa-boxes-stacking me-2"></i>Request Refill for Low Stock'; btn.style.background = ''; btn.disabled = false; }, 3000);
    }, 1000);
}
document.addEventListener('DOMContentLoaded', loadHospitalData);
</script>
