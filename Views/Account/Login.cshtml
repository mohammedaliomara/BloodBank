@model BloodBank.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BloodLink</title>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,600;1,9..144,300&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --red:      #C0162B;
    --red-lt:   #E02540;
    --red-pale: #FFF0F2;
    --red-glow: rgba(192,22,43,0.18);
    --cream:    #FDF6F0;
    --ink:      #1A0508;
    --muted:    #9C7C82;
    --border:   #EAD9DC;
    --surface:  #FFFFFF;
  }

  *, *::before, *::after { box-sizing:border-box; margin:0; padding:0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    height: 100vh;
    display: flex;
    overflow: hidden;
  }

  /* ══ LEFT ══════════════════════════════════════ */
  .left {
    width: 46%;
    position: relative;
    background: #fff;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    border-right: 1px solid var(--border);
  }

  .left::before {
    content:'';
    position:absolute; inset:0;
    background-image: radial-gradient(circle, rgba(192,22,43,0.08) 1px, transparent 1px);
    background-size: 26px 26px;
    pointer-events:none;
  }

  .visual-wrap {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  .hero-svg {
    width: 360px;
    height: 380px;
    animation: floatAnim 5s ease-in-out infinite;
  }
  @@keyframes floatAnim {
    0%,100% { transform: translateY(0); }
    50%      { transform: translateY(-10px); }
  }

  .wordmark {
    font-family: 'Fraunces', serif;
    font-size: 1.75rem;
    font-weight: 300;
    color: var(--ink);
    letter-spacing: .02em;
    text-align: center;
    margin-top: 6px;
  }
  .wordmark em { font-style: italic; color: var(--red); }

  .tagline {
    font-size: 11px;
    letter-spacing: .14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 8px;
  }

  /* ══ RIGHT ══════════════════════════════════════ */
  .right {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 32px;
    background: var(--surface);
  }

  .page { width:100%; max-width:360px; animation:fadeIn .35s ease both; }
  .page.hidden { display:none; }
  @@keyframes fadeIn {
    from { opacity:0; transform:translateY(12px); }
    to   { opacity:1; transform:translateY(0); }
  }

  .form-logo {
    width:40px; height:40px; background:var(--red); border-radius:11px;
    display:flex; align-items:center; justify-content:center;
    font-size:19px; box-shadow:0 4px 18px var(--red-glow); margin-bottom:22px;
  }
  .form-title { font-family:'Fraunces',serif; font-weight:600; font-size:1.7rem; color:var(--ink); margin-bottom:4px; }
  .form-sub   { font-size:13px; color:var(--muted); margin-bottom:28px; }

  .field { margin-bottom:15px; }
  label  { display:block; font-size:12px; font-weight:600; letter-spacing:.04em; color:#3A1A20; margin-bottom:6px; }

  input, select {
    width:100%; height:46px;
    border:1.5px solid var(--border); border-radius:10px;
    padding:0 14px;
    font-family:'DM Sans',sans-serif; font-size:13.5px; color:var(--ink);
    background:var(--cream); outline:none;
    transition:border-color .2s, box-shadow .2s, background .2s;
    appearance:none;
  }
  input::placeholder { color:#C4AAAE; }
  input:focus, select:focus { border-color:var(--red); background:#fff; box-shadow:0 0 0 4px rgba(192,22,43,0.09); }

  .pw-wrap { position:relative; }
  .pw-wrap input { padding-right:44px; }
  .eye-btn { position:absolute; right:13px; top:50%; transform:translateY(-50%); background:none; border:none; cursor:pointer; color:var(--muted); font-size:16px; line-height:1; }

  .field-row { display:grid; grid-template-columns:1fr 1fr; gap:12px; }

  .btn-primary {
    width:100%; height:48px; background:var(--red); color:#fff;
    border:none; border-radius:10px;
    font-family:'DM Sans',sans-serif; font-size:14px; font-weight:600;
    cursor:pointer; display:flex; align-items:center; justify-content:center; gap:8px;
    margin-top:4px; box-shadow:0 4px 20px var(--red-glow);
    transition:background .2s, transform .15s, box-shadow .2s;
  }
  .btn-primary:hover { background:var(--red-lt); transform:translateY(-1px); box-shadow:0 6px 26px rgba(192,22,43,0.32); }
  .btn-primary:active { transform:translateY(0); }

  .divider { display:flex; align-items:center; gap:12px; margin:18px 0 14px; font-size:11px; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); }
  .divider::before, .divider::after { content:''; flex:1; height:1px; background:var(--border); }



  .link-row { text-align:center; font-size:13px; color:var(--muted); margin-top:14px; }
  .link-row a { color:var(--red); font-weight:600; text-decoration:none; cursor:pointer; }
  .link-row a:hover { text-decoration:underline; }

  .back-link { display:inline-flex; align-items:center; gap:5px; font-size:12.5px; color:var(--muted); cursor:pointer; margin-bottom:20px; transition:color .2s; }
  .back-link:hover { color:var(--ink); }

  .section-label { font-size:10.5px; font-weight:700; letter-spacing:.1em; text-transform:uppercase; color:var(--muted); margin:16px 0 10px; }

  .form-footer { text-align:center; font-size:11px; color:var(--border); margin-top:24px; }

  #registerPage { max-height:90vh; overflow-y:auto; padding-right:4px; scrollbar-width:thin; scrollbar-color:var(--border) transparent; }
</style>
</head>
<body>

<!-- ══ LEFT ══════════════════════════════════════════ -->
<aside class="left">
  <div class="visual-wrap">

    <svg class="hero-svg" viewBox="0 0 360 380" fill="none" xmlns="http://www.w3.org/2000/svg">

      <!-- ╔══════════════════════════════════════════╗ -->
      <!-- ║  TOP: BLOOD BAG + ARM (line art style)   ║ -->
      <!-- ╚══════════════════════════════════════════╝ -->

      <!-- Blood bag outline -->
      <rect x="108" y="18" width="72" height="90" rx="14" fill="white" stroke="#C0162B" stroke-width="2.2"/>
      <!-- bag top nubs -->
      <rect x="125" y="12" width="10" height="12" rx="4" fill="white" stroke="#C0162B" stroke-width="2"/>
      <rect x="145" y="8" width="10" height="16" rx="4" fill="white" stroke="#C0162B" stroke-width="2"/>
      <rect x="155" y="8" width="10" height="16" rx="4" fill="white" stroke="#C0162B" stroke-width="2"/>
      <!-- bag fill (red) -->
      <rect x="110" y="52" width="68" height="54" rx="8" fill="#C0162B"/>
      <!-- blood type label area -->
      <rect x="116" y="24" width="56" height="26" rx="6" fill="white" stroke="#C0162B" stroke-width="1.2"/>
      <rect x="122" y="29" width="30" height="3" rx="1.5" fill="#C0162B" opacity="0.4"/>
      <rect x="122" y="35" width="20" height="3" rx="1.5" fill="#C0162B" opacity="0.3"/>
      <rect x="156" y="26" width="12" height="12" rx="3" fill="#C0162B"/>
      <text x="162" y="36" text-anchor="middle" font-family="Georgia,serif" font-size="7" font-weight="700" fill="white">A+</text>
      <!-- bag bottom connectors -->
      <rect x="131" y="108" width="6" height="10" rx="2" fill="white" stroke="#C0162B" stroke-width="1.8"/>
      <rect x="151" y="108" width="6" height="10" rx="2" fill="white" stroke="#C0162B" stroke-width="1.8"/>

      <!-- tube from bag forming a HEART shape -->
      <!-- left tube from bag going left and curving into left half of heart -->
      <path d="M134 118 Q134 134 120 146 Q100 162 118 178 Q136 194 180 210"
            stroke="#C0162B" stroke-width="2.2" fill="none" stroke-linecap="round"/>
      <!-- right tube from bag going right and curving into right half of heart -->
      <path d="M154 118 Q154 134 168 146 Q188 162 170 178 Q152 194 180 210"
            stroke="#C0162B" stroke-width="2.2" fill="none" stroke-linecap="round"/>

      <!-- ARM (right side, line art) -->
      <!-- forearm silhouette -->
      <path d="M242 48 Q265 50 270 72 Q272 90 260 102 Q248 114 240 118"
            stroke="#3D1A20" stroke-width="2.2" fill="none" stroke-linecap="round"/>
      <path d="M228 44 Q252 42 260 62 Q266 80 256 96 Q244 112 236 118"
            stroke="#3D1A20" stroke-width="2.2" fill="none" stroke-linecap="round"/>
      <!-- fingers (hand raised) -->
      <!-- thumb -->
      <path d="M228 44 Q220 36 222 28 Q224 22 230 24 Q236 26 234 36"
            stroke="#3D1A20" stroke-width="2" fill="none" stroke-linecap="round"/>
      <!-- index -->
      <path d="M236 42 Q234 28 238 20 Q242 14 248 16 Q252 20 248 32"
            stroke="#3D1A20" stroke-width="2" fill="none" stroke-linecap="round"/>
      <!-- middle -->
      <path d="M245 43 Q244 27 249 18 Q253 12 259 14 Q264 18 260 32"
            stroke="#3D1A20" stroke-width="2" fill="none" stroke-linecap="round"/>
      <!-- ring -->
      <path d="M253 46 Q254 32 258 24 Q262 18 267 21 Q271 26 266 38"
            stroke="#3D1A20" stroke-width="2" fill="none" stroke-linecap="round"/>
      <!-- pinky -->
      <path d="M260 51 Q263 40 267 34 Q271 28 275 31 Q278 36 274 46"
            stroke="#3D1A20" stroke-width="2" fill="none" stroke-linecap="round"/>
      <!-- IV patch on wrist -->
      <rect x="237" y="108" width="18" height="11" rx="3" fill="white" stroke="#3D1A20" stroke-width="1.5"/>
      <line x1="246" y1="108" x2="246" y2="119" stroke="#3D1A20" stroke-width="1"/>
      <line x1="237" y1="113" x2="255" y2="113" stroke="#3D1A20" stroke-width="1"/>
      <!-- tube from arm going to meet the bag tube -->
      <path d="M241 119 Q230 130 210 148 Q192 164 180 210"
            stroke="#C0162B" stroke-width="2.2" fill="none" stroke-linecap="round"/>

      <!-- ╔══════════════════════════════════════════╗ -->
      <!-- ║  MIDDLE: ORBITING CELLS + PULSE RINGS    ║ -->
      <!-- ╚══════════════════════════════════════════╝ -->

      <!-- outer glow ring 1 -->
      <circle cx="180" cy="262" r="58" fill="none" stroke="#C0162B" stroke-width="1" opacity="0.12"/>
      <!-- outer glow ring 2 -->
      <circle cx="180" cy="262" r="72" fill="none" stroke="#C0162B" stroke-width="0.7" opacity="0.08"/>

      <!-- pulse expand rings (animated) -->
      <circle cx="180" cy="262" r="46" fill="none" stroke="#C0162B" stroke-width="1.5" opacity="0">
        <animate attributeName="r"       values="46;80"  dur="2.4s" repeatCount="indefinite"/>
        <animate attributeName="opacity" values="0.4;0"  dur="2.4s" repeatCount="indefinite"/>
      </circle>
      <circle cx="180" cy="262" r="46" fill="none" stroke="#C0162B" stroke-width="1.5" opacity="0">
        <animate attributeName="r"       values="46;80"  dur="2.4s" begin="1.2s" repeatCount="indefinite"/>
        <animate attributeName="opacity" values="0.4;0"  dur="2.4s" begin="1.2s" repeatCount="indefinite"/>
      </circle>

      <!-- orbiting red-cell dots (group rotates) -->
      <g transform-origin="180 262">
        <animateTransform attributeName="transform" type="rotate"
          from="0 180 262" to="360 180 262" dur="8s" repeatCount="indefinite"/>
        <circle cx="180" cy="210" r="6"  fill="#C0162B" opacity="0.85"/>
        <circle cx="228" cy="278" r="4.5" fill="#C0162B" opacity="0.6"/>
        <circle cx="132" cy="278" r="4.5" fill="#C0162B" opacity="0.6"/>
      </g>
      <!-- counter-orbit smaller dots -->
      <g transform-origin="180 262">
        <animateTransform attributeName="transform" type="rotate"
          from="360 180 262" to="0 180 262" dur="12s" repeatCount="indefinite"/>
        <circle cx="180" cy="222" r="3" fill="#E02540" opacity="0.45"/>
        <circle cx="218" cy="292" r="3" fill="#E02540" opacity="0.45"/>
        <circle cx="142" cy="292" r="3" fill="#E02540" opacity="0.45"/>
        <circle cx="144" cy="232" r="2.5" fill="#C0162B" opacity="0.3"/>
        <circle cx="216" cy="232" r="2.5" fill="#C0162B" opacity="0.3"/>
      </g>

      <!-- dashed orbit path -->
      <circle cx="180" cy="262" r="52" fill="none" stroke="#C0162B" stroke-width="0.9"
              stroke-dasharray="4 6" opacity="0.18"/>

      <!-- Blood drop center (outline style, red) -->
      <path d="M180 218 C180 218 204 248 204 264 C204 277.25 193.25 288 180 288 C166.75 288 156 277.25 156 264 C156 248 180 218 180 218Z"
            fill="white" stroke="#C0162B" stroke-width="2.5"/>
      <!-- drop inner fill glow -->
      <path d="M180 232 C180 232 198 254 198 264 C198 273.9 189.9 282 180 282 C170.1 282 162 273.9 162 264 C162 254 180 232 180 232Z"
            fill="#C0162B" opacity="0.08"/>
      <!-- drop inner shine -->
      <path d="M168 260 Q172 250 178 252" stroke="white" stroke-width="1.5" fill="none" stroke-linecap="round" opacity="0.8"/>

      <!-- ╔══════════════════════════════════════════╗ -->
      <!-- ║  BOTTOM: HEARTBEAT LINE                  ║ -->
      <!-- ╚══════════════════════════════════════════╝ -->
      <polyline
        points="34,340 70,340 82,320 92,360 104,316 116,340 180,340 194,328 200,348 206,340 290,340 302,320 312,360 322,316 334,340 346,340"
        stroke="#C0162B" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round" opacity="0.6"/>

      <!-- animated pulse dot -->
      <circle r="4" fill="#C0162B" opacity="0">
        <animateMotion
          path="M34,340 L70,340 L82,320 L92,360 L104,316 L116,340 L180,340 L194,328 L200,348 L206,340 L346,340"
          dur="3s" repeatCount="indefinite"/>
        <animate attributeName="opacity" values="0;1;1;0" dur="3s" repeatCount="indefinite"/>
      </circle>

      <!-- small sparkle dots -->
      <circle cx="46" cy="200" r="3" fill="#C0162B" opacity="0.15"/>
      <circle cx="314" cy="200" r="3" fill="#C0162B" opacity="0.15"/>
      <circle cx="180" cy="370" r="3" fill="#C0162B" opacity="0.1"/>

    </svg>

    <div class="wordmark">Blood <em>Donation</em></div>
    <div class="tagline">Every drop saves a life</div>
  </div>
</aside>

<!-- ══ RIGHT ══════════════════════════════════════════ -->
<main class="right">

  <!-- LOGIN -->
  <div class="page" id="loginPage">
    <div class="form-logo">🩸</div>
    <h2 class="form-title">Sign in</h2>
    <p class="form-sub">Enter your credentials to continue</p>

    @if (!ViewData.ModelState.IsValid)
    {
      <div style="background:#fff0f2;border:1.5px solid #ffd6da;border-radius:10px;padding:11px 14px;margin-bottom:14px;font-size:13px;color:#C8102E;">
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
          <div>⚠️ @error.ErrorMessage</div>
        }
      </div>
    }

    <form method="post" asp-action="Login" asp-controller="Account" id="loginForm">
      @Html.AntiForgeryToken()
      <div class="field">
        <label>Work Email</label>
        <input id="emailInput" name="Username" type="email" placeholder="user@bloodlink.org" value="@Model?.Username" required>
      </div>
      <div class="field">
        <label>Password</label>
        <div class="pw-wrap">
          <input id="pw" name="Password" type="password" placeholder="••••••••" required>
          <button type="button" class="eye-btn" onclick="togglePw()">👁</button>
        </div>
      </div>

      <button type="submit" class="btn-primary">Sign In &nbsp;→</button>
    </form>



    <div class="link-row">Don't have an account? <a onclick="goTo('register')">Create new account</a></div>
    <p class="form-footer">© 2026 BloodLink · Blood Donation Management System</p>
  </div>

  <!-- REGISTER -->
  <div class="page hidden" id="registerPage">
    <div class="back-link" onclick="goTo('login')">← Back to Sign In</div>
    <div class="form-logo">🩸</div>
    <h2 class="form-title">Create Account</h2>
    <p class="form-sub">Join BloodLink — fill in your details below</p>

    <form method="post" asp-action="Register" asp-controller="Account" id="registerForm">
      @Html.AntiForgeryToken()

      <div class="section-label">Personal Information</div>
      <div class="field-row">
        <div class="field"><label>First Name</label><input type="text" name="FirstName" placeholder="Ahmed" required></div>
        <div class="field"><label>Last Name</label><input type="text" name="LastName" placeholder="Sami" required></div>
      </div>
      <div class="field"><label>National ID</label><input type="text" name="NationalId" placeholder="29XXXXXXXXXXX" maxlength="14"></div>
      <div class="field-row">
        <div class="field"><label>Date of Birth</label><input type="date" name="DateOfBirth" required></div>
        <div class="field"><label>Gender</label><select name="Gender"><option value="">Select</option><option>Male</option><option>Female</option></select></div>
      </div>

      <div class="section-label">Medical Information</div>
      <div class="field-row">
        <div class="field"><label>Blood Type</label><select name="BloodType"><option value="">Select</option><option>A+</option><option>A-</option><option>B+</option><option>B-</option><option>AB+</option><option>AB-</option><option>O+</option><option>O-</option></select></div>
      </div>

      <div class="section-label">Contact &amp; Access</div>
      <div class="field"><label>Email Address</label><input type="email" name="Email" placeholder="user@bloodlink.org" required></div>
      <div class="field"><label>Phone Number</label><input type="tel" name="PhoneNumber" placeholder="+20 1XX XXX XXXX"></div>
      <div class="field"><label>Governorate</label><select name="Governorate"><option value="">Select governorate</option><option>Cairo</option><option>Giza</option><option>Alexandria</option><option>Gharbia</option><option>Dakahlia</option><option>Sharqia</option><option>Qalyubia</option><option>Beheira</option><option>Menufia</option><option>Other</option></select></div>
      <div class="field"><label>Password</label><div class="pw-wrap"><input id="rpw" type="password" name="Password" placeholder="Min 8 characters" required minlength="8"><button type="button" class="eye-btn" onclick="toggleRpw()">👁</button></div></div>
      <div class="field"><label>Confirm Password</label><input type="password" name="ConfirmPassword" placeholder="Re-enter password" required></div>

      <button type="submit" class="btn-primary" style="margin-top:10px">Create Account &nbsp;→</button>
      <div class="link-row" style="margin-top:12px">Already have an account? <a onclick="goTo('login')">Sign in</a></div>
    </form>
  </div>

  <!-- SUCCESS -->
  <div class="page hidden" id="successPage" style="text-align:center">
    <div style="font-size:52px;margin-bottom:18px">🩸</div>
    <h2 class="form-title" style="text-align:center">Account Created!</h2>
    <p class="form-sub" style="text-align:center;max-width:280px;margin:8px auto 28px">Welcome to BloodLink. Your account is pending verification — a confirmation email is on its way.</p>
    <button class="btn-primary" onclick="goTo('login')">← Back to Sign In</button>
  </div>

</main>

<script>
  function goTo(page) {
    document.querySelectorAll('.page').forEach(p => p.classList.add('hidden'));
    const t = document.getElementById(page+'Page');
    t.classList.remove('hidden');
    t.style.animation='none'; t.offsetHeight; t.style.animation='';
    if(page==='register') t.scrollTop=0;
  }
  function togglePw()  { const p=document.getElementById('pw');  p.type=p.type==='password'?'text':'password'; }
  function toggleRpw() { const p=document.getElementById('rpw'); p.type=p.type==='password'?'text':'password'; }

</script>
</body>
</html>
