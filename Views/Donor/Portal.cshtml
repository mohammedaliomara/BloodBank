  </div>
  <div class="bn" onclick="showScreen('sc-history')">
    <div class="bn-ico">🩸</div><div class="bn-lbl">History</div>
  </div>
  <div class="bn" onclick="showScreen('sc-profile')">
    <div class="bn-ico">👤</div><div class="bn-lbl">Profile</div>
