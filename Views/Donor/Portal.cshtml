@using BloodBank.Models
@{
    ViewData["Title"] = "Donor Portal";
    var fullName     = ViewBag.FullName     ?? "Guest";
    var initials     = ViewBag.Initials     ?? "?";
    var bloodType    = ViewBag.BloodType    ?? "—";
    var governorate  = ViewBag.Governorate  ?? "—";
    var totalDon     = (int)(ViewBag.TotalDonations ?? 0);
    var livesSaved   = (int)(ViewBag.LivesSaved     ?? 0);
    var isEligible   = (bool)(ViewBag.IsEligible    ?? true);
    var daysLeft     = (int)(ViewBag.DaysUntilEligible ?? 0);
    var unreadCount  = (int)(ViewBag.UnreadNotifications ?? 0);
    var lastAppt     = ViewBag.LastAppointment  as Appointment;
    var nextAppt     = ViewBag.NextAppointment  as Appointment;
    var centers      = ViewBag.DonationCenters  as List<BloodBank.Models.BloodCenter> ?? new();
}

<div class="page-header mt-4">
    <div class="d-flex align-items-center gap-3">
        <div class="bg-primary-brand text-white rounded d-flex align-items-center justify-content-center fw-bold" style="width: 48px; height: 48px; font-size: 20px;">
            @initials
        </div>
        <div>
            <h2 class="page-title mb-0">Welcome back, @fullName!</h2>
            <div class="text-muted small">
                <span class="badge badge-primary me-2">@bloodType</span>
                <span><i class="fa-solid fa-location-dot me-1"></i> @governorate</span>
            </div>
        </div>
    </div>
    @if (isEligible) {
        <span class="badge badge-success fs-6"><i class="fa-solid fa-circle-check"></i> Ready to Donate</span>
    } else {
        <span class="badge badge-warning fs-6"><i class="fa-solid fa-clock"></i> Eligible in @daysLeft days</span>
    }
</div>

<!-- TOP STATS -->
<div class="row mb-4">
    <div class="col-md-4 col-sm-12 mb-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-primary"><i class="fa-solid fa-hand-holding-droplet"></i></div>
            <div class="stat-info">
                <div class="stat-label">Total Donations</div>
                <div class="stat-value text-primary-brand">@totalDon</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-12 mb-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-success"><i class="fa-solid fa-heart-pulse"></i></div>
            <div class="stat-info">
                <div class="stat-label">Lives Saved</div>
                <div class="stat-value text-success">@livesSaved</div>
            </div>
        </div>
    </div>
    <div class="col-md-4 col-sm-12 mb-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-danger"><i class="fa-solid fa-droplet"></i></div>
            <div class="stat-info">
                <div class="stat-label">Blood Type</div>
                <div class="stat-value text-danger">@bloodType</div>
            </div>
        </div>
    </div>
</div>

<!-- URGENT ALERT -->
@if (isEligible && (bloodType == "O-" || bloodType == "O+")) {
<div class="alert alert-danger shadow-sm d-flex justify-content-between align-items-center mb-4" id="urgentAlert">
    <div class="d-flex gap-3 align-items-center">
        <div class="text-danger"><i class="fa-solid fa-siren-on fa-2x"></i></div>
        <div>
            <h6 class="fw-bold mb-1">URGENT REQUEST — NOW</h6>
            <p class="mb-0 small text-dark">Cairo General Hospital urgently needs @bloodType blood. AI Match: 99%.</p>
        </div>
    </div>
    <div class="d-flex gap-2">
        <button class="btn btn-danger btn-sm fw-bold" onclick="respondUrgent(this)">Respond Now</button>
        <button class="btn btn-outline-secondary btn-sm" onclick="document.getElementById('urgentAlert').style.display='none'">Not Now</button>
    </div>
</div>
}

<!-- TABS -->
<ul class="nav nav-tabs" id="donorTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="home-tab" data-bs-toggle="tab" data-bs-target="#home" type="button" role="tab">
            <i class="fa-solid fa-house me-2"></i> Home
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="book-tab" data-bs-toggle="tab" data-bs-target="#book" type="button" role="tab">
            <i class="fa-solid fa-calendar-check me-2"></i> Book Appointment
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="history-tab" data-bs-toggle="tab" data-bs-target="#history" type="button" role="tab">
            <i class="fa-solid fa-clock-rotate-left me-2"></i> History
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="profile-tab" data-bs-toggle="tab" data-bs-target="#profile" type="button" role="tab">
            <i class="fa-solid fa-user me-2"></i> Profile
        </button>
    </li>
</ul>

<div class="tab-content" id="donorTabsContent">
    
    <!-- HOME TAB -->
    <div class="tab-pane fade show active" id="home" role="tabpanel" tabindex="0">
        <div class="row">
            <div class="col-lg-6 mb-4">
                <div class="card h-100">
                    <div class="card-header">
                        <span><i class="fa-solid fa-location-dot me-2 text-primary-brand"></i> Nearby Centers</span>
                        <button class="btn btn-sm btn-outline-primary" onclick="document.getElementById('book-tab').click()">View All</button>
                    </div>
                    <div class="card-body p-0">
                        <ul class="list-group list-group-flush">
                            @if (centers != null && centers.Any())
                            {
                                foreach (var c in centers.Take(3))
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center p-3" style="cursor: pointer;" onclick="document.getElementById('book-tab').click()">
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="bg-primary-light text-primary-brand rounded p-2"><i class="fa-solid fa-hospital fa-lg"></i></div>
                                            <div>
                                                <h6 class="mb-0 fw-bold">@c.Name</h6>
                                                <small class="text-muted">📍 @c.Address · @c.Governorate</small>
                                            </div>
                                        </div>
                                        <span class="badge badge-success">Ready</span>
                                    </li>
                                }
                            }
                            else
                            {
                                <li class="list-group-item text-center text-muted py-4">No nearby donation centers available.</li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 mb-4">
                <div class="card h-100">
                    <div class="card-header">
                        <span><i class="fa-solid fa-clipboard-check me-2 text-success"></i> Last Donation</span>
                        <button class="btn btn-sm btn-outline-primary" onclick="document.getElementById('history-tab').click()">Full History</button>
                    </div>
                    <div class="card-body d-flex flex-column justify-content-center">
                        @if (lastAppt != null) {
                            <div class="d-flex align-items-center gap-3 p-3 border rounded mb-3">
                                <div class="bg-primary-brand text-white rounded p-3 fw-bold fs-5">@bloodType</div>
                                <div>
                                    <h6 class="mb-1 fw-bold">@(lastAppt.Hospital?.Name ?? "Blood Center")</h6>
                                    <small class="text-muted">@lastAppt.AppointmentDate.ToString("MMMM dd, yyyy")</small>
                                </div>
                                <div class="ms-auto">
                                    <span class="badge badge-success">Completed</span>
                                </div>
                            </div>
                            <button class="btn btn-primary" onclick="document.getElementById('book-tab').click()">📅 Book Next Appointment</button>
                        } else {
                            <div class="text-center py-4">
                                <i class="fa-solid fa-droplet-slash fa-3x text-muted mb-3"></i>
                                <p class="text-muted">No donations yet — book your first appointment!</p>
                                <button class="btn btn-primary mt-2" onclick="document.getElementById('book-tab').click()">📅 Book Now</button>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- BOOK APPOINTMENT TAB -->
    <div class="tab-pane fade" id="book" role="tabpanel" tabindex="0">
        <div class="card">
            <div class="card-body">
                <h4 class="fw-bold mb-1">Book an Appointment</h4>
                <p class="text-muted mb-4">Follow the steps to schedule your donation.</p>

                <!-- Steps Navigation -->
                <ul class="nav nav-pills nav-fill mb-4 border-bottom pb-3" id="bookSteps">
                    <li class="nav-item">
                        <button class="nav-link active fw-bold" id="step1-tab" data-bs-toggle="pill" data-bs-target="#step1" type="button">1. Center</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold" id="step2-tab" data-bs-toggle="pill" data-bs-target="#step2" type="button" @(!isEligible ? "disabled" : "")>2. Questionnaire</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold" id="step3-tab" data-bs-toggle="pill" data-bs-target="#step3" type="button" disabled>3. Date & Time</button>
                    </li>
                    <li class="nav-item">
                        <button class="nav-link fw-bold" id="step4-tab" data-bs-toggle="pill" data-bs-target="#step4" type="button" disabled>4. Confirm</button>
                    </li>
                </ul>

                <div class="tab-content" id="bookStepsContent">
                    <!-- Step 1: Center -->
                    <div class="tab-pane fade show active" id="step1">
                        <h6 class="fw-bold mb-3">Select a Donation Center</h6>
                        <div class="row">
                            @if (centers != null && centers.Any())
                            {
                                foreach (var c in centers)
                                {
                                    <div class="col-md-6 mb-3">
                                        <div class="card h-100 border hover-shadow" style="cursor:pointer;" onclick="selectCenter(this, @c.Id, '@c.Name')">
                                            <div class="card-body d-flex align-items-center gap-3">
                                                <div class="bg-primary-light text-primary-brand rounded p-3"><i class="fa-solid fa-hospital fa-lg"></i></div>
                                                <div>
                                                    <h6 class="mb-1 fw-bold">@c.Name</h6>
                                                    <small class="text-muted d-block">📍 @c.Address</small>
                                                    <small class="text-muted d-block">📞 @c.PhoneNumber</small>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="col-12 text-center text-muted">No centers available.</div>
                            }
                        </div>
                        <div class="text-end mt-3">
                            <button class="btn btn-primary" onclick="nextStep('step2')" id="btnNext1" disabled>Continue to Questionnaire <i class="fa-solid fa-arrow-right"></i></button>
                        </div>
                    </div>

                    <!-- Step 2: Questionnaire -->
                    <div class="tab-pane fade" id="step2">
                        <h6 class="fw-bold mb-3">Medical Questionnaire</h6>
                        <div class="alert alert-info">
                            <i class="fa-solid fa-circle-info me-2"></i> Please answer truthfully to ensure the safety of both donor and recipient.
                        </div>
                        
                        <form id="questionnaireForm">
                            <div class="mb-3">
                                <label class="form-label fw-bold">1. Are you currently taking any antibiotics or medications for infection?</label>
                                <div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="q1" id="q1_yes" value="yes">
                                        <label class="form-check-label text-danger" for="q1_yes">Yes</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="q1" id="q1_no" value="no" checked>
                                        <label class="form-check-label text-success" for="q1_no">No</label>
                                    </div>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="form-label fw-bold">2. Have you traveled outside the country in the last 6 months?</label>
                                <div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="q2" id="q2_yes" value="yes">
                                        <label class="form-check-label text-danger" for="q2_yes">Yes</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="q2" id="q2_no" value="no" checked>
                                        <label class="form-check-label text-success" for="q2_no">No</label>
                                    </div>
                                </div>
                            </div>
                            <div class="mb-4">
                                <label class="form-label fw-bold">3. Have you had a tattoo or piercing in the last 6 months?</label>
                                <div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="q3" id="q3_yes" value="yes">
                                        <label class="form-check-label text-danger" for="q3_yes">Yes</label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <input class="form-check-input" type="radio" name="q3" id="q3_no" value="no" checked>
                                        <label class="form-check-label text-success" for="q3_no">No</label>
                                    </div>
                                </div>
                            </div>
                        </form>
                        
                        <div class="d-flex justify-content-between mt-4">
                            <button class="btn btn-outline-secondary" onclick="prevStep('step1')"><i class="fa-solid fa-arrow-left"></i> Back</button>
                            <button class="btn btn-primary" onclick="validateQuestionnaire()">Continue to Date & Time <i class="fa-solid fa-arrow-right"></i></button>
                        </div>
                    </div>

                    <!-- Step 3: Date & Time -->
                    <div class="tab-pane fade" id="step3">
                        <h6 class="fw-bold mb-3">Select Date & Time</h6>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Date</label>
                                <input type="date" class="form-control" id="apptDate" onchange="checkTimeSlot()">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Time</label>
                                <select class="form-select" id="apptTime" onchange="checkTimeSlot()">
                                    <option value="">Select a time</option>
                                    <option value="09:00">09:00 AM</option>
                                    <option value="10:00">10:00 AM</option>
                                    <option value="11:30">11:30 AM</option>
                                    <option value="14:00">02:00 PM</option>
                                    <option value="16:00">04:00 PM</option>
                                </select>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between mt-4">
                            <button class="btn btn-outline-secondary" onclick="prevStep('step2')"><i class="fa-solid fa-arrow-left"></i> Back</button>
                            <button class="btn btn-primary" onclick="nextStep('step4')" id="btnNext3" disabled>Review Booking <i class="fa-solid fa-arrow-right"></i></button>
                        </div>
                    </div>

                    <!-- Step 4: Confirm -->
                    <div class="tab-pane fade" id="step4">
                        <div class="alert alert-success d-flex align-items-center gap-3">
                            <i class="fa-solid fa-circle-check fa-2x"></i>
                            <div>
                                <h6 class="mb-1 fw-bold">Almost Done!</h6>
                                <p class="mb-0 small">Please review your appointment details before confirming.</p>
                            </div>
                        </div>
                        
                        <div class="card border-0 bg-light mb-4">
                            <div class="card-body">
                                <div class="row mb-2">
                                    <div class="col-4 text-muted">Donor Name</div>
                                    <div class="col-8 fw-bold">@fullName</div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-4 text-muted">Center</div>
                                    <div class="col-8 fw-bold" id="confirmCenter">...</div>
                                </div>
                                <div class="row mb-2">
                                    <div class="col-4 text-muted">Date & Time</div>
                                    <div class="col-8 fw-bold" id="confirmDateTime">...</div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-between mt-4">
                            <button class="btn btn-outline-secondary" onclick="prevStep('step3')" id="btnBack4"><i class="fa-solid fa-arrow-left"></i> Back</button>
                            <button class="btn btn-success" onclick="submitBooking(this)" id="btnConfirmBooking"><i class="fa-solid fa-check"></i> Confirm Appointment</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- HISTORY TAB -->
    <div class="tab-pane fade" id="history" role="tabpanel" tabindex="0">
        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-clock-rotate-left me-2 text-primary-brand"></i> Donation History</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Date</th>
                                <th>Center</th>
                                <th>Blood Type</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="history-tbody">
                            <tr><td colspan="4" class="text-center text-muted">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- PROFILE TAB -->
    <div class="tab-pane fade" id="profile" role="tabpanel" tabindex="0">
        <div class="card mb-4">
            <div class="card-header">
                <span><i class="fa-solid fa-user me-2 text-primary-brand"></i> Personal Information</span>
            </div>
            <div class="card-body">
                <div class="row mb-3 pb-3 border-bottom">
                    <div class="col-md-3 text-muted fw-bold">Full Name</div>
                    <div class="col-md-9">@fullName</div>
                </div>
                <div class="row mb-3 pb-3 border-bottom">
                    <div class="col-md-3 text-muted fw-bold">Blood Type</div>
                    <div class="col-md-9 text-danger fw-bold">@bloodType</div>
                </div>
                <div class="row mb-3 pb-3 border-bottom">
                    <div class="col-md-3 text-muted fw-bold">Governorate</div>
                    <div class="col-md-9">@governorate</div>
                </div>
                <div class="row mb-3 pb-3">
                    <div class="col-md-3 text-muted fw-bold">Account Status</div>
                    <div class="col-md-9">
                        @if (isEligible) {
                            <span class="badge badge-success">Eligible to Donate</span>
                        } else {
                            <span class="badge badge-warning">Cooldown Period (@daysLeft days left)</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
<script>
// Booking Logic
let selectedCenterId = null;
let selectedCenterName = null;

function selectCenter(card, id, name) {
    document.querySelectorAll('#step1 .card').forEach(c => c.classList.remove('border-danger', 'bg-primary-light'));
    card.classList.add('border-danger', 'bg-primary-light');
    selectedCenterId = id;
    selectedCenterName = name;
    document.getElementById('btnNext1').disabled = false;
}

function validateQuestionnaire() {
    const q1 = document.querySelector('input[name="q1"]:checked').value;
    const q2 = document.querySelector('input[name="q2"]:checked').value;
    const q3 = document.querySelector('input[name="q3"]:checked').value;
    
    if (q1 === 'yes' || q2 === 'yes' || q3 === 'yes') {
        alert("Based on your answers, you are currently not eligible to donate. Please consult a doctor.");
        return;
    }
    
    // Auto-set date limits
    const dt = document.getElementById('apptDate');
    const today = new Date();
    today.setDate(today.getDate() + 1);
    dt.min = today.toISOString().split('T')[0];
    
    nextStep('step3');
}

function checkTimeSlot() {
    const date = document.getElementById('apptDate').value;
    const time = document.getElementById('apptTime').value;
    document.getElementById('btnNext3').disabled = !(date && time);
    
    if (date && time) {
        document.getElementById('confirmCenter').textContent = selectedCenterName;
        document.getElementById('confirmDateTime').textContent = `${date} at ${time}`;
    }
}

function nextStep(stepId) {
    document.getElementById(stepId + '-tab').disabled = false;
    document.getElementById(stepId + '-tab').click();
}
function prevStep(stepId) {
    document.getElementById(stepId + '-tab').click();
}

function submitBooking(btn) {
    const origHtml = btn.innerHTML;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Processing...';
    btn.disabled = true;
    document.getElementById('btnBack4').disabled = true;
    
    const hospitalId = selectedCenterId;   // centers map to hospitalId in BookAppointment
    const dt = document.getElementById('apptDate').value;
    const tm = document.getElementById('apptTime').value;

    fetch('/Donor/BookAppointment', {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: `hospitalId=${hospitalId}&appointmentDate=${dt}&appointmentTime=${tm}`
    })
    .then(r => r.ok ? r.json() : Promise.reject())
    .then(res => {
        btn.innerHTML = '<i class="fa-solid fa-check"></i> Booking Confirmed!';
        btn.classList.replace('btn-success', 'btn-primary');
        setTimeout(() => {
            window.location.reload();
        }, 2000);
    })
    .catch(() => {
        btn.innerHTML = '<i class="fa-solid fa-xmark"></i> Error Booking';
        btn.classList.replace('btn-success', 'btn-danger');
        setTimeout(() => {
            btn.innerHTML = origHtml;
            btn.classList.replace('btn-danger', 'btn-success');
            btn.disabled = false;
            document.getElementById('btnBack4').disabled = false;
        }, 2000);
    });
}

function respondUrgent(btn) {
    const origHtml = btn.innerHTML;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Conf...';
    btn.disabled = true;
    setTimeout(() => {
        btn.innerHTML = '<i class="fa-solid fa-check"></i> Navigating to Book...';
        btn.classList.replace('btn-danger', 'btn-success');
        setTimeout(() => {
            btn.innerHTML = origHtml;
            btn.classList.replace('btn-success', 'btn-danger');
            btn.disabled = false;
            document.getElementById('urgentAlert').style.display = 'none';
            document.getElementById('book-tab').click();
        }, 1500);
    }, 1000);
}

// Load donation history from API
function loadDonorHistory() {
    fetch('/Donor/GetMyAppointments')
        .then(r => r.ok ? r.json() : Promise.reject())
        .then(data => {
            const tbody = document.getElementById('history-tbody');
            if (!tbody) return;
            if (!data || data.length === 0) {
                tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">No donation history found.</td></tr>';
                return;
            }
            const statusMap = { 'Completed': 'badge-success', 'Cancelled': 'badge-danger', 'Confirmed': 'badge-info', 'Pending': 'badge-warning' };
            tbody.innerHTML = data.map(a => `
                <tr>
                    <td>${new Date(a.appointmentDate).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' })}</td>
                    <td class="fw-bold">${a.hospitalName || '—'}</td>
                    <td><span class="badge badge-danger">${a.status === 'Completed' ? '@bloodType' : '—'}</span></td>
                    <td><span class="badge ${statusMap[a.status] || 'badge-warning'}">${a.status}</span></td>
                </tr>
            `).join('');
        })
        .catch(() => {
            const tbody = document.getElementById('history-tbody');
            if (tbody) tbody.innerHTML = '<tr><td colspan="4" class="text-center text-muted">Error loading history.</td></tr>';
        });
}

// Initial setup
document.addEventListener('DOMContentLoaded', () => {
    // Set min date for date picker to tomorrow
    const dateInput = document.getElementById('apptDate');
    if(dateInput) {
        const tomorrow = new Date();
        tomorrow.setDate(tomorrow.getDate() + 1);
        dateInput.min = tomorrow.toISOString().split('T')[0];
    }
    loadDonorHistory();
});
</script>
}
