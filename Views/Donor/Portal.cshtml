<script>
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('on'));
  const el = document.getElementById(id);
  if (el) el.classList.add('on');
  // bottom nav mapping (questionnaire removed)
  const map = { 'sc-home':'0','sc-book':'1','sc-history':'2','sc-profile':'3' };
  document.querySelectorAll('.bn').forEach(b => b.classList.remove('on'));
  const idx = map[id];
  if (idx !== undefined) document.querySelectorAll('.bn')[parseInt(idx)].classList.add('on');
}

function respondUrgent() {
  const btn = document.getElementById('urgBtn');
  btn.textContent = '⏳ Sending response…'; btn.disabled = true;
  setTimeout(() => {
    btn.textContent = '✓ Responded! Center will contact you'; btn.style.background = 'var(--emerald)';
    setTimeout(() => { document.getElementById('urgentCard').style.display = 'none'; }, 2000);
  }, 1200);
}

// BOOKING (now 4 steps: center, questionnaire, date/time, confirm)
let bookStep = 1;
let selectedCenterId = null;
let selectedCenterName = "";
let selectedDate = "";
let selectedTimeSlot = "";

function initBookingSelection() {
  const activeCenter = document.querySelector('.center-card.sel');
  if (activeCenter) {
    selectedCenterId = activeCenter.dataset.centerId;
    selectedCenterName = activeCenter.dataset.centerName;
    const confCenterEl = document.getElementById('confCenter');
    if (confCenterEl) confCenterEl.textContent = selectedCenterName;
  }
  const activeTime = document.querySelector('.time-btn.sel');
  if (activeTime) {
    selectedTimeSlot = activeTime.textContent.trim();
    const confTimeEl = document.getElementById('confTime');
    if (confTimeEl) confTimeEl.textContent = selectedTimeSlot;
  }
}
setTimeout(initBookingSelection, 200);

function selCenter(el) {
  document.querySelectorAll('.center-card').forEach(c => c.classList.remove('sel'));
  el.classList.add('sel');
  selectedCenterId = el.dataset.centerId;
  selectedCenterName = el.dataset.centerName;
  const confCenterEl = document.getElementById('confCenter');
  if (confCenterEl) confCenterEl.textContent = selectedCenterName;
}
function selTime(el) {
  if (el.classList.contains('full') || el.classList.contains('past')) return;
  document.querySelectorAll('.time-btn').forEach(t => t.classList.remove('sel'));
  el.classList.add('sel');
  selectedTimeSlot = el.textContent.trim();
  const confTimeEl = document.getElementById('confTime');
  if (confTimeEl) confTimeEl.textContent = selectedTimeSlot;
}
function bookNext(step) {
  bookStep = step + 1;
  updateBookSteps();
  document.getElementById('bStep' + step).style.display = 'none';
  document.getElementById('bStep' + (step+1)).style.display = 'block';
}
function bookPrev(step) {
  bookStep = step - 1;
  updateBookSteps();
  document.getElementById('bStep' + step).style.display = 'none';
  // If going back from date/time (step 3) to questionnaire (step 2), show result or last q section
  if (step - 1 === 2) {
    // Show the questionnaire step 2
    document.getElementById('bStep2').style.display = 'block';
  } else {
    document.getElementById('bStep' + (step-1)).style.display = 'block';
  }
}
function updateBookSteps() {
  for (let i = 1; i <= 4; i++) {
    const el = document.getElementById('bs' + i);
    if (!el) continue;
    el.className = 'step';
    if (i < bookStep) el.classList.add('done');
    else if (i === bookStep) el.classList.add('active');
  }
}
function proceedToDateTime() {
  bookStep = 3;
  updateBookSteps();
  document.getElementById('bStep2').style.display = 'none';
  document.getElementById('bStep3').style.display = 'block';
}
function convertTo24Hour(timeStr) {
  const parts = timeStr.split(' ');
  if (parts.length < 2) return timeStr;
  const time = parts[0];
  const ampm = parts[1].toUpperCase();
  const hm = time.split(':');
  let hours = parseInt(hm[0], 10);
  const minutes = hm[1];
  if (ampm === 'PM' && hours < 12) hours += 12;
  if (ampm === 'AM' && hours === 12) hours = 0;
  return `${String(hours).padStart(2, '0')}:${minutes}`;
}

function confirmBook() {
  if (!selectedCenterId) { alert('Please select a donation center.'); return; }
  if (!selectedDate) { alert('Please select a date.'); return; }
  if (!selectedTimeSlot) { alert('Please select a time slot.'); return; }

  const btn = document.getElementById('confirmBtn');
  btn.textContent = '⏳ Booking…'; btn.disabled = true;

  const time24 = convertTo24Hour(selectedTimeSlot);

  const params = new URLSearchParams({
    hospitalId: selectedCenterId,
    appointmentDate: selectedDate,
    appointmentTime: time24,
    notes: ''
  });

  fetch('/Donor/BookAppointment', {
    method: 'POST',
    body: params,
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
  })
  .then(r => r.ok ? r.json() : Promise.reject())
  .then(data => {
    btn.textContent = '✅ Appointment Booked!'; btn.style.background = 'var(--emerald)';
    setTimeout(() => {
      showScreen('sc-home');
      bookStep = 1;
      updateBookSteps();
      document.getElementById('bStep1').style.display = 'block';
      document.getElementById('bStep2').style.display = 'none';
      document.getElementById('bStep3').style.display = 'none';
      document.getElementById('bStep4').style.display = 'none';
      btn.textContent = '✓ Confirm Booking'; btn.style.background = ''; btn.disabled = false;
      resetQuestionnaire();
      location.reload();
    }, 2000);
  })
  .catch(() => {
    btn.textContent = '❌ Booking Failed'; btn.style.background = 'var(--crimson)';
    btn.disabled = false;
    setTimeout(() => {
      btn.textContent = '✓ Confirm Booking'; btn.style.background = '';
    }, 2000);
  });
}

// CALENDAR
let calYear = new Date().getFullYear(), calMonth = new Date().getMonth();
const monthNames = ['January','February','March','April','May','June','July','August','September','October','November','December'];
function renderCal() {
  document.getElementById('calMonth').textContent = monthNames[calMonth] + ' ' + calYear;
  const grid = document.getElementById('calGrid');
  grid.innerHTML = '';
  const first = new Date(calYear, calMonth, 1).getDay();
  const days = new Date(calYear, calMonth + 1, 0).getDate();
  const today = new Date();
  for (let i = 0; i < first; i++) {
    const d = document.createElement('div'); d.className = 'cal-day empty'; grid.appendChild(d);
  }
  for (let d = 1; d <= days; d++) {
    const div = document.createElement('div');
    div.className = 'cal-day';
    div.textContent = d;
    const dt = new Date(calYear, calMonth, d);
    if (dt < today && dt.toDateString() !== today.toDateString()) div.classList.add('past');
    if (d === today.getDate() && calMonth === today.getMonth() && calYear === today.getFullYear()) div.classList.add('today');
    div.onclick = function() {
      if (!this.classList.contains('past')) {
        document.querySelectorAll('.cal-day').forEach(x => x.classList.remove('sel'));
        this.classList.add('sel');
        selectedDate = `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
        document.getElementById('confDate').textContent = monthNames[calMonth] + ' ' + d + ', ' + calYear;
      }
    };
    grid.appendChild(div);
  }
}
function calPrev() { if (calMonth === 0) { calMonth = 11; calYear--; } else calMonth--; renderCal(); }
function calNext() { if (calMonth === 11) { calMonth = 0; calYear++; } else calMonth++; renderCal(); }
renderCal();

// QUESTIONNAIRE (embedded in booking step 2)
let qCur = 1;
const Q_SECTIONS = 4;

function resetQuestionnaire() {
  qCur = 1;
  for (let i = 1; i <= 5; i++) {
    const d = document.getElementById('qStepDiv' + i);
    if (d) d.style.display = i === 1 ? 'block' : 'none';
  }
  document.getElementById('qProgress').style.width = '25%';
  document.getElementById('qStep').textContent = 'Section 1 of 4';
  // Clear all selects
  ['q_age','q_weight','q_feeling','q_meal','q_bp','q_thinners','q_infection','q_heart','q_surgery','q_pregnancy','q_lastdonation','q_platelets','q_transfusion','q_malaria','q_tattoo','q_covid'].forEach(id => {
    const el = document.getElementById(id);
    if (el) el.value = '';
  });
  clearAllErrors();
}

function clearAllErrors() {
  document.querySelectorAll('.q-error').forEach(e => e.classList.remove('visible'));
  document.querySelectorAll('.form-input.error').forEach(e => e.classList.remove('error'));
}

function showError(fieldId, errId) {
  const field = document.getElementById(fieldId);
  const err = document.getElementById(errId);
  if (field) field.classList.add('error');
  if (err) err.classList.add('visible');
}

function clearError(fieldId, errId) {
  const field = document.getElementById(fieldId);
  const err = document.getElementById(errId);
  if (field) field.classList.remove('error');
  if (err) err.classList.remove('visible');
}

// Validate section and return {valid, ineligible, reasons}
function validateSection(section) {
  let valid = true;
  let ineligible = false;
  let reasons = [];

  if (section === 1) {
    const age = document.getElementById('q_age').value;
    const weight = document.getElementById('q_weight').value;
    const feeling = document.getElementById('q_feeling').value;
    const meal = document.getElementById('q_meal').value;
    const bp = document.getElementById('q_bp').value;

    if (!age) { showError('q_age','err_age'); valid = false; } else clearError('q_age','err_age');
    if (!weight) { showError('q_weight','err_weight'); valid = false; } else clearError('q_weight','err_weight');
    if (!feeling) { showError('q_feeling','err_feeling'); valid = false; } else clearError('q_feeling','err_feeling');
    if (!meal) { showError('q_meal','err_meal'); valid = false; } else clearError('q_meal','err_meal');
    if (!bp) { showError('q_bp','err_bp'); valid = false; } else clearError('q_bp','err_bp');

    if (valid) {
      if (age === 'under18') { ineligible = true; reasons.push('Donors must be at least 18 years old.'); }
      if (age === 'over65') { ineligible = true; reasons.push('Donors must be 65 years old or younger.'); }
      if (weight === 'under50') { ineligible = true; reasons.push('Donors must weigh at least 50 kg.'); }
      if (feeling === 'unwell') { ineligible = true; reasons.push('You must feel healthy and well on the day of donation.'); }
      if (meal === 'no') { ineligible = true; reasons.push('Please eat a full meal within 4 hours before donating.'); }
      if (bp === 'yes') { ineligible = true; reasons.push('Uncontrolled high blood pressure is a temporary deferral.'); }
    }
  }

  if (section === 2) {
    const thinners = document.getElementById('q_thinners').value;
    const infection = document.getElementById('q_infection').value;
    const heart = document.getElementById('q_heart').value;
    const surgery = document.getElementById('q_surgery').value;
    const pregnancy = document.getElementById('q_pregnancy').value;

    if (!thinners) { showError('q_thinners','err_thinners'); valid = false; } else clearError('q_thinners','err_thinners');
    if (!infection) { showError('q_infection','err_infection'); valid = false; } else clearError('q_infection','err_infection');
    if (!heart) { showError('q_heart','err_heart'); valid = false; } else clearError('q_heart','err_heart');
    if (!surgery) { showError('q_surgery','err_surgery'); valid = false; } else clearError('q_surgery','err_surgery');
    if (!pregnancy) { showError('q_pregnancy','err_pregnancy'); valid = false; } else clearError('q_pregnancy','err_pregnancy');

    if (valid) {
      if (thinners === 'yes') { ineligible = true; reasons.push('Blood thinners are a temporary deferral — check with your doctor.'); }
      if (infection === 'yes') { ineligible = true; reasons.push('Active infectious diseases prevent blood donation at this time.'); }
      if (heart === 'yes') { ineligible = true; reasons.push('Chronic heart or lung conditions require medical clearance before donating.'); }
      if (surgery === 'yes') { ineligible = true; reasons.push('Recent surgery or major illness requires a 6-month recovery period.'); }
      if (pregnancy === 'yes') { ineligible = true; reasons.push('Pregnancy, breastfeeding, or recent childbirth (within 6 months) is a deferral.'); }
    }
  }

  if (section === 3) {
    const lastdonation = document.getElementById('q_lastdonation').value;
    const platelets = document.getElementById('q_platelets').value;
    const transfusion = document.getElementById('q_transfusion').value;

    if (!lastdonation) { showError('q_lastdonation','err_lastdonation'); valid = false; } else clearError('q_lastdonation','err_lastdonation');
    if (!platelets) { showError('q_platelets','err_platelets'); valid = false; } else clearError('q_platelets','err_platelets');
    if (!transfusion) { showError('q_transfusion','err_transfusion'); valid = false; } else clearError('q_transfusion','err_transfusion');

    if (valid) {
      if (lastdonation === 'yes') { ineligible = true; reasons.push('You must wait 90 days between whole blood donations.'); }
      if (platelets === 'yes') { ineligible = true; reasons.push('You must wait 14 days after a platelet donation.'); }
      if (transfusion === 'yes') { ineligible = true; reasons.push('Receiving a blood transfusion within the last 12 months is a deferral.'); }
    }
  }

  if (section === 4) {
    const malaria = document.getElementById('q_malaria').value;
    const tattoo = document.getElementById('q_tattoo').value;
    const covid = document.getElementById('q_covid').value;

    if (!malaria) { showError('q_malaria','err_malaria'); valid = false; } else clearError('q_malaria','err_malaria');
    if (!tattoo) { showError('q_tattoo','err_tattoo'); valid = false; } else clearError('q_tattoo','err_tattoo');
    if (!covid) { showError('q_covid','err_covid'); valid = false; } else clearError('q_covid','err_covid');

    if (valid) {
      if (malaria === 'yes') { ineligible = true; reasons.push('Travel to a malaria-risk area requires a 12-month deferral.'); }
      if (tattoo === 'yes_unlicensed') { ineligible = true; reasons.push('Tattoos/piercings from non-licensed facilities require a 12-month deferral.'); }
      if (covid === 'yes_infection') { ineligible = true; reasons.push('Please wait 28 days after recovering from COVID-19 before donating.'); }
      if (covid === 'yes_vaccine') { ineligible = true; reasons.push('Please wait 48 hours after a COVID-19 vaccine before donating.'); }
    }
  }

  return { valid, ineligible, reasons };
}

// Accumulated ineligibility reasons across all sections
let allDeferralReasons = [];

function qNext(step) {
  const result = validateSection(step);
  if (!result.valid) return; // stop if any field is blank

  // Collect deferral reasons from this section
  if (result.ineligible) {
    allDeferralReasons = allDeferralReasons.concat(result.reasons);
  }

  qCur = step + 1;
  document.getElementById('qStepDiv' + step).style.display = 'none';
  document.getElementById('qStepDiv' + qCur).style.display = 'block';
  const progress = Math.round((qCur <= Q_SECTIONS ? qCur : Q_SECTIONS) / Q_SECTIONS * 100);
  document.getElementById('qProgress').style.width = progress + '%';
  if (qCur <= Q_SECTIONS) {
    document.getElementById('qStep').textContent = 'Section ' + qCur + ' of ' + Q_SECTIONS;
  }
}

function qPrev(step) {
  qCur = step - 1;
  document.getElementById('qStepDiv' + step).style.display = 'none';
  document.getElementById('qStepDiv' + qCur).style.display = 'block';
  const progress = Math.round(qCur / Q_SECTIONS * 100);
  document.getElementById('qProgress').style.width = progress + '%';
  document.getElementById('qStep').textContent = 'Section ' + qCur + ' of ' + Q_SECTIONS;
}

function qSubmit() {
  // Validate last section
  const result = validateSection(4);
  if (!result.valid) return;

  if (result.ineligible) {
    allDeferralReasons = allDeferralReasons.concat(result.reasons);
  }

  // Show result screen (qStepDiv5)
  document.getElementById('qStepDiv4').style.display = 'none';
  document.getElementById('qStepDiv5').style.display = 'block';
  document.getElementById('qProgress').style.width = '100%';
  document.getElementById('qStep').textContent = 'Complete';

  const eligIcon = document.getElementById('eligIcon');
  const eligTitle = document.getElementById('eligTitle');
  const eligDesc = document.getElementById('eligDesc');
  const eligBtn = document.getElementById('eligBtn');
  const eligReasons = document.getElementById('eligReasons');

  if (allDeferralReasons.length > 0) {
    // Ineligible
    eligIcon.textContent = '⚠️';
    eligTitle.textContent = 'Not Eligible Right Now';
    eligDesc.textContent = 'Based on your answers, you are temporarily deferred from donating blood for the following reason(s):';
    eligReasons.innerHTML = allDeferralReasons.map(r =>
      `<div style="display:flex;gap:8px;align-items:flex-start;padding:8px 10px;background:var(--crimson-pale);border-radius:8px;margin-bottom:6px;border-left:3px solid var(--crimson);">
        <span style="color:var(--crimson);font-weight:700;flex-shrink:0;">✗</span>
        <span style="font-size:12px;color:var(--ink-mid);line-height:1.5;">${r}</span>
      </div>`
    ).join('');
    eligBtn.textContent = '← Return Home';
    eligBtn.className = 'btn-ghost';
    eligBtn.onclick = function() {
      showScreen('sc-home');
      allDeferralReasons = [];
      resetQuestionnaire();
      bookStep = 1;
      updateBookSteps();
      document.getElementById('bStep1').style.display = 'block';
      document.getElementById('bStep2').style.display = 'none';
    };
  } else {
    // Eligible
    eligIcon.textContent = '✅';
    eligTitle.textContent = "You're Eligible!";
    eligDesc.textContent = 'All responses indicate you\'re ready to donate. You may proceed to select a date and time.';
    eligReasons.innerHTML = '';
    eligBtn.textContent = 'Continue to Date & Time →';
    eligBtn.className = 'btn-primary';
    eligBtn.onclick = proceedToDateTime;
  }
}

// EDIT PROFILE
function saveProfile() {
  const btn = event.currentTarget;
  btn.textContent = '⏳ Saving…'; btn.disabled = true;
  setTimeout(() => {
    btn.textContent = '✅ Saved!'; btn.style.background = 'var(--emerald)';
    setTimeout(() => {
      showScreen('sc-profile');
      btn.textContent = 'Save Changes'; btn.style.background = ''; btn.disabled = false;
    }, 1500);
  }, 900);
}

// On booking screen entry, reset questionnaire
document.querySelectorAll('.bn')[1].addEventListener('click', function() {
  allDeferralReasons = [];
  resetQuestionnaire();
});

// ─── Notifications: load from server ───
function loadNotifications() {
  fetch('/Donor/GetMyNotifications')
    .then(r => r.ok ? r.json() : Promise.reject(r.status))
    .then(data => {
      const container = document.getElementById('notifsContainer');
      if (!container) return;
      if (!data || data.length === 0) {
        container.innerHTML = '<div style="text-align:center;padding:20px;color:var(--ink-light);font-size:13px;">No notifications yet.</div>';
        return;
      }
      const icons = ['🚨','💬','🩸','✅','🏆'];
      const classes = ['ni-red','ni-blue','ni-blue','ni-green','ni-green'];
      container.innerHTML = data.map((n, i) => `
        <div class="notif-item" id="notif-${n.idSMS}">
          <div class="notif-ico ${classes[i % classes.length]}">${icons[i % icons.length]}</div>
          <div style="flex:1;">
            <div class="notif-title">Blood Needed: ${n.bloodNeeded || '—'}</div>
            <div class="notif-desc">${n.message || ''}</div>
            <div class="notif-time">${new Date(n.sentAt).toLocaleString()}</div>
          </div>
          ${!n.isRead ? '<div class="notif-unread"></div>' : ''}
        </div>
      `).join('');
      // mark as read on click
      data.filter(n => !n.isRead).forEach(n => {
        const el = document.getElementById('notif-' + n.idSMS);
        if (el) el.addEventListener('click', () => {
          fetch('/Donor/MarkNotificationRead?id=' + n.idSMS, { method: 'POST' });
          const dot = el.querySelector('.notif-unread');
          if (dot) dot.remove();
        });
      });
    })
    .catch(() => {
      const container = document.getElementById('notifsContainer');
      if (container) container.innerHTML = '<div style="text-align:center;padding:20px;color:var(--ink-light);font-size:13px;">Could not load notifications.</div>';
    });
}

function loadHistory() {
  fetch('/Donor/GetMyAppointments')
    .then(r => r.ok ? r.json() : Promise.reject())
    .then(data => {
      const container = document.getElementById('historyContainer');
      if (!container) return;
      if (!data || data.length === 0) {
        container.innerHTML = '<div style="text-align:center;padding:20px;color:var(--ink-light);font-size:13px;">No past appointments found.</div>';
        return;
      }
      container.innerHTML = data.map(a => {
        const dateStr = new Date(a.appointmentDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
        const timeParts = a.appointmentTime.split(':');
        let timeStr = a.appointmentTime;
        if(timeParts.length >= 2) {
          const h = parseInt(timeParts[0]);
          const m = timeParts[1];
          const suffix = h >= 12 ? 'PM' : 'AM';
          const displayH = h % 12 === 0 ? 12 : h % 12;
          timeStr = `${displayH}:${m} ${suffix}`;
        }
        let chipClass = 'chip-green';
        if (a.status === 'Pending') chipClass = 'chip-yellow';
        else if (a.status === 'Cancelled') chipClass = 'chip-red';

        return `
          <div class="hist-item">
            <div class="hist-blood">@ViewBag.BloodType</div>
            <div style="flex:1;">
              <div class="hist-center">${a.hospitalName}</div>
              <div class="hist-date">${dateStr} · ${timeStr}</div>
              <span class="hist-tag">${a.notes || 'No notes'}</span>
            </div>
            <span class="chip ${chipClass}">${a.status}</span>
          </div>
        `;
      }).join('');
    })
    .catch(() => {
      const container = document.getElementById('historyContainer');
      if (container) container.innerHTML = '<div style="text-align:center;padding:20px;color:var(--ink-light);font-size:13px;">Could not load history.</div>';
    });
}

// Load dynamic data when screen opens
const origShowScreen = showScreen;
window.showScreen = function(id) {
  origShowScreen(id);
  if (id === 'sc-notifs') loadNotifications();
  if (id === 'sc-history') loadHistory();
};
// Load on page ready if screens are active
document.addEventListener('DOMContentLoaded', () => {
  const elNotifs = document.getElementById('sc-notifs');
  if (elNotifs && elNotifs.classList.contains('on')) loadNotifications();
  const elHistory = document.getElementById('sc-history');
  if (elHistory && elHistory.classList.contains('on')) loadHistory();
});

</script>
