@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BloodLink — Maadi Donation Center</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=DM+Serif+Display&display=swap" rel="stylesheet">
<style>
  :root {
    --red:       #C0162B;
    --red-lt:    #E8223A;
    --red-pale:  #FFF0F1;
    --red-border:#F5C5CB;
    --green:     #0A7A4B;
    --green-bg:  #EDFAF3;
    --amber:     #C47A0A;
    --amber-bg:  #FFF8EC;
    --blue:      #1460AA;
    --blue-bg:   #EEF5FF;
    --ink:       #14080A;
    --ink-2:     #4A3037;
    --ink-3:     #8C6E75;
    --bg:        #F4F1F1;
    --surface:   #FFFFFF;
    --border:    #E8DEDE;
    --radius:    14px;
    --shadow:    0 2px 16px rgba(20,8,10,0.07);
  }

  *, *::before, *::after { box-sizing: border-box; margin:0; padding:0; }

  body {
    font-family: 'Sora', sans-serif;
    background: var(--bg);
    color: var(--ink);
    min-height: 100vh;
  }

  /* ── TOPNAV ─────────────────────────── */
  nav {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 28px;
    height: 58px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    position: sticky; top:0; z-index:100;
    box-shadow: 0 1px 8px rgba(20,8,10,0.05);
  }

  .nav-left { display:flex; align-items:center; gap:14px; }

  .nav-logo {
    width: 34px; height: 34px;
    background: var(--red);
    border-radius: 9px;
    display: flex; align-items:center; justify-content:center;
    font-size: 17px;
    box-shadow: 0 2px 10px rgba(192,22,43,0.35);
    flex-shrink:0;
  }

  .nav-name {
    font-weight: 600;
    font-size: 15px;
    color: var(--ink);
  }

  .nav-sub {
    font-size: 11.5px;
    color: var(--ink-3);
    font-weight: 400;
  }

  .badge-staff {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .08em;
    background: var(--red-pale);
    color: var(--red);
    border: 1px solid var(--red-border);
    border-radius: 6px;
    padding: 3px 8px;
    text-transform: uppercase;
  }

  .btn-signout {
    font-family: 'Sora', sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--ink-2);
    background: none;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    padding: 7px 16px;
    cursor: pointer;
    transition: border-color .2s, color .2s;
  }
  .btn-signout:hover { border-color: var(--red); color: var(--red); }

  /* ── PAGE LAYOUT ─────────────────────── */
  .page {
    max-width: 860px;
    margin: 0 auto;
    padding: 32px 20px 60px;
  }

  /* ── CENTER HEADER CARD ──────────────── */
  .center-card {
    background: var(--surface);
    border-radius: var(--radius);
    border: 1px solid var(--border);
    box-shadow: var(--shadow);
    padding: 22px 26px;
    display: flex;
    align-items: center;
    gap: 18px;
    margin-bottom: 20px;
    animation: fadeUp .4s ease both;
  }

  .center-icon {
    width: 52px; height: 52px;
    background: var(--red-pale);
    border: 1.5px solid var(--red-border);
    border-radius: 13px;
    display: flex; align-items:center; justify-content:center;
    font-size: 22px;
    flex-shrink:0;
  }

  .center-info h1 {
    font-family: 'DM Serif Display', serif;
    font-size: 1.35rem;
    color: var(--ink);
    margin-bottom: 2px;
  }

  .center-info p {
    font-size: 12.5px;
    color: var(--ink-3);
    margin-bottom: 8px;
  }

  .active-badge {
    display: inline-flex; align-items:center; gap:6px;
    font-size: 11.5px; font-weight: 600;
    background: var(--green-bg);
    color: var(--green);
    border: 1px solid #b2e6cf;
    border-radius: 20px;
    padding: 3px 10px;
  }
  .active-dot {
    width:6px; height:6px;
    background: var(--green);
    border-radius:50%;
    animation: blink 2s ease-in-out infinite;
  }
  @@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

  /* ── STATS STRIP ─────────────────────── */
  .stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
    margin-bottom: 20px;
    animation: fadeUp .4s .08s ease both;
  }

  .stat-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 20px 22px;
    text-align: center;
    transition: transform .2s, box-shadow .2s;
  }
  .stat-card:hover { transform: translateY(-2px); box-shadow: 0 6px 24px rgba(20,8,10,0.10); }

  .stat-num {
    font-family: 'DM Serif Display', serif;
    font-size: 2.4rem;
    color: var(--ink);
    line-height: 1;
    margin-bottom: 6px;
  }
  .stat-card:nth-child(1) .stat-num { color: var(--red); }
  .stat-card:nth-child(2) .stat-num { color: var(--green); }

  .stat-label {
    font-size: 10.5px;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--ink-3);
    font-weight: 600;
  }

  /* ── INFO BANNER ─────────────────────── */
  .info-banner {
    background: var(--blue-bg);
    border: 1px solid #c5d9f5;
    border-radius: var(--radius);
    padding: 14px 18px;
    display: flex;
    gap: 12px;
    align-items: flex-start;
    margin-bottom: 20px;
    font-size: 13px;
    color: var(--blue);
    line-height: 1.55;
    animation: fadeUp .4s .12s ease both;
  }
  .info-banner strong { color: #0d3f80; }

  /* ── SECTION CARD ────────────────────── */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    margin-bottom: 20px;
    overflow: hidden;
    animation: fadeUp .4s .16s ease both;
  }

  .card-header {
    padding: 16px 22px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .card-header h2 {
    font-size: 14px;
    font-weight: 600;
    color: var(--ink);
  }

  /* ── PROGRESS ────────────────────────── */
  .progress-wrap { padding: 18px 22px; }

  .progress-bar-bg {
    height: 8px;
    background: #f0e8e8;
    border-radius: 99px;
    overflow: hidden;
    margin-bottom: 8px;
  }
  .progress-bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--red-lt), var(--red));
    border-radius: 99px;
    width: 8%;
    transition: width 1s ease;
  }
  .progress-meta {
    display: flex;
    justify-content: space-between;
    font-size: 12px;
    color: var(--ink-3);
  }
  .progress-meta strong { color: var(--ink); }

  /* ── APPOINTMENT LIST ────────────────── */
  .appt-item {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 13px 22px;
    border-bottom: 1px solid var(--border);
    transition: background .15s;
  }
  .appt-item:last-child { border-bottom: none; }
  .appt-item:hover { background: #fdf8f8; }
  .appt-item.done { background: var(--green-bg); }
  .appt-item.done:hover { background: #e0f7ec; }

  .appt-time {
    font-size: 13px;
    font-weight: 600;
    color: var(--ink-2);
    width: 44px;
    flex-shrink:0;
  }

  .avatar {
    width: 36px; height: 36px;
    border-radius: 10px;
    display: flex; align-items:center; justify-content:center;
    font-size: 12px;
    font-weight: 700;
    color: #fff;
    flex-shrink:0;
  }

  .appt-info { flex: 1; min-width:0; }
  .appt-name {
    font-size: 13.5px;
    font-weight: 600;
    color: var(--ink);
  }
  .appt-meta {
    font-size: 11.5px;
    color: var(--ink-3);
    margin-top: 1px;
  }

  .status-done {
    font-size: 12px;
    font-weight: 600;
    color: var(--green);
    white-space: nowrap;
  }

  .status-waiting {
    font-size: 11.5px;
    font-weight: 600;
    color: var(--amber);
    background: var(--amber-bg);
    border: 1px solid #f0d9a5;
    border-radius: 6px;
    padding: 3px 9px;
    white-space: nowrap;
  }

  .btn-mark {
    font-family: 'Sora', sans-serif;
    font-size: 12.5px;
    font-weight: 600;
    background: var(--red);
    color: #fff;
    border: none;
    border-radius: 8px;
    padding: 8px 15px;
    cursor: pointer;
    white-space: nowrap;
    transition: background .2s, transform .15s, box-shadow .2s;
    box-shadow: 0 2px 10px rgba(192,22,43,0.3);
  }
  .btn-mark:hover {
    background: var(--red-lt);
    transform: translateY(-1px);
    box-shadow: 0 4px 16px rgba(192,22,43,0.4);
  }
  .btn-mark:active { transform: translateY(0); }

  /* ── COLLECTION CARD ─────────────────── */
  .collection-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 22px;
    border-bottom: 1px solid var(--border);
    font-size: 13.5px;
  }
  .collection-item:last-child { border-bottom: none; }

  .blood-type-tag {
    display: inline-flex; align-items:center; gap:6px;
    font-weight: 600;
    color: var(--red);
  }

  .inv-badge {
    font-size: 12px;
    font-weight: 600;
    color: var(--green);
  }

  .units-row {
    display: flex;
    justify-content: space-between;
    padding: 12px 22px 16px;
    font-size: 13px;
    color: var(--ink-3);
    border-top: 1px solid var(--border);
  }
  .units-row strong { color: var(--blue); font-weight:700; }

  /* ── ANIMATIONS ──────────────────────── */
  @@keyframes fadeUp {
    from { opacity:0; transform: translateY(14px); }
    to   { opacity:1; transform: translateY(0); }
  }

  /* ── AVATAR COLORS ───────────────────── */
  .av-red    { background: #C0162B; }
  .av-purple { background: #7c3aed; }
  .av-green  { background: #0A7A4B; }
  .av-navy   { background: #1460AA; }
  .av-orange { background: #C47A0A; }
  .av-teal   { background: #0891b2; }
  .av-rose   { background: #be185d; }
  .av-indigo { background: #4338ca; }
</style>
</head>
<body>

<!-- ══ TOPNAV ══════════════════════════════════════ -->
<nav>
  <div class="nav-left">
    <div class="nav-logo">🩸</div>
    <div>
      <div class="nav-name">Maadi Center &nbsp;<span style="color:var(--ink-3);font-weight:400">·</span>&nbsp; Cairo, Maadi District</div>
      <div class="nav-sub">Ahmed Sami (Staff)</div>
    </div>
    <span class="badge-staff">Center Staff</span>
  </div>
  <button class="btn-signout">Sign Out</button>
</nav>

<!-- ══ PAGE ════════════════════════════════════════ -->
<div class="page">

  <!-- Center header card (replaces dark bar) -->
  <div class="center-card">
    <div class="center-icon">🏥</div>
    <div class="center-info">
      <h1>Maadi Donation Center</h1>
      <p>Maadi, Cairo &nbsp;·&nbsp; Ahmed Sami (Staff)</p>
      <span class="active-badge">
        <span class="active-dot"></span>
        Thursday, April 24, 2025 &nbsp;·&nbsp; Active
      </span>
    </div>
  </div>

  <!-- Stats -->
  <div class="stats">
    <div class="stat-card">
      <div class="stat-num">12</div>
      <div class="stat-label">Today's Appointments</div>
    </div>
    <div class="stat-card">
      <div class="stat-num">1</div>
      <div class="stat-label">Completed</div>
    </div>
    <div class="stat-card">
      <div class="stat-num" style="color:var(--amber)">11</div>
      <div class="stat-label">Remaining</div>
    </div>
  </div>

  <!-- Info banner -->
  <div class="info-banner">
    <span style="font-size:16px;flex-shrink:0">ℹ️</span>
    <span>When a donor completes their donation, tap <strong>"Mark Done"</strong> to automatically add a blood unit to the national inventory.</span>
  </div>

  <!-- Today's Progress -->
  <div class="card">
    <div class="card-header">
      <span>📊</span>
      <h2>Today's Progress</h2>
    </div>
    <div class="progress-wrap">
      <div class="progress-bar-bg">
        <div class="progress-bar-fill" id="progressFill"></div>
      </div>
      <div class="progress-meta">
        <span><strong>1</strong> of 12 completed</span>
        <span>8%</span>
      </div>
    </div>
  </div>

  <!-- Appointments -->
  <div class="card">
    <div class="card-header">
      <span>📋</span>
      <h2>Today's Appointments — Maadi Center</h2>
    </div>

    <!-- Done row -->
    <div class="appt-item done">
      <div class="appt-time">10:30</div>
      <div class="avatar av-red">HS</div>
      <div class="appt-info">
        <div class="appt-name">Hind Sheikh</div>
        <div class="appt-meta">AB− &nbsp;·&nbsp; Unit BU-2025-00901 added to national inventory ✓</div>
      </div>
      <div class="status-done">Done ✓</div>
    </div>

    <!-- Waiting rows -->
    <div class="appt-item" id="row-js">
      <div class="appt-time">9:00</div>
      <div class="avatar av-teal">JS</div>
      <div class="appt-info">
        <div class="appt-name">John Smith</div>
        <div class="appt-meta">O− &nbsp;·&nbsp; Waiting</div>
      </div>
      <div class="status-waiting">Waiting</div>
      <button class="btn-mark" onclick="markDone('row-js','JS','O−')">Mark Done</button>
    </div>

    <div class="appt-item" id="row-sk">
      <div class="appt-time">10:00</div>
      <div class="avatar av-purple">SK</div>
      <div class="appt-info">
        <div class="appt-name">Sara Khalid</div>
        <div class="appt-meta">A+ &nbsp;·&nbsp; Waiting</div>
      </div>
      <div class="status-waiting">Waiting</div>
      <button class="btn-mark" onclick="markDone('row-sk','SK','A+')">Mark Done</button>
    </div>

    <div class="appt-item" id="row-km">
      <div class="appt-time">11:00</div>
      <div class="avatar av-green">KM</div>
      <div class="appt-info">
        <div class="appt-name">Karim Mahmoud</div>
        <div class="appt-meta">B+ &nbsp;·&nbsp; Waiting</div>
      </div>
      <div class="status-waiting">Waiting</div>
      <button class="btn-mark" onclick="markDone('row-km','KM','B+')">Mark Done</button>
    </div>

    <div class="appt-item" id="row-rs">
      <div class="appt-time">11:30</div>
      <div class="avatar av-navy">RS</div>
      <div class="appt-info">
        <div class="appt-name">Rana Saeed</div>
        <div class="appt-meta">AB+ &nbsp;·&nbsp; Waiting</div>
      </div>
      <div class="status-waiting">Waiting</div>
      <button class="btn-mark" onclick="markDone('row-rs','RS','AB+')">Mark Done</button>
    </div>

    <div class="appt-item" id="row-of">
      <div class="appt-time">12:00</div>
      <div class="avatar av-orange">OF</div>
      <div class="appt-info">
        <div class="appt-name">Omar Farouk</div>
        <div class="appt-meta">O+ &nbsp;·&nbsp; Waiting</div>
      </div>
      <div class="status-waiting">Waiting</div>
      <button class="btn-mark" onclick="markDone('row-of','OF','O+')">Mark Done</button>
    </div>

    <div class="appt-item" id="row-la">
      <div class="appt-time">13:00</div>
      <div class="avatar av-indigo">LA</div>
      <div class="appt-info">
        <div class="appt-name">Laila Amin</div>
        <div class="appt-meta">A− &nbsp;·&nbsp; Waiting</div>
      </div>
      <div class="status-waiting">Waiting</div>
      <button class="btn-mark" onclick="markDone('row-la','LA','A−')">Mark Done</button>
    </div>

    <div class="appt-item" id="row-th">
      <div class="appt-time">14:00</div>
      <div class="avatar av-rose">TH</div>
      <div class="appt-info">
        <div class="appt-name">Tarek Hassan</div>
        <div class="appt-meta">B− &nbsp;·&nbsp; Waiting</div>
      </div>
      <div class="status-waiting">Waiting</div>
      <button class="btn-mark" onclick="markDone('row-th','TH','B−')">Mark Done</button>
    </div>
  </div>

  <!-- Today's Collection -->
  <div class="card" id="collectionCard">
    <div class="card-header">
      <span>🩸</span>
      <h2>Today's Collection So Far</h2>
    </div>
    <div id="collectionList">
      <div class="collection-item">
        <span class="blood-type-tag">🩸 AB− — Unit BU-2025-00901</span>
        <span class="inv-badge">Added to inventory ✓</span>
      </div>
    </div>
    <div class="units-row">
      <span>Units collected today:</span>
      <strong id="unitCount">1</strong>
    </div>
  </div>

</div><!-- /page -->

<script>
  // animate progress bar on load
  setTimeout(() => {
    document.getElementById('progressFill').style.width = '8%';
  }, 300);

  let unitCount = 1;
  let completed = 1;
  const total = 12;
  let unitIndex = 902;

  function markDone(rowId, initials, bloodType) {
    const row = document.getElementById(rowId);
    if (!row) return;

    // Update row style
    row.classList.add('done');
    const waiting = row.querySelector('.status-waiting');
    const btn     = row.querySelector('.btn-mark');
    const meta    = row.querySelector('.appt-meta');

    const unitId = `BU-2025-00${unitIndex++}`;
    meta.textContent = `${bloodType} · Unit ${unitId} added to national inventory ✓`;
    waiting.outerHTML = `<div class="status-done">Done ✓</div>`;
    btn.remove();

    // Update stats
    completed++;
    unitCount++;
    const pct = Math.round((completed / total) * 100);

    document.querySelector('.stat-card:nth-child(2) .stat-num').textContent = completed;
    document.querySelector('.stat-card:nth-child(3) .stat-num').textContent = total - completed;
    document.querySelector('.progress-meta strong').textContent = completed;
    document.querySelector('.progress-meta span:last-child').textContent = pct + '%';
    document.getElementById('progressFill').style.width = pct + '%';
    document.getElementById('unitCount').textContent = unitCount;

    // Add to collection
    const item = document.createElement('div');
    item.className = 'collection-item';
    item.innerHTML = `<span class="blood-type-tag">🩸 ${bloodType} — Unit ${unitId}</span><span class="inv-badge">Added to inventory ✓</span>`;
    document.getElementById('collectionList').appendChild(item);
  }
</script>
</body>
</html>
