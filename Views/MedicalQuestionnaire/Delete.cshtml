@model BloodBank.Models.MedicalQuestionnaire

@{
    ViewData["Title"] = "Delete Questionnaire";
}

<div class="page-header mt-4">
    <div>
        <h2 class="page-title d-flex align-items-center gap-2 text-danger">
            <i class="fa-solid fa-triangle-exclamation"></i> Delete Questionnaire
        </h2>
        <p class="text-muted mb-0">This action cannot be undone</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="fa-solid fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="alert alert-danger d-flex gap-2">
            <i class="fa-solid fa-triangle-exclamation fa-lg mt-1"></i>
            <div>
                <strong>Are you sure?</strong> You are about to permanently delete questionnaire <strong>#@Model?.Id</strong> for donor <strong>@Model?.Donor?.Id</strong>.
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-clipboard-list text-danger me-2"></i>Questionnaire to Delete</span>
            </div>
            <div class="card-body">
                <dl class="row g-0">
                    <dt class="col-sm-5 text-muted fw-semibold py-2 border-bottom" style="font-size:0.875rem;">Donor ID</dt>
                    <dd class="col-sm-7 py-2 border-bottom fw-bold">@Html.DisplayFor(m => m.Donor.Id)</dd>

                    <dt class="col-sm-5 text-muted fw-semibold py-2 border-bottom" style="font-size:0.875rem;">Age Range</dt>
                    <dd class="col-sm-7 py-2 border-bottom">@Html.DisplayFor(m => m.AgeRange)</dd>

                    <dt class="col-sm-5 text-muted fw-semibold py-2 border-bottom" style="font-size:0.875rem;">Weight Range</dt>
                    <dd class="col-sm-7 py-2 border-bottom">@Html.DisplayFor(m => m.WeightRange)</dd>

                    <dt class="col-sm-5 text-muted fw-semibold py-2 border-bottom" style="font-size:0.875rem;">Blood Pressure Issue</dt>
                    <dd class="col-sm-7 py-2 border-bottom">
                        @if (Model.HasUncontrolledBloodPressure)
                        { <span class="badge badge-danger">Yes</span> }
                        else
                        { <span class="badge badge-success">No</span> }
                    </dd>

                    <dt class="col-sm-5 text-muted fw-semibold py-2" style="font-size:0.875rem;">Chronic Heart/Lung</dt>
                    <dd class="col-sm-7 py-2">
                        @if (Model.HasChronicHeartOrLungCondition)
                        { <span class="badge badge-danger">Yes</span> }
                        else
                        { <span class="badge badge-success">No</span> }
                    </dd>
                </dl>
            </div>
        </div>

        <form asp-action="Delete" class="d-flex gap-2 mt-3">
            <input type="hidden" asp-for="Id" />
            <input type="submit" value="Yes, Delete Permanently" class="btn btn-danger flex-grow-1" />
            <a asp-action="Index" class="btn btn-outline-primary">Cancel</a>
        </form>
    </div>
</div>
