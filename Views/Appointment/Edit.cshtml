@model BloodBank.Models.Appointment

@{
    ViewData["Title"] = "Edit Appointment";
}

<div class="page-header mt-4">
    <div>
        <h2 class="page-title d-flex align-items-center gap-2">
            <i class="fa-solid fa-calendar-pen text-primary-brand"></i> Edit Appointment
        </h2>
        <p class="text-muted mb-0">Update appointment #@Model?.AppointmentId</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="fa-solid fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-pen-to-square text-primary-brand me-2"></i>Edit Details</span>
            </div>
            <div class="card-body">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>
                    <input type="hidden" asp-for="AppointmentId" />

                    <div class="mb-3">
                        <label asp-for="DonorId" class="form-label"></label>
                        <input asp-for="DonorId" class="form-control" />
                        <span asp-validation-for="DonorId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="HospitalId" class="form-label"></label>
                        <select asp-for="HospitalId" class="form-control form-select" asp-items="ViewBag.HospitalId">
                            <option value="">— Select Hospital —</option>
                        </select>
                        <span asp-validation-for="HospitalId" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label asp-for="AppointmentDate" class="form-label"></label>
                            <input asp-for="AppointmentDate" class="form-control" type="date" />
                            <span asp-validation-for="AppointmentDate" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="AppointmentTime" class="form-label"></label>
                            <input asp-for="AppointmentTime" class="form-control" type="time" />
                            <span asp-validation-for="AppointmentTime" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Status" class="form-label"></label>
                        <select asp-for="Status" class="form-control form-select">
                            <option value="Pending">Pending</option>
                            <option value="Confirmed">Confirmed</option>
                            <option value="Completed">Completed</option>
                            <option value="Cancelled">Cancelled</option>
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label"></label>
                        <input asp-for="Notes" class="form-control" />
                        <span asp-validation-for="Notes" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="CreatedAt" class="form-label"></label>
                        <input asp-for="CreatedAt" class="form-control" />
                        <span asp-validation-for="CreatedAt" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <input type="submit" value="Save Changes" class="btn btn-primary flex-grow-1" />
                        <a asp-action="Index" class="btn btn-outline-primary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
