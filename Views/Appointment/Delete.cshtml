@model BloodBank.Models.Appointment

@{
    ViewData["Title"] = "Delete Appointment";
}

<div class="page-header mt-4">
    <div>
        <h2 class="page-title d-flex align-items-center gap-2 text-danger">
            <i class="fa-solid fa-triangle-exclamation"></i> Delete Appointment
        </h2>
        <p class="text-muted mb-0">This action cannot be undone</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-primary">
        <i class="fa-solid fa-arrow-left me-2"></i>Back to List
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="alert alert-danger d-flex gap-2">
            <i class="fa-solid fa-triangle-exclamation fa-lg mt-1"></i>
            <div>
                <strong>Are you sure?</strong> You are about to permanently delete appointment <strong>#@Model?.AppointmentId</strong>.
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-calendar-xmark text-danger me-2"></i>Appointment to Delete</span>
            </div>
            <div class="card-body">
                <dl class="row g-0">
                    <dt class="col-sm-4 text-muted fw-semibold py-2 border-bottom" style="font-size:0.875rem;">Donor ID</dt>
                    <dd class="col-sm-8 py-2 border-bottom fw-bold">@Html.DisplayFor(m => m.DonorId)</dd>

                    <dt class="col-sm-4 text-muted fw-semibold py-2 border-bottom" style="font-size:0.875rem;">Date</dt>
                    <dd class="col-sm-8 py-2 border-bottom">@Html.DisplayFor(m => m.AppointmentDate)</dd>

                    <dt class="col-sm-4 text-muted fw-semibold py-2 border-bottom" style="font-size:0.875rem;">Time</dt>
                    <dd class="col-sm-8 py-2 border-bottom">@Html.DisplayFor(m => m.AppointmentTime)</dd>

                    <dt class="col-sm-4 text-muted fw-semibold py-2 border-bottom" style="font-size:0.875rem;">Status</dt>
                    <dd class="col-sm-8 py-2 border-bottom">@Html.DisplayFor(m => m.Status)</dd>

                    <dt class="col-sm-4 text-muted fw-semibold py-2 border-bottom" style="font-size:0.875rem;">Notes</dt>
                    <dd class="col-sm-8 py-2 border-bottom text-muted">@(string.IsNullOrEmpty(Model?.Notes) ? "—" : Model.Notes)</dd>

                    <dt class="col-sm-4 text-muted fw-semibold py-2" style="font-size:0.875rem;">Hospital</dt>
                    <dd class="col-sm-8 py-2">@Html.DisplayFor(m => m.Hospital.Address)</dd>
                </dl>
            </div>
        </div>

        <form asp-action="Delete" class="d-flex gap-2 mt-3">
            <input type="hidden" asp-for="AppointmentId" />
            <input type="submit" value="Yes, Delete Permanently" class="btn btn-danger flex-grow-1" />
            <a asp-action="Index" class="btn btn-outline-primary">Cancel</a>
        </form>
    </div>
</div>
