@model IEnumerable<BloodBank.Models.Appointment>

@{
    ViewData["Title"] = "Appointments";
}

<div class="page-header mt-4">
    <div>
        <h2 class="page-title d-flex align-items-center gap-2">
            <i class="fa-solid fa-calendar-check text-primary-brand"></i> Appointments
        </h2>
        <p class="text-muted mb-0">Manage all donation appointments</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fa-solid fa-plus me-2"></i>New Appointment
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Donor ID</th>
                        <th>Date</th>
                        <th>Time</th>
                        <th>Status</th>
                        <th>Notes</th>
                        <th>Created</th>
                        <th>Hospital</th>
                        <th style="text-align:right;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-5">
                                <i class="fa-solid fa-calendar-xmark fa-2x mb-2 d-block"></i>
                                No appointments found
                            </td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        var statusClass = item.Status == "Completed" ? "badge-success"
                            : item.Status == "Cancelled" ? "badge-danger"
                            : item.Status == "Confirmed" ? "badge-info"
                            : "badge-warning";
                        <tr>
                            <td><strong>@Html.DisplayFor(m => item.DonorId)</strong></td>
                            <td>@Html.DisplayFor(m => item.AppointmentDate)</td>
                            <td>@Html.DisplayFor(m => item.AppointmentTime)</td>
                            <td><span class="badge @statusClass">@Html.DisplayFor(m => item.Status)</span></td>
                            <td class="text-muted">@Html.DisplayFor(m => item.Notes)</td>
                            <td class="text-muted" style="font-size:0.8rem;">@Html.DisplayFor(m => item.CreatedAt)</td>
                            <td>@Html.DisplayFor(m => item.Hospital.Address)</td>
                            <td style="text-align:right;">
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Details" asp-route-id="@item.AppointmentId" class="btn btn-outline-primary btn-sm">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>
                                    <a asp-action="Edit" asp-route-id="@item.AppointmentId" class="btn btn-outline-primary btn-sm">
                                        <i class="fa-solid fa-pen-to-square"></i>
                                    </a>
                                    <a asp-action="Delete" asp-route-id="@item.AppointmentId" class="btn btn-danger btn-sm">
                                        <i class="fa-solid fa-trash"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
