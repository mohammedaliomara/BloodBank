@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BloodBank · Every Drop Counts</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800;900&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root {
  --cr:#D01C2A; --cr2:#FF3B4A; --cr-pale:#FFF1F2; --cr-mid:#FFCDD0;
  --slate:#080E1A; --slate2:#0F1521; --slate3:#1C2840;
  --fog:#F3F5F8; --fog2:#EAECF2;
  --ink:#080E1A; --ink-mid:#485070; --ink-soft:#8891AA;
  --white:#FFFFFF; --border:#E4E6EE;
  --em:#0C9B60; --em-pale:#EDFAF4;
  --sap:#1E5FD0; --sap-pale:#EEF3FF;
  --am:#D47B00; --am-pale:#FFF8EC;
}

*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }

html { scroll-behavior:smooth; }

body {
  font-family:'DM Sans', sans-serif;
  background:var(--white);
  color:var(--ink);
  overflow-x:hidden;
}

::-webkit-scrollbar { width:5px; }
::-webkit-scrollbar-thumb { background:var(--cr); border-radius:3px; }

/* ─── NAV ─── */
.nav {
  position:fixed; top:0; left:0; right:0; z-index:200;
  padding:0 5%;
  height:68px;
  display:flex; align-items:center; gap:0;
  transition:all 0.35s;
}
.nav.scrolled {
  background:rgba(8,14,26,0.92);
  backdrop-filter:blur(20px);
  border-bottom:1px solid rgba(255,255,255,0.06);
  height:60px;
}
.nav-brand {
  display:flex; align-items:center; gap:11px;
  text-decoration:none;
}
.nav-mark {
  width:38px; height:38px; background:var(--cr); border-radius:11px;
  display:flex; align-items:center; justify-content:center;
  box-shadow:0 6px 20px rgba(208,28,42,0.45);
  flex-shrink:0;
  transition:transform 0.2s;
}
.nav-mark:hover { transform:scale(1.07); }
.nav-mark svg { width:22px; height:22px; }
.nav-logo-name {
  font-family:'Sora', sans-serif;
  font-size:18px; font-weight:800;
  color:var(--white);
  letter-spacing:-0.5px;
}
.nav-links {
  display:flex; align-items:center; gap:32px;
  margin:0 auto;
  list-style:none;
}
.nav-links a {
  font-size:13px; font-weight:500;
  color:rgba(255,255,255,0.55);
  text-decoration:none;
  transition:color 0.2s;
  letter-spacing:0.1px;
}
.nav-links a:hover { color:var(--white); }
.nav-cta {
  display:flex; align-items:center; gap:10px;
}
.btn-nav-ghost {
  padding:8px 18px; border-radius:9px;
  border:1.5px solid rgba(255,255,255,0.18);
  background:transparent;
  color:rgba(255,255,255,0.7);
  font-size:13px; font-weight:600;
  cursor:pointer; font-family:'DM Sans', sans-serif;
  text-decoration:none;
  transition:all 0.2s;
}
.btn-nav-ghost:hover {
  border-color:rgba(255,255,255,0.4);
  color:var(--white);
  background:rgba(255,255,255,0.06);
}
.btn-nav-primary {
  padding:9px 20px; border-radius:9px;
  background:var(--cr);
  color:var(--white);
  font-size:13px; font-weight:700;
  cursor:pointer; font-family:'Sora', sans-serif;
  text-decoration:none;
  transition:all 0.2s;
  box-shadow:0 4px 16px rgba(208,28,42,0.4);
  letter-spacing:0.1px;
}
.btn-nav-primary:hover {
  background:#B01520;
  transform:translateY(-1px);
  box-shadow:0 8px 24px rgba(208,28,42,0.5);
}

/* ─── HERO ─── */
.hero {
  min-height:100vh;
  background:var(--slate);
  position:relative;
  display:flex; align-items:center;
  padding:100px 5% 80px;
  overflow:hidden;
}

/* Animated mesh background */
.hero-canvas {
  position:absolute; inset:0;
  pointer-events:none;
  overflow:hidden;
}
.hero-orb {
  position:absolute;
  border-radius:50%;
  filter:blur(80px);
}
.orb-1 {
  width:700px; height:700px;
  background:radial-gradient(ellipse, rgba(208,28,42,0.14) 0%, transparent 70%);
  top:-200px; right:-150px;
  animation:drift1 18s ease-in-out infinite;
}
.orb-2 {
  width:500px; height:500px;
  background:radial-gradient(ellipse, rgba(208,28,42,0.07) 0%, transparent 70%);
  bottom:-100px; left:-100px;
  animation:drift2 22s ease-in-out infinite;
}
.orb-3 {
  width:300px; height:300px;
  background:radial-gradient(ellipse, rgba(255,100,120,0.06) 0%, transparent 70%);
  top:40%; left:40%;
  animation:drift3 15s ease-in-out infinite;
}
@@keyframes drift1 { 0%,100%{transform:translate(0,0);} 50%{transform:translate(-40px,30px);} }
@@keyframes drift2 { 0%,100%{transform:translate(0,0);} 50%{transform:translate(30px,-25px);} }
@@keyframes drift3 { 0%,100%{transform:translate(0,0);} 50%{transform:translate(-20px,40px);} }

.hero-grid { display:none; }

.hero-content {
  max-width:700px;
  position:relative; z-index:2;
  animation:fadeUp 0.9s ease both;
}
.hero-stats-divider {
  width:100%;
  height:1px;
  background:rgba(255,255,255,0.07);
  margin-bottom:32px;
}
@@keyframes fadeUp {
  from { opacity:0; transform:translateY(30px); }
  to   { opacity:1; transform:translateY(0); }
}

.hero-eyebrow {
  display:inline-flex; align-items:center; gap:8px;
  background:rgba(208,28,42,0.12);
  border:1px solid rgba(208,28,42,0.28);
  border-radius:30px;
  padding:6px 16px;
  font-size:11px; font-weight:700;
  color:#FF8A90;
  text-transform:uppercase; letter-spacing:1.8px;
  margin-bottom:26px;
}
.ew-dot {
  width:7px; height:7px; background:#FF6B6B;
  border-radius:50%;
  animation:pulse-dot 2s ease-in-out infinite;
}
@@keyframes pulse-dot {
  0%,100%{transform:scale(1);opacity:1;}
  50%{transform:scale(1.8);opacity:0.3;}
}

.hero-title {
  font-family:'Sora', sans-serif;
  font-size:clamp(46px, 6vw, 80px);
  font-weight:900;
  color:var(--white);
  line-height:1.0;
  letter-spacing:-3px;
  margin-bottom:24px;
}
.hero-title .accent { color:var(--cr); }
.hero-title .dim { color:rgba(255,255,255,0.22); }

.hero-sub {
  font-size:17px;
  color:rgba(255,255,255,0.48);
  line-height:1.75;
  max-width:500px;
  margin-bottom:38px;
  font-weight:400;
}

.hero-actions {
  display:flex; align-items:center; gap:14px;
  flex-wrap:wrap;
  margin-bottom:40px;
}
.btn-hero-primary {
  display:inline-flex; align-items:center; gap:9px;
  padding:15px 28px;
  background:var(--cr);
  color:var(--white);
  border:none; border-radius:12px;
  font-family:'Sora', sans-serif;
  font-size:15px; font-weight:700;
  cursor:pointer; text-decoration:none;
  transition:all 0.22s;
  box-shadow:0 8px 28px rgba(208,28,42,0.45);
  letter-spacing:0.1px;
}
.btn-hero-primary:hover {
  background:#B01520;
  transform:translateY(-2px);
  box-shadow:0 14px 38px rgba(208,28,42,0.55);
}
.btn-hero-primary svg { width:18px; height:18px; }

.btn-hero-ghost {
  display:inline-flex; align-items:center; gap:8px;
  padding:14px 26px;
  background:rgba(255,255,255,0.06);
  color:rgba(255,255,255,0.7);
  border:1.5px solid rgba(255,255,255,0.14);
  border-radius:12px;
  font-family:'DM Sans', sans-serif;
  font-size:14px; font-weight:600;
  cursor:pointer; text-decoration:none;
  transition:all 0.2s;
}
.btn-hero-ghost:hover {
  background:rgba(255,255,255,0.1);
  color:var(--white);
  border-color:rgba(255,255,255,0.28);
}

.hero-stats {
  display:flex; gap:36px; flex-wrap:wrap;
}
.hs-item { display:flex; flex-direction:column; gap:4px; }
.hs-val {
  font-family:'Sora', sans-serif;
  font-size:28px; font-weight:800;
  color:var(--white); letter-spacing:-1px;
}
.hs-val span { color:var(--cr); }
.hs-lbl {
  font-size:11px;
  color:rgba(255,255,255,0.32);
  text-transform:uppercase; letter-spacing:1px;
}
.hs-div {
  width:1px; background:rgba(255,255,255,0.08);
  align-self:center; height:44px;
}

/* floating card right side */
.hero-visual {
  position:absolute; right:6%; top:50%;
  transform:translateY(-50%);
  z-index:2;
  display:flex; flex-direction:column; gap:14px;
  animation:fadeUp 1.1s ease 0.2s both;
}
.hv-card {
  background:rgba(255,255,255,0.05);
  border:1px solid rgba(255,255,255,0.1);
  border-radius:16px;
  padding:18px 20px;
  backdrop-filter:blur(12px);
  width:260px;
}
.hv-label {
  font-size:9px; font-weight:700; color:rgba(255,255,255,0.35);
  text-transform:uppercase; letter-spacing:1.5px; margin-bottom:10px;
}
.hv-blood-row {
  display:flex; gap:6px; flex-wrap:wrap;
}
.hv-blood-tag {
  font-family:'Sora', sans-serif;
  font-size:12px; font-weight:800;
  padding:5px 10px; border-radius:7px;
  background:rgba(208,28,42,0.2);
  border:1px solid rgba(208,28,42,0.3);
  color:#FF8A90;
}
.hv-stat-row {
  display:flex; align-items:center; justify-content:space-between;
  padding:8px 0;
  border-bottom:1px solid rgba(255,255,255,0.06);
}
.hv-stat-row:last-child { border:none; }
.hv-stat-key { font-size:12px; color:rgba(255,255,255,0.45); }
.hv-stat-val { font-family:'Sora', sans-serif; font-size:13px; font-weight:700; color:var(--white); }
.hv-pill {
  display:inline-flex; align-items:center; gap:6px;
  padding:4px 10px; border-radius:20px;
  font-size:10px; font-weight:700;
}
.pill-green { background:rgba(12,155,96,0.2); border:1px solid rgba(12,155,96,0.3); color:#5DEBB4; }
.pill-amber { background:rgba(212,123,0,0.2); border:1px solid rgba(212,123,0,0.3); color:#FFC870; }
.pill-dot { width:5px; height:5px; border-radius:50%; }
.pd-green { background:#5DEBB4; animation:pulse-dot 2s infinite; }
.pd-amber { background:#FFC870; animation:pulse-dot 2.5s infinite; }

.urgent-card {
  background:rgba(208,28,42,0.12);
  border:1px solid rgba(208,28,42,0.3);
  border-radius:14px; padding:16px 18px;
  backdrop-filter:blur(12px);
  width:260px;
}
.uc-label {
  display:flex; align-items:center; gap:6px;
  font-size:9px; font-weight:700; color:#FF8A90;
  text-transform:uppercase; letter-spacing:1.5px;
  margin-bottom:10px;
}
.uc-blood {
  font-family:'Sora', sans-serif;
  font-size:36px; font-weight:900; color:#FF3B4A;
  letter-spacing:-2px; line-height:1;
}
.uc-hosp { font-size:13px; font-weight:600; color:var(--white); margin-top:5px; }
.uc-meta { font-size:11px; color:rgba(255,255,255,0.4); margin-top:3px; }
.uc-btn {
  width:100%; padding:10px;
  background:var(--cr); color:var(--white);
  border:none; border-radius:9px;
  font-family:'Sora', sans-serif; font-size:12px; font-weight:700;
  cursor:pointer; margin-top:12px; transition:all 0.18s;
}
.uc-btn:hover { background:#B01520; }

/* scroll indicator */
.scroll-hint {
  position:absolute; bottom:30px; left:50%; transform:translateX(-50%);
  display:flex; flex-direction:column; align-items:center; gap:6px;
  z-index:2; color:rgba(255,255,255,0.22); font-size:11px;
  animation:bounce 2.5s ease-in-out infinite;
}
@@keyframes bounce { 0%,100%{transform:translateX(-50%) translateY(0);} 50%{transform:translateX(-50%) translateY(6px);} }
.scroll-arrow { width:20px; height:20px; }


/* ─── SECTION BASE ─── */
section { padding:100px 5%; }
.section-eyebrow {
  display:inline-flex; align-items:center; gap:7px;
  background:var(--cr-pale);
  border:1px solid var(--cr-mid);
  border-radius:30px;
  padding:5px 14px;
  font-size:10px; font-weight:700;
  color:var(--cr);
  text-transform:uppercase; letter-spacing:1.5px;
  margin-bottom:18px;
}
.section-title {
  font-family:'Sora', sans-serif;
  font-size:clamp(32px, 4vw, 48px);
  font-weight:800;
  letter-spacing:-1.5px;
  line-height:1.1;
  color:var(--ink);
  margin-bottom:16px;
}
.section-title .accent { color:var(--cr); }
.section-subtitle {
  font-size:16px;
  color:var(--ink-soft);
  line-height:1.7;
  max-width:520px;
}

/* ─── ABOUT ─── */
.about {
  background:var(--white);
  display:flex; align-items:center; gap:80px;
  flex-wrap:wrap;
}
.about-left { flex:1; min-width:300px; }
.about-right {
  flex:1; min-width:300px;
  display:grid; grid-template-columns:1fr 1fr; gap:14px;
}
.about-card {
  background:var(--fog);
  border:1px solid var(--border);
  border-radius:16px; padding:22px;
  transition:all 0.25s;
}
.about-card:hover {
  border-color:var(--cr-mid);
  background:var(--cr-pale);
  transform:translateY(-3px);
  box-shadow:0 12px 30px rgba(208,28,42,0.08);
}
.about-card-ico {
  font-size:28px; margin-bottom:12px;
}
.about-card-title {
  font-family:'Sora', sans-serif;
  font-size:15px; font-weight:700;
  margin-bottom:6px;
}
.about-card-desc {
  font-size:13px; color:var(--ink-soft); line-height:1.6;
}
.about-card.span2 { grid-column:1/-1; display:flex; align-items:center; gap:20px; }
.about-card.span2 .about-card-ico { font-size:36px; margin:0; flex-shrink:0; }

/* timeline */
.timeline {
  display:flex; flex-direction:column; gap:0;
  margin-top:32px;
}
.tl-item {
  display:flex; gap:16px; padding-bottom:28px;
  position:relative;
}
.tl-item:not(:last-child)::after {
  content:''; position:absolute;
  left:17px; top:36px; bottom:0;
  width:2px; background:var(--border);
}
.tl-dot {
  width:36px; height:36px; border-radius:50%;
  background:var(--cr-pale); border:2px solid var(--cr);
  display:flex; align-items:center; justify-content:center;
  font-size:14px; flex-shrink:0; z-index:1;
}
.tl-year {
  font-family:'Sora', sans-serif;
  font-size:11px; font-weight:700;
  color:var(--cr); margin-bottom:3px;
}
.tl-title { font-size:14px; font-weight:700; }
.tl-desc { font-size:12px; color:var(--ink-soft); margin-top:3px; line-height:1.5; }


/* ─── SERVICES ─── */
.services { background:var(--fog); }
.services-grid {
  display:grid;
  grid-template-columns:repeat(3, 1fr);
  gap:16px;
  margin-top:50px;
}
.svc-card {
  background:var(--white);
  border:1.5px solid var(--border);
  border-radius:18px;
  padding:28px 24px;
  position:relative; overflow:hidden;
  transition:all 0.28s;
  cursor:default;
}
.svc-card::before {
  content:'';
  position:absolute; bottom:0; left:0; right:0;
  height:3px;
  opacity:0; transition:opacity 0.25s;
}
.svc-card:hover {
  border-color:transparent;
  box-shadow:0 16px 48px rgba(15,21,33,0.1);
  transform:translateY(-4px);
}
.svc-card:hover::before { opacity:1; }
.svc-card.c-red::before { background:linear-gradient(to right,var(--cr),#FF7080); }
.svc-card.c-blue::before { background:linear-gradient(to right,var(--sap),#60A0FF); }
.svc-card.c-green::before { background:linear-gradient(to right,var(--em),#40D090); }
.svc-card.c-amber::before { background:linear-gradient(to right,var(--am),#FFB340); }
.svc-card.c-violet::before { background:linear-gradient(to right,#6E40C9,#B080FF); }
.svc-card.c-navy::before { background:linear-gradient(to right,#1B3A7A,#4080FF); }

.svc-ico-wrap {
  width:54px; height:54px; border-radius:14px;
  display:flex; align-items:center; justify-content:center;
  font-size:26px; margin-bottom:18px;
}
.ico-red { background:var(--cr-pale); }
.ico-blue { background:var(--sap-pale); }
.ico-green { background:var(--em-pale); }
.ico-amber { background:var(--am-pale); }
.ico-violet { background:#F3EEFF; }
.ico-navy { background:#EEF2FF; }

.svc-tag {
  position:absolute; top:18px; right:18px;
  font-size:9px; font-weight:700;
  padding:3px 8px; border-radius:8px;
  text-transform:uppercase; letter-spacing:1px;
}
.tag-red { background:var(--cr-pale); color:var(--cr); }
.tag-blue { background:var(--sap-pale); color:var(--sap); }
.tag-green { background:var(--em-pale); color:var(--em); }
.tag-amber { background:var(--am-pale); color:var(--am); }
.tag-violet { background:#F3EEFF; color:#6E40C9; }
.tag-navy { background:#EEF2FF; color:#1B3A7A; }

.svc-title {
  font-family:'Sora', sans-serif;
  font-size:17px; font-weight:700;
  letter-spacing:-0.3px; margin-bottom:10px;
}
.svc-desc {
  font-size:13px; color:var(--ink-soft);
  line-height:1.65;
  margin-bottom:18px;
}
.svc-features {
  display:flex; flex-direction:column; gap:6px;
}
.svc-feat {
  display:flex; align-items:center; gap:8px;
  font-size:12px; color:var(--ink-mid);
}
.feat-dot { width:5px; height:5px; border-radius:50%; flex-shrink:0; }
.fd-red { background:var(--cr); }
.fd-blue { background:var(--sap); }
.fd-green { background:var(--em); }
.fd-amber { background:var(--am); }
.fd-violet { background:#6E40C9; }
.fd-navy { background:#1B3A7A; }


/* ─── ROLES ─── */
.roles { background:var(--white); }
.roles-grid {
  display:grid;
  grid-template-columns:repeat(5, 1fr);
  gap:12px;
  margin-top:50px;
}
.role-card {
  background:var(--fog);
  border:1.5px solid var(--border);
  border-radius:16px; padding:22px 16px;
  text-align:center;
  cursor:pointer; text-decoration:none; color:var(--ink);
  transition:all 0.22s;
  display:flex; flex-direction:column; align-items:center; gap:10px;
}
.role-card:hover {
  transform:translateY(-4px);
  box-shadow:0 12px 36px rgba(15,21,33,0.1);
  border-color:var(--cr-mid);
  background:var(--white);
}
.role-ico {
  width:52px; height:52px; border-radius:15px;
  display:flex; align-items:center; justify-content:center;
  font-size:24px;
}
.role-name {
  font-family:'Sora', sans-serif;
  font-size:13px; font-weight:700;
}
.role-desc { font-size:11px; color:var(--ink-soft); line-height:1.4; }
.role-chip {
  font-size:10px; font-weight:700; padding:3px 9px;
  border-radius:20px; margin-top:2px;
}


/* ─── IMPACT ─── */
.impact {
  background:var(--slate);
  position:relative; overflow:hidden;
}
.impact::before {
  content:''; position:absolute; inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size:60px 60px;
}
.impact-orb {
  position:absolute; border-radius:50%; filter:blur(80px); pointer-events:none;
}
.io1 { width:600px; height:400px; background:radial-gradient(ellipse,rgba(208,28,42,0.1) 0%,transparent 70%); top:-100px; right:-100px; }
.io2 { width:400px; height:400px; background:radial-gradient(ellipse,rgba(208,28,42,0.06) 0%,transparent 70%); bottom:-80px; left:-80px; }

.impact-inner { position:relative; z-index:1; }
.impact-header { text-align:center; margin-bottom:64px; }
.impact-header .section-title { color:var(--white); }
.impact-header .section-subtitle { color:rgba(255,255,255,0.45); margin:0 auto; }
.impact-header .section-eyebrow {
  background:rgba(208,28,42,0.15);
  border-color:rgba(208,28,42,0.3);
  color:#FF8A90;
}

.impact-grid {
  display:grid;
  grid-template-columns:repeat(4, 1fr);
  gap:16px;
  margin-bottom:48px;
}
.impact-card {
  background:rgba(255,255,255,0.05);
  border:1px solid rgba(255,255,255,0.08);
  border-radius:16px; padding:28px 22px;
  text-align:center;
  transition:all 0.25s;
}
.impact-card:hover {
  background:rgba(255,255,255,0.08);
  border-color:rgba(208,28,42,0.3);
  transform:translateY(-3px);
}
