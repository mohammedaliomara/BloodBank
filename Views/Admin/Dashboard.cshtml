function closeReview(){document.getElementById('reviewOverlay').classList.remove('open');}
function approveFromReview(){closeReview();}
function rejectFromReview(){closeReview();}

function closeSMS(){document.getElementById('smsOverlay').classList.remove('open');}
function sendSMS(){
  const btn=document.getElementById('sendSMSBtn');
  const msg = document.getElementById('sms-text').value.trim();
  if(!msg){alert('Please enter a message.');return;}
  btn.textContent='⏳ Sending...';btn.disabled=true;
  const params = new URLSearchParams({ message: msg, bloodNeeded: 'O-', governorate: 'Cairo' });
  fetch('/Admin/SendBulkSMS', { method: 'POST', body: params, headers: {'Content-Type':'application/x-www-form-urlencoded'} })
    .then(r => r.json())
    .then(data => {
      btn.textContent=`✅ Sent to ${data.count || '?'} donors`;btn.style.background='var(--emerald)';
      setTimeout(()=>{closeSMS();btn.textContent='📱 Send';btn.style.background='';btn.disabled=false;},1500);
    }).catch(()=>{ btn.textContent='📱 Send';btn.disabled=false; alert('Send failed'); });
}

function addCenter(){document.getElementById('centerOverlay').classList.add('open');}
function closeCenter(){document.getElementById('centerOverlay').classList.remove('open');}
function submitCenter(){
  const name=document.getElementById('cName').value.trim();
  const address=document.getElementById('cAddress') ? document.getElementById('cAddress').value.trim() : '';
  const gov=document.getElementById('cGov') ? document.getElementById('cGov').value : 'Cairo';
  const phone=document.getElementById('cPhone') ? document.getElementById('cPhone').value.trim() : '';
  if(!name){alert('Please fill in center name.');return;}
  const btn=document.getElementById('centerBtn');
  btn.textContent='⏳ Adding...';btn.disabled=true;
  const params = new URLSearchParams({ name, address, governorate: gov, phone });
  fetch('/Admin/AddCenter', { method: 'POST', body: params, headers: {'Content-Type':'application/x-www-form-urlencoded'} })
    .then(r => r.ok ? r.json() : Promise.reject())
    .then(() => {
      btn.textContent='✅ Center Added';btn.style.background='var(--emerald)';
      setTimeout(()=>{closeCenter();btn.textContent='Add Center';btn.style.background='';btn.disabled=false;
        document.getElementById('cName').value='';
        loadAdminData();
      },1500);
    }).catch(()=>{ btn.textContent='Add Center';btn.disabled=false; alert('Error adding center'); });
}

