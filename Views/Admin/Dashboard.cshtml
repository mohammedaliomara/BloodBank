@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page-header mt-4">
    <h2 class="page-title d-flex align-items-center gap-2">
        <i class="fa-solid fa-shield-halved text-primary-brand"></i> BloodBank Admin Console
    </h2>
    <span class="badge badge-primary"><i class="fa-solid fa-circle-check"></i> System Live</span>
</div>

<!-- TOP STATS -->
<div class="row mb-4">
    <div class="col-md col-sm-6 mb-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-success"><i class="fa-solid fa-boxes-stacked"></i></div>
            <div class="stat-info">
                <div class="stat-label">Units in Stock</div>
                <div class="stat-value">@ViewBag.TotalBloodUnits</div>
            </div>
        </div>
    </div>
    <div class="col-md col-sm-6 mb-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-danger"><i class="fa-solid fa-clipboard-list"></i></div>
            <div class="stat-info">
                <div class="stat-label">Active Requests</div>
                <div class="stat-value text-danger">@ViewBag.PendingRequests</div>
            </div>
        </div>
    </div>
    <div class="col-md col-sm-6 mb-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-primary"><i class="fa-solid fa-users"></i></div>
            <div class="stat-info">
                <div class="stat-label">Donors Ready</div>
                <div class="stat-value">@ViewBag.TotalDonors</div>
            </div>
        </div>
    </div>
    <div class="col-md col-sm-6 mb-3">
        <div class="stat-card">
            <div class="stat-icon stat-bg-warning"><i class="fa-solid fa-hourglass-half"></i></div>
            <div class="stat-info">
                <div class="stat-label">Expiring Soon</div>
                <div class="stat-value text-warning">@ViewBag.ExpiringSoon</div>
            </div>
        </div>
    </div>
</div>

<!-- TABS -->
<ul class="nav nav-tabs" id="adminTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview" type="button" role="tab">
            <i class="fa-solid fa-chart-pie me-2"></i> Overview
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="requests-tab" data-bs-toggle="tab" data-bs-target="#requests" type="button" role="tab">
            <i class="fa-solid fa-code-pull-request me-2"></i> Requests
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="inventory-tab" data-bs-toggle="tab" data-bs-target="#inventory" type="button" role="tab">
            <i class="fa-solid fa-boxes-stacked me-2"></i> Inventory
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="donors-tab" data-bs-toggle="tab" data-bs-target="#donors" type="button" role="tab">
            <i class="fa-solid fa-users me-2"></i> Donors
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="centers-tab" data-bs-toggle="tab" data-bs-target="#centers" type="button" role="tab">
            <i class="fa-solid fa-hospital me-2"></i> Centers
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="settings-tab" data-bs-toggle="tab" data-bs-target="#settings" type="button" role="tab">
            <i class="fa-solid fa-gear me-2"></i> Settings
        </button>
    </li>
</ul>

<div class="tab-content" id="adminTabsContent">
    
    <!-- OVERVIEW TAB -->
    <div class="tab-pane fade show active" id="overview" role="tabpanel" tabindex="0">
        <div class="row">
            <div class="col-lg-8">
                <div class="card h-100">
                    <div class="card-header">
                        <span><i class="fa-solid fa-chart-column me-2 text-primary-brand"></i> Donations — Last 7 Days</span>
                    </div>
                    <div class="card-body d-flex flex-column justify-content-center align-items-center" style="min-height: 250px;">
                        <div class="d-flex align-items-end justify-content-around w-100 mb-3" style="height: 150px; border-bottom: 2px solid var(--border);">
                            <!-- Mock Bars -->
                            <div class="d-flex flex-column align-items-center w-100 px-1">
                                <div class="bg-primary-brand rounded-top w-100" style="height: 20%; opacity: 0.7;"></div>
                                <small class="mt-2 text-muted fw-bold">Sun</small>
                            </div>
                            <div class="d-flex flex-column align-items-center w-100 px-1">
                                <div class="bg-primary-brand rounded-top w-100" style="height: 30%; opacity: 0.7;"></div>
                                <small class="mt-2 text-muted fw-bold">Mon</small>
                            </div>
                            <div class="d-flex flex-column align-items-center w-100 px-1">
                                <div class="bg-primary-brand rounded-top w-100" style="height: 40%; opacity: 0.7;"></div>
                                <small class="mt-2 text-muted fw-bold">Tue</small>
                            </div>
                            <div class="d-flex flex-column align-items-center w-100 px-1">
                                <div class="bg-danger rounded-top w-100" style="height: 80%;"></div>
                                <small class="mt-2 text-danger fw-bold">Wed</small>
                            </div>
                            <div class="d-flex flex-column align-items-center w-100 px-1">
                                <div class="bg-primary-brand rounded-top w-100" style="height: 50%; opacity: 0.7;"></div>
                                <small class="mt-2 text-muted fw-bold">Thu</small>
                            </div>
                            <div class="d-flex flex-column align-items-center w-100 px-1">
                                <div class="bg-primary-brand rounded-top w-100" style="height: 60%; opacity: 0.7;"></div>
                                <small class="mt-2 text-muted fw-bold">Fri</small>
                            </div>
                            <div class="d-flex flex-column align-items-center w-100 px-1">
                                <div class="bg-success rounded-top w-100" style="height: 90%;"></div>
                                <small class="mt-2 text-success fw-bold">Today</small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-lg-4">
                <div class="card h-100">
                    <div class="card-header">
                        <span><i class="fa-solid fa-droplet me-2 text-danger"></i> Blood Type Distribution</span>
                    </div>
                    <div class="card-body">
                        <div class="text-center mb-4">
                            <h2 class="display-4 fw-bold text-dark mb-0">@ViewBag.TotalBloodUnits</h2>
                            <p class="text-muted">Total Units</p>
                        </div>
                        <ul class="list-group list-group-flush" id="overview-blood-types">
                            <!-- Populated dynamically -->
                            <li class="list-group-item text-center text-muted border-0">Loading...</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- REQUESTS TAB -->
    <div class="tab-pane fade" id="requests" role="tabpanel" tabindex="0">
        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-clipboard-list me-2 text-primary-brand"></i> Hospital Requests</span>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Request #</th>
                                <th>Hospital</th>
                                <th>Blood Type</th>
                                <th>Quantity</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="requests-tbody">
                            <tr><td colspan="7" class="text-center text-muted">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- INVENTORY TAB -->
    <div class="tab-pane fade" id="inventory" role="tabpanel" tabindex="0">
        <div class="row" id="inventory-grid">
            <div class="col-12 text-center text-muted py-4">Loading inventory...</div>
        </div>
        <div class="mt-4">
            <button class="btn btn-primary" onclick="sendSMSCampaign(this)">
                <i class="fa-solid fa-mobile-screen"></i> Send SMS to Required Donors
            </button>
        </div>
    </div>

    <!-- DONORS TAB -->
    <div class="tab-pane fade" id="donors" role="tabpanel" tabindex="0">
        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-users me-2 text-primary-brand"></i> Donor List</span>
                <a href="/Admin/ExportDonors" class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-file-export"></i> Export</a>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Donor</th>
                                <th>Blood Type</th>
                                <th>Location</th>
                                <th>Last Donation</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="donors-tbody">
                            <tr><td colspan="5" class="text-center text-muted">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- CENTERS TAB -->
    <div class="tab-pane fade" id="centers" role="tabpanel" tabindex="0">
        <div class="card">
            <div class="card-header">
                <span><i class="fa-solid fa-hospital me-2 text-primary-brand"></i> Donation Centers</span>
                <button class="btn btn-primary btn-sm"><i class="fa-solid fa-plus"></i> Add Center</button>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Center</th>
                                <th>Address</th>
                                <th>Governorate</th>
                                <th>Phone</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody id="centers-tbody">
                            <tr><td colspan="5" class="text-center text-muted">Loading...</td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <!-- SETTINGS TAB -->
    <div class="tab-pane fade" id="settings" role="tabpanel" tabindex="0">
        <div class="row">
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header">
                        <span><i class="fa-solid fa-gear me-2 text-primary-brand"></i> Inventory Settings</span>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Minimum stock threshold (units)</label>
                            <input type="number" class="form-control" value="20" id="set-minStock">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Blood unit validity period (days)</label>
                            <input type="number" class="form-control" value="42" id="set-expDays">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Cooldown period between donations (days)</label>
                            <input type="number" class="form-control" value="90" id="set-cooldown">
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-6 mb-4">
                <div class="card h-100">
                    <div class="card-header">
                        <span><i class="fa-solid fa-mobile-screen me-2 text-primary-brand"></i> SMS Settings</span>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label">Sender ID</label>
                            <input type="text" class="form-control" value="BloodBankEG" id="set-sender">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">SMS API Key</label>
                            <input type="password" class="form-control" value="••••••••••••" id="set-apikey">
                        </div>
                        <button class="btn btn-primary" onclick="saveSettings(this)">
                            <i class="fa-solid fa-floppy-disk"></i> Save Settings
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
function loadAdminData() {
  // Load Requests
  fetch('/Admin/GetRequests')
    .then(r => r.json())
    .then(data => {
      const tbody = document.getElementById('requests-tbody');
      if(tbody) {
        tbody.innerHTML = data.length === 0 ? '<tr><td colspan="7" class="text-center text-muted">No active requests</td></tr>' : data.map(r => `
          <tr>
            <td class="fw-bold">#${r.requestId}</td>
            <td>${r.hospitalName}</td>
            <td><span class="badge badge-danger">${r.bloodType}</span></td>
            <td>${r.quantityNeeded} units</td>
            <td><span class="badge ${r.urgencyLevel === 'High' || r.urgencyLevel === 'Critical' ? 'badge-danger' : 'badge-warning'}">${r.urgencyLevel}</span></td>
            <td><span class="badge ${r.status === 'Approved' ? 'badge-success' : 'badge-primary'}">${r.status}</span></td>
            <td>
              ${r.status === 'Pending' ? `<button class="btn btn-primary btn-sm" onclick="approveReq(${r.requestId}, this)">Approve</button>` : `<span class="text-muted">—</span>`}
            </td>
          </tr>
        `).join('');
      }
    }).catch(() => {});

  // Load Inventory
  fetch('/Admin/GetInventory')
    .then(r => r.json())
    .then(data => {
      const grid = document.getElementById('inventory-grid');
      const ovTypes = document.getElementById('overview-blood-types');
      if (grid && data.length > 0) {
        let html = ''; let ovHtml = '';
        data.forEach(item => {
            const pct = Math.min(100, Math.round((item.quantity / 100) * 100));
            let badgeCls = 'bg-success';
            if(item.quantity < 20) badgeCls = 'bg-danger';
            else if(item.quantity < 50) badgeCls = 'bg-warning';
            
            html += `
            <div class="col-md-3 col-sm-6 mb-4">
                <div class="card h-100 text-center">
                    <div class="card-body">
                        <h3 class="fw-bold text-danger">${item.bloodType}</h3>
                        <p class="text-muted mb-2">${item.quantity} units</p>
                        <div class="progress" style="height: 6px;">
                            <div class="progress-bar ${badgeCls}" role="progressbar" style="width: ${pct}%"></div>
                        </div>
                    </div>
                </div>
            </div>`;
            
            ovHtml += `
            <li class="list-group-item d-flex justify-content-between align-items-center">
                <span class="fw-bold">${item.bloodType}</span>
                <span class="badge ${badgeCls} rounded-pill">${item.quantity}</span>
            </li>`;
        });
        grid.innerHTML = html;
        if(ovTypes) ovTypes.innerHTML = ovHtml;
      }
    }).catch(() => {});

  // Load Centers
  fetch('/Admin/GetCenters')
    .then(r => r.json())
    .then(data => {
      const tbody = document.getElementById('centers-tbody');
      if(tbody) {
        tbody.innerHTML = data.length === 0 ? '<tr><td colspan="5" class="text-center text-muted">No centers found</td></tr>' : data.map(c => `
          <tr>
            <td class="fw-bold">${c.name}</td>
            <td>${c.address}</td>
            <td>${c.governorate}</td>
            <td>${c.phoneNumber || '—'}</td>
            <td><span class="badge badge-success">${c.status}</span></td>
          </tr>
        `).join('');
      }
    }).catch(() => {});
}

function approveReq(id, btn) {
  const orig = btn.innerHTML;
  btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
  btn.disabled = true;
  fetch('/Admin/ApproveRequest', {
    method: 'POST',
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
    body: 'requestId=' + id
  })
  .then(r => r.ok ? r.json() : Promise.reject())
  .then(() => {
    btn.innerHTML = '<i class="fa-solid fa-check"></i>';
    btn.classList.replace('btn-primary', 'btn-success');
    setTimeout(() => { loadAdminData(); }, 1500);
  }).catch(() => {
    btn.innerHTML = 'Error';
    btn.classList.replace('btn-primary', 'btn-danger');
    setTimeout(() => { btn.innerHTML = orig; btn.classList.replace('btn-danger', 'btn-primary'); btn.disabled = false; }, 2000);
  });
}

function sendSMSCampaign(btn) {
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Sending...';
    btn.disabled = true;
    setTimeout(() => {
        btn.innerHTML = '<i class="fa-solid fa-check-double"></i> SMS Dispatched';
        btn.classList.replace('btn-primary', 'btn-success');
        setTimeout(() => {
            btn.innerHTML = orig;
            btn.classList.replace('btn-success', 'btn-primary');
            btn.disabled = false;
        }, 3000);
    }, 1500);
}

function saveSettings(btn) {
    const orig = btn.innerHTML;
    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Saving...';
    btn.disabled = true;
    setTimeout(() => {
        btn.innerHTML = '<i class="fa-solid fa-check"></i> Saved';
        btn.classList.replace('btn-primary', 'btn-success');
        setTimeout(() => {
            btn.innerHTML = orig;
            btn.classList.replace('btn-success', 'btn-primary');
            btn.disabled = false;
        }, 2000);
    }, 1000);
}

document.addEventListener('DOMContentLoaded', loadAdminData);
</script>
}
