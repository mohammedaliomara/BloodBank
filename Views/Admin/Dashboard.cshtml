        <div class="sbox"><div class="sl">Total Donors</div><div class="sn">@ViewBag.TotalDonors</div><div class="st up">↑ Registered</div><div class="sbar g"></div></div>
        <div class="sbox"><div class="sl">Total Hospitals</div><div class="sn">@ViewBag.TotalHospitals</div><div class="st up">↑ Connected</div><div class="sbar b"></div></div>
        <div class="sbox"><div class="sl">Donation Centers</div><div class="sn">@ViewBag.TotalCenters</div><div class="st up">↑ Active</div><div class="sbar g"></div></div>
        <div class="sbox"><div class="sl">Pending Requests</div><div class="sn" style="color:var(--amber)">@ViewBag.PendingRequests</div><div class="st dn">↓ Needs review</div><div class="sbar o"></div></div>
      </div>
      <div class="card">
        <div class="card-head"><div class="card-title"><div class="card-icon ci-green">👥</div>Donor List</div><div style="display:flex;gap:7px;"><div class="card-action" onclick="window.location.href='/Admin/ExportDonors'">Export</div><div class="card-action" onclick="go('pending',null)">Pending</div></div></div>
        <div class="drow" onclick="openDonorModal('Mohamed Ahmed','O-','Maadi','8','Ready ✅','Maadi Center')"><div class="d-ava">MA</div><div><div class="d-name">Mohamed Ahmed</div><div class="d-meta">📍 Maadi · Last donation: Jan 8, 2024</div></div><div class="d-blood">O-</div><div class="d-status on"></div></div>
        <div class="drow" onclick="openDonorModal('Sara Khaled','A+','Nasr City','6','Ready ✅','Nasr City Center')"><div class="d-ava">SK</div><div><div class="d-name">Sara Khaled</div><div class="d-meta">📍 Nasr City · Last donation: Oct 15, 2023</div></div><div class="d-blood">A+</div><div class="d-status on"></div></div>
        <div class="drow" onclick="openDonorModal('Karim Mahmoud','B+','Zamalek','5','Cooldown 🕐','Zamalek Center')"><div class="d-ava">KM</div><div><div class="d-name">Karim Mahmoud</div><div class="d-meta">📍 Zamalek · Last donation: Mar 1, 2024</div></div><div class="d-blood">B+</div><div class="d-status off"></div></div>
        <div class="drow" onclick="openDonorModal('Hend El Sheikh','AB-','Mohandeseen','4','Ready ✅','Mohandeseen Center')"><div class="d-ava">HS</div><div><div class="d-name">Hend El Sheikh</div><div class="d-meta">📍 Mohandeseen · Last donation: Nov 20, 2023</div></div><div class="d-blood">AB-</div><div class="d-status on"></div></div>
        <div class="drow" onclick="openDonorModal('Omar Farouk','O+','Dokki','3','Cooldown 🕐','Dokki Center')"><div class="d-ava">OF</div><div><div class="d-name">Omar Farouk</div><div class="d-meta">📍 Dokki · Last donation: Feb 5, 2024</div></div><div class="d-blood">O+</div><div class="d-status off"></div></div>
      </div>
    </div>

    <!-- ══ PENDING DONORS ══ -->
    <div id="s-pending" class="screen">
      <div class="card">
        <div class="card-head"><div class="card-title"><div class="card-icon ci-amber">⏳</div>Donors Pending Approval</div></div>
        <div style="padding: 20px; text-align: center; color: var(--ink-light); font-size: 13px;">No pending donors found</div>
      </div>
    </div>

    <!-- ══ CENTERS ══ -->
    <div id="s-centers" class="screen">
      <div class="g3 mb">
        <div class="sbox"><div class="sl">Active Centers</div><div class="sn">@ViewBag.TotalCenters</div><div class="st up">↑ Operating now</div><div class="sbar g"></div></div>
        <div class="sbox"><div class="sl">Today's Appointments (All Centers)</div><div class="sn">0</div><div class="st up">↑ Booked</div><div class="sbar b"></div></div>
        <div class="sbox"><div class="sl">Today's Donations (All Centers)</div><div class="sn">0</div><div class="st up">↑ Successful</div><div class="sbar g"></div></div>
      </div>
      <div class="card">
        <div class="card-head"><div class="card-title"><div class="card-icon ci-blue">🏪</div>Donation Centers</div><div class="card-action" onclick="addCenter()">+ Add Center</div></div>
        <table class="tbl">
          <thead><tr><th>Center</th><th>Address</th><th>Governorate</th><th>Phone</th><th>Status</th><th>Action</th></tr></thead>
          <tbody id="centers-tbody">
          </tbody>
        </table>
      </div>
      <div class="card">
        <div class="card-head"><div class="card-title"><div class="card-icon ci-green">📊</div>Center Performance — March 2026</div></div>
        <table class="tbl">
          <thead><tr><th>Center</th><th>Monthly Donations</th><th>Daily Average</th><th>Completion Rate</th></tr></thead>
          <tbody>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ══ TRACKING ══ -->
    <div id="s-tracking" class="screen">
      <div class="card mb">
        <div class="card-head"><div class="card-title"><div class="card-icon ci-blue">🔍</div>Track Blood Unit</div></div>
        <div style="display:flex;gap:10px;margin-bottom:18px;">
          <input class="f-i" placeholder="Unit number e.g.: BU-2024-00814" style="flex:1">
          <button class="btn b">Search</button>
        </div>
        <div class="track-steps" style="padding: 20px; text-align: center; color: var(--ink-light); font-size: 13px;">
          Search for a unit to begin tracking.
        </div>
      </div>
    </div>

    <!-- ══ HOSPITALS ══ -->
    <div id="s-hospitals" class="screen">
      <div class="g3 mb">
        <div class="sbox"><div class="sl">Registered Hospitals</div><div class="sn">@ViewBag.TotalHospitals</div><div class="st up">↑ Active</div><div class="sbar g"></div></div>
        <div class="sbox"><div class="sl">Requests This Month</div><div class="sn">0</div><div class="st up">↑ Requests</div><div class="sbar b"></div></div>
        <div class="sbox"><div class="sl">Completion Rate</div><div class="sn">0%</div><div class="st up">↑ Pending Data</div><div class="sbar g"></div></div>
      </div>
      <div class="card">
        <div class="card-head"><div class="card-title"><div class="card-icon ci-green">🏥</div>Registered Hospitals</div><div class="card-action" onclick="addHospital()">+ Add Hospital</div></div>
        <table class="tbl">
          <thead><tr><th>Hospital</th><th>Location</th><th>Phone</th><th>Email</th><th>Status</th><th>Action</th></tr></thead>
          <tbody id="hospitals-tbody">
          </tbody>
        </table>
      </div>
    </div>

    <!-- ══ SETTINGS ══ -->
    <div id="s-settings" class="screen">
      <div class="card mb">
        <div class="card-head"><div class="card-title"><div class="card-icon ci-red">⚙️</div>Inventory Settings</div></div>
        <div class="fg2" style="margin-bottom:14px;">
          <div class="f-g"><div class="f-l">Minimum stock threshold (units)</div><input class="f-i" type="number" value="20" min="1" id="set-minStock"></div>
          <div class="f-g"><div class="f-l">Blood unit validity period (days)</div><input class="f-i" type="number" value="42" min="1" id="set-expDays"></div>
        </div>
        <div class="f-g" style="margin-bottom:0;"><div class="f-l">Cooldown period between donations (days)</div><input class="f-i" type="number" value="90" min="1" id="set-cooldown" style="max-width:220px;"></div>
      </div>
      <div class="card">
        <div class="card-head"><div class="card-title"><div class="card-icon ci-blue">📱</div>SMS Settings</div></div>
        <div class="fg2" style="margin-bottom:14px;">
          <div class="f-g"><div class="f-l">Sender ID</div><input class="f-i" value="BloodBankEG" id="set-sender"></div>
          <div class="f-g"><div class="f-l">SMS API Key</div><input class="f-i" type="password" value="••••••••••••" id="set-apikey"></div>
        </div>
        <button class="btn" onclick="saveSettings(this)" style="padding:10px 24px;">💾 Save Settings</button>
      </div>
    </div>

  </div>
</div>

<!-- DONOR MODAL -->
<div class="overlay" id="donorOverlay" onclick="if(event.target===this)closeDonorModal()">
  <div class="modal">
    <div class="modal-hd">
      <div class="modal-ava" id="mAva">MA</div>
      <div><div style="font-size:16px;font-weight:800;" id="mName">Mohamed Ahmed</div><div style="font-size:12px;color:var(--ink-light);margin-top:2px;" id="mSub">O- · Maadi</div></div>
      <div class="modal-close" onclick="closeDonorModal()">✕</div>
    </div>
    <div class="mf-grid">
      <div class="mf"><div class="mf-l">Blood Type</div><div class="mf-v r" id="mBlood">O-</div></div>
      <div class="mf"><div class="mf-l">Donations</div><div class="mf-v" id="mDon">8</div></div>
      <div class="mf"><div class="mf-l">Status</div><div class="mf-v g" id="mStat">Ready</div></div>
      <div class="mf"><div class="mf-l">Donation Center</div><div class="mf-v" id="mCenter">Maadi Center</div></div>
    </div>
    <div style="display:flex;gap:8px;">
      <button class="btn" style="flex:1;font-size:12px;" onclick="notifyDonor(this)">📱 Send SMS</button>
      <button class="btn g" style="flex:1;font-size:12px;" onclick="closeDonorModal()">✅ Close</button>
    </div>
  </div>
</div>

<script>
const titles={
  dashboard:'Dashboard',requests:'Hospital Requests',
  inventory:'Blood Inventory',expiry:'Expiry Management',
  donors:'Donors',pending:'Pending Approval',
  centers:'Donation Centers',
  tracking:'Unit Tracking',
  hospitals:'Hospital Management',settings:'Settings'
};

function go(sc,el){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('on'));
  document.querySelectorAll('.sb-item').forEach(n=>n.classList.remove('on'));
  const s=document.getElementById('s-'+sc);
  if(s)s.classList.add('on');
  
  // Resolve sidebar item automatically if el is not provided
  let sidebarItem = el;
  if (!sidebarItem) {
    sidebarItem = Array.from(document.querySelectorAll('.sb-item')).find(item => {
      const onclickAttr = item.getAttribute('onclick');
      return onclickAttr && (onclickAttr.includes(`'${sc}'`) || onclickAttr.includes(`"${sc}"`));
    });
  }
  if(sidebarItem) sidebarItem.classList.add('on');
  
  document.getElementById('pageTitle').textContent=(titles[sc]||sc);
  const now = new Date();
  document.getElementById('pageSubtitle').textContent = now.toLocaleDateString('en-US', {weekday:'long', year:'numeric', month:'long', day:'numeric'});
  document.getElementById('sb').classList.remove('open');
}
function toggleSB(){document.getElementById('sb').classList.toggle('open');}
function logout(){
  const f = document.createElement('form');
  f.method = 'POST'; f.action = '/Account/Logout';
  document.body.appendChild(f);
  f.submit();
}

function loadAdminData() {
  // Load Requests
  fetch('/Admin/GetRequests')
    .then(r => r.json())
    .then(data => {
      const tbody = document.querySelector('#s-requests tbody');
      if(tbody) {
        tbody.innerHTML = data.map(r => `
          <tr>
            <td class="bold">#${r.requestId}</td>
            <td>${r.hospitalName}</td>
            <td style="color:var(--crimson);font-weight:700">${r.bloodType}</td>
            <td>${r.quantityNeeded} units</td>
            <td><span class="chip ${r.urgencyLevel === 'High' || r.urgencyLevel === 'Critical' ? 'urgent' : 'wait'}">${r.urgencyLevel}</span></td>
            <td><span class="chip ${r.status === 'Approved' ? 'done' : 'prog'}">${r.status}</span></td>
            <td>
              ${r.status === 'Pending' ? `<button class="btn" style="padding:5px 12px;font-size:11px;" onclick="approveReq(${r.requestId}, this)">Approve</button>` : `<span style="color:var(--ink-light);font-size:12px;">—</span>`}
            </td>
          </tr>
        `).join('');
      }
      
      // Update counts
      const reqTitle = document.getElementById('requests-title-count');
      if(reqTitle) reqTitle.textContent = `Hospital Requests (${data.length})`;
      
      const pendingCount = data.filter(r => r.status === 'Pending').length;
      const reqBadge = document.getElementById('sidebar-pending-requests');
      if(reqBadge) {
        reqBadge.textContent = pendingCount;
        reqBadge.style.display = pendingCount > 0 ? 'inline-block' : 'none';
      }

      const notifDot = document.getElementById('notif-dot');
      if(notifDot) {
        notifDot.style.display = pendingCount > 0 ? 'block' : 'none';
      }
    });

  // Load Donors
  fetch('/Admin/GetDonors')
    .then(r => r.json())
    .then(data => {
      // Find the donor list container. It's the parent of the .drow elements in #s-donors.
      const donorsContainer = document.querySelector('#s-donors .card');
      if (donorsContainer) {
        // Keep the card-head, remove the rest
        const headHtml = donorsContainer.querySelector('.card-head').outerHTML;
        const bodyHtml = data.map(d => `
          <div class="drow" onclick="openDonorModal('${d.nationalId}','${d.bloodType}','${d.governorate}','—','Ready ✅','—')">
            <div class="d-ava">${d.bloodType}</div>
            <div><div class="d-name">Donor #${d.id}</div><div class="d-meta">📍 ${d.governorate} · Phone: ${d.phoneNumber}</div></div>
            <div class="d-blood">${d.bloodType}</div>
            <div class="d-status on"></div>
          </div>
        `).join('');
        donorsContainer.innerHTML = headHtml + bodyHtml;
      }
      
      const donorBadge = document.getElementById('sidebar-donors');
      if(donorBadge) {
        donorBadge.textContent = data.length;
      }
    });

  // Load Hospitals
  fetch('/Admin/GetHospitals')
    .then(r => r.json())
    .then(data => {
      const tbody = document.getElementById('hospitals-tbody');
      if(tbody) {
        tbody.innerHTML = data.map(h => `
          <tr>
            <td class="bold">${h.name}</td>
            <td>${h.city || h.address}</td>
            <td>${h.phone}</td>
            <td>${h.email || '—'}</td>
            <td><span class="chip ${h.status === 'Active' ? 'done' : 'wait'}">${h.status}</span></td>
            <td style="display:flex;gap:6px;">
              <span style="color:var(--sapphire);font-size:12px;font-weight:600;cursor:pointer;" onclick="openEditHospital(${h.hospitalId}, '${h.name.replace(/'/g, "\\'")}', '${h.address.replace(/'/g, "\\'")}', '${h.city.replace(/'/g, "\\'")}', '${h.phone}', '${h.email || ''}')">Edit</span>
              <span style="color:${h.status === 'Active' ? 'var(--crimson)' : 'var(--emerald)'};font-size:12px;font-weight:600;cursor:pointer;" onclick="toggleHospitalStatus(${h.hospitalId}, this)">${h.status === 'Active' ? 'Disable' : 'Enable'}</span>
            </td>
          </tr>
        `).join('');
      }
    });

  // Load Centers
  fetch('/Admin/GetCenters')
    .then(r => r.json())
    .then(data => {
      const tbody = document.getElementById('centers-tbody');
      if(tbody) {
        tbody.innerHTML = data.map(c => `
          <tr>
            <td class="bold">${c.name}</td>
            <td>${c.address}</td>
            <td>${c.governorate}</td>
            <td>${c.phoneNumber}</td>
            <td><span class="chip ${c.status === 'Active' ? 'done' : 'wait'}">${c.status}</span></td>
            <td style="display:flex;gap:6px;">
              <span style="color:var(--sapphire);font-size:12px;font-weight:600;cursor:pointer;" onclick="openEditCenter(${c.id}, '${c.name.replace(/'/g, "\\'")}', '${c.address.replace(/'/g, "\\'")}', '${c.governorate}', '${c.phoneNumber}')">Edit</span>
              <span style="color:${c.status === 'Active' ? 'var(--crimson)' : 'var(--emerald)'};font-size:12px;font-weight:600;cursor:pointer;" onclick="toggleCenterStatus(${c.id}, this)">${c.status === 'Active' ? 'Disable' : 'Enable'}</span>
            </td>
          </tr>
        `).join('');
      }
    });
}

function approveReq(id, btn) {
  btn.textContent='⏳';btn.disabled=true;
  fetch('/Admin/ApproveRequest?requestId=' + id, { method: 'POST' })
    .then(() => {
      btn.textContent='✅ Approved';btn.style.background='var(--emerald)';btn.style.color='#fff';
      setTimeout(loadAdminData, 1000);
    });
}

function assignUnits(requestId, btn) {
  btn.textContent='⏳';btn.disabled=true;
  fetch('/Admin/AssignUnit?requestId=' + requestId, { method: 'POST' })
    .then(r => r.ok ? r.json() : Promise.reject())
    .then(() => {
      btn.textContent='✅ Assigned';btn.style.background='var(--emerald)';btn.style.color='#fff';
    }).catch(() => {
      btn.textContent='❌ Failed (Low Stock)';btn.style.background='var(--crimson)';btn.style.color='#fff';
      setTimeout(() => { btn.textContent='Assign Units'; btn.style.background=''; btn.disabled=false; }, 2000);
    });
}

function sendSMSCampaign(btn) {
  btn.textContent='⏳ Sending...';btn.disabled=true;
  
  const formData = new URLSearchParams();
  formData.append('message', 'URGENT: Blood Type O- is needed immediately at critical hospitals.');
  formData.append('bloodNeeded', 'O-');
  formData.append('governorate', 'Cairo'); // Or dynamically selected

  fetch('/Admin/SendBulkSMS', { 
    method: 'POST',
    body: formData,
    headers: { 'Content-Type': 'application/x-www-form-urlencoded' }
  })
  .then(r => r.json())
  .then((data) => {
    btn.textContent=`✅ SMS Sent to ${data.count || 'all'} Donors`;
    btn.style.background='var(--emerald)';
  });
}

function approveDonor(id, btn) {
  btn.textContent='⏳';
  fetch('/Admin/ApproveDonor?donorId=' + id, { method: 'POST' })
    .then(() => {
      btn.textContent='✅';btn.style.background='var(--emerald)';btn.style.color='#fff';
    });
}

function rejectDonor(btn) {
  btn.textContent='✗';btn.style.color='var(--crimson)';btn.style.borderColor='var(--crimson)';
}

function toggleCenterStatus(id, btn) {
  fetch('/Admin/ToggleCenterStatus?centerId=' + id, { method: 'POST' })
    .then(() => {
      if(btn.textContent==='Disable') { btn.textContent='Enable'; btn.style.color='var(--emerald)'; }
      else { btn.textContent='Disable'; btn.style.color='var(--crimson)'; }
    });
}

function reviewDonor(btn) {
  alert("Manual review needed for ID mismatch.");
}

document.addEventListener('DOMContentLoaded', loadAdminData);

let donationCountNum = 38;

function donationDone(btn){
  const row = btn.closest('.appt-row');
  const name = row.dataset.name;
  const blood = row.dataset.blood;
  const center = row.dataset.centerName;
  btn.textContent = '⏳ Recording...';
  btn.disabled = true;
  setTimeout(()=>{
    const uid = 'BU-2026-0' + (900 + Math.floor(Math.random()*99));
    row.classList.add('done-row');
    row.querySelector('.appt-status').className = 'chip done appt-status';
    row.querySelector('.appt-status').textContent = 'Donated ✅';
    row.querySelector('.appt-meta').textContent = blood + ' · ' + center + ' · Unit ' + uid + ' ✅';
    btn.textContent = '✅ Added to Stock';
    btn.style.background = 'var(--emerald)';
    donationCountNum++;
    document.getElementById('donationCount').textContent = donationCountNum;
    const log = document.querySelector('#s-dashboard .act:last-child');
    if(log){
      const newAct = document.createElement('div');
      newAct.className = 'act';
      newAct.innerHTML = `<div class="act-dot" style="background:var(--emerald)"></div><div class="act-txt"><strong>${name}</strong> donated ${blood} at ${center} · ${uid}<span class="act-time">Just now</span></div>`;
      log.parentNode.insertBefore(newAct, log);
    }
  }, 1000);
}

function filterCenter(btn, center){
  document.querySelectorAll('.center-filter').forEach(b => b.classList.remove('on'));
  btn.classList.add('on');
  document.querySelectorAll('.appt-row').forEach(row => {
    row.style.display = (center === 'all' || row.dataset.center === center) ? 'flex' : 'none';
  });
}

function addUnit(){alert('Add new unit form will open');}
function notifyDonor(btn){
  const name = document.getElementById('mName') ? document.getElementById('mName').textContent : 'Donor';
  const blood = document.getElementById('mBlood') ? document.getElementById('mBlood').textContent : '';
  document.getElementById('sms-text').value = `Dear ${name}, your blood type ${blood} is urgently needed. Please visit the nearest donation center. Thank you — BloodBank Egypt`;
  document.getElementById('smsOverlay').classList.add('open');
}
function openDonorModal(name,blood,loc,don,stat,center){
  document.getElementById('mAva').textContent=name.slice(0,2).toUpperCase();
  document.getElementById('mName').textContent=name;
  document.getElementById('mSub').textContent=blood+' · '+loc;
  document.getElementById('mBlood').textContent=blood;
  document.getElementById('mDon').textContent=don+' donations';
  document.getElementById('mStat').textContent=stat;
  document.getElementById('mCenter').textContent=center;
  document.getElementById('donorOverlay').classList.add('open');
}
function closeDonorModal(){document.getElementById('donorOverlay').classList.remove('open');}

function saveSettings(btn){
  btn.textContent='⏳ Saving...';btn.disabled=true;
  setTimeout(()=>{btn.textContent='✅ Saved';btn.style.background='var(--emerald)';
    setTimeout(()=>{btn.textContent='💾 Save Settings';btn.style.background='';btn.disabled=false;},2000);
  },900);
}

function toggleHospitalStatus(id, btn){
  fetch('/Admin/ToggleHospitalStatus?hospitalId=' + id, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      const row = btn.closest('tr');
      const chip = row.querySelector('.chip');
      if(data.status === 'Active'){
        chip.className='chip done'; chip.textContent='Active';
        btn.textContent='Disable'; btn.style.color='var(--crimson)';
      } else {
        chip.className='chip wait'; chip.textContent='Inactive';
        btn.textContent='Enable'; btn.style.color='var(--emerald)';
      }
    });
}

function toggleCenterStatus(id, btn){
  fetch('/Admin/ToggleCenterStatus?centerId=' + id, { method: 'POST' })
    .then(r => r.json())
    .then(data => {
      const row = btn.closest('tr');
      const chip = row.querySelector('.chip');
      if(data.status === 'Active'){
        chip.className='chip done'; chip.textContent='Active';
        btn.textContent='Disable'; btn.style.color='var(--crimson)';
      } else {
        chip.className='chip wait'; chip.textContent='Inactive';
        btn.textContent='Enable'; btn.style.color='var(--emerald)';
      }
    });
}

let _editHospitalId = null;
function openEditHospital(id, name, address, city, phone, email){
  _editHospitalId = id;
  document.getElementById('eh-name').value = name;
  document.getElementById('eh-location').value = address;
  if(document.getElementById('eh-gov')) document.getElementById('eh-gov').value = city;
  document.getElementById('eh-code').value = phone;
  document.getElementById('editHospitalOverlay').classList.add('open');
}
function closeEditHospital(){document.getElementById('editHospitalOverlay').classList.remove('open');}
function submitEditHospital(){
  const btn=document.getElementById('editHospitalBtn');
  btn.textContent='⏳ Saving...';btn.disabled=true;
  const params = new URLSearchParams({
    id: _editHospitalId,
    name: document.getElementById('eh-name').value,
    address: document.getElementById('eh-location').value,
    city: document.getElementById('eh-gov') ? document.getElementById('eh-gov').value : '',
    phone: document.getElementById('eh-code').value,
    email: ''
  });
  fetch('/Admin/EditHospital', { method: 'POST', body: params, headers: {'Content-Type':'application/x-www-form-urlencoded'} })
    .then(() => {
      btn.textContent='✅ Saved';btn.style.background='var(--emerald)';
      setTimeout(()=>{closeEditHospital();btn.textContent='Save Changes';btn.style.background='';btn.disabled=false;loadAdminData();},1500);
    });
}

