@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Haemo — Admin Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root{
  --crimson:#D01C2A;--crimson-deep:#A0141F;--crimson-pale:#FFF1F2;--crimson-mid:#FFCDD0;
  --slate:#0F1521;--slate-mid:#1C2840;
  --fog:#F3F4F8;--fog2:#EAECF2;
  --ink:#0F1521;--ink-mid:#485070;--ink-light:#8891AA;
  --white:#FFFFFF;--border:#E4E6EE;
  --emerald:#0C9B60;--emerald-pale:#EDFAF4;--emerald-mid:#B3ECDA;
  --amber:#D47B00;--amber-pale:#FFF8EC;
  --sapphire:#1E5FD0;--sapphire-pale:#EEF3FF;--sapphire-mid:#B3CFFF;
  --violet:#6E40C9;--violet-pale:#F3EEFF;
  --shadow:0 2px 16px rgba(15,21,33,0.07);--r:14px;
}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--fog);color:var(--ink);font-family:'DM Sans',sans-serif;min-height:100vh;display:flex;}
::-webkit-scrollbar{width:5px;}::-webkit-scrollbar-thumb{background:var(--border);border-radius:3px;}

/* SIDEBAR */
.sb{width:260px;background:var(--white);border-right:1px solid var(--border);height:100vh;position:fixed;left:0;top:0;display:flex;flex-direction:column;z-index:100;box-shadow:2px 0 16px rgba(15,21,33,0.05);}
.sb-logo{padding:22px 20px 18px;border-bottom:1px solid var(--border);}
.sb-logorow{display:flex;align-items:center;gap:11px;margin-bottom:14px;}
.sb-mark{width:42px;height:42px;background:var(--crimson);border-radius:13px;display:flex;align-items:center;justify-content:center;font-size:20px;box-shadow:0 6px 18px rgba(208,28,42,0.35);}
.sb-name{font-family:'Sora',sans-serif;font-size:15px;font-weight:800;letter-spacing:-0.4px;}
.sb-tag{font-size:10px;color:var(--ink-light);margin-top:1px;}
.sb-live{display:inline-flex;align-items:center;gap:6px;background:var(--emerald-pale);color:var(--emerald);font-size:10px;font-weight:700;padding:5px 12px;border-radius:20px;text-transform:uppercase;letter-spacing:0.8px;}
.live-dot{width:6px;height:6px;background:var(--emerald);border-radius:50%;animation:blink 2s ease-in-out infinite;}
@@keyframes blink{0%,100%{opacity:1;}50%{opacity:0.2;}}

.sb-nav{flex:1;padding:12px;overflow-y:auto;}
.sb-sec{font-size:9px;font-weight:700;color:var(--ink-light);text-transform:uppercase;letter-spacing:2px;padding:0 8px;margin:14px 0 4px;}
.sb-item{display:flex;align-items:center;gap:10px;padding:9px 10px;border-radius:10px;cursor:pointer;transition:all 0.18s;font-size:13px;font-weight:500;color:var(--ink-mid);margin-bottom:1px;position:relative;}
.sb-item:hover{background:var(--fog);color:var(--ink);}
.sb-item.on{background:var(--crimson-pale);color:var(--crimson);font-weight:700;}
.sb-ico{width:30px;height:30px;border-radius:9px;background:var(--fog);display:flex;align-items:center;justify-content:center;font-size:14px;flex-shrink:0;}
.sb-item.on .sb-ico{background:var(--crimson-mid);}
.sb-badge{margin-left:auto;font-size:9px;font-weight:800;padding:2px 7px;border-radius:12px;}
.sb-badge.r{background:var(--crimson);color:#fff;}
.sb-badge.o{background:var(--amber);color:#fff;}
.sb-badge.g{background:var(--emerald);color:#fff;}

.sb-foot{padding:14px;border-top:1px solid var(--border);}
.sb-user{display:flex;align-items:center;gap:10px;padding:11px 12px;background:var(--fog);border-radius:12px;cursor:pointer;}
.sb-ava{width:36px;height:36px;border-radius:10px;background:linear-gradient(135deg,var(--crimson),var(--crimson-deep));color:#fff;display:flex;align-items:center;justify-content:center;font-family:'Sora',sans-serif;font-size:13px;font-weight:700;flex-shrink:0;}
.sb-uname{font-size:12px;font-weight:700;}
.sb-urole{font-size:10px;color:var(--crimson);font-weight:600;}
.sb-logout{margin-left:auto;font-size:11px;color:var(--ink-light);cursor:pointer;transition:color 0.18s;}
.sb-logout:hover{color:var(--crimson);}

/* MAIN */
.main{margin-left:260px;flex:1;display:flex;flex-direction:column;min-height:100vh;}
.topbar{background:var(--white);border-bottom:1px solid var(--border);height:62px;display:flex;align-items:center;padding:0 28px;gap:11px;position:sticky;top:0;z-index:50;box-shadow:0 1px 8px rgba(15,21,33,0.04);}
.tb-title{flex:1;}
.tb-title h1{font-family:'Sora',sans-serif;font-size:18px;font-weight:700;letter-spacing:-0.4px;}
.tb-title p{font-size:11px;color:var(--ink-light);margin-top:1px;}
.tb-actions{display:flex;align-items:center;gap:10px;}
.icon-btn{width:38px;height:38px;border-radius:10px;border:1.5px solid var(--border);background:var(--white);display:flex;align-items:center;justify-content:center;cursor:pointer;position:relative;transition:all 0.18s;font-size:16px;}
.icon-btn:hover{border-color:var(--crimson);background:var(--crimson-pale);}
.icon-btn .dot{position:absolute;top:6px;right:6px;width:8px;height:8px;background:var(--crimson);border-radius:50%;border:2px solid var(--white);}
.tb-avatar{width:38px;height:38px;border-radius:10px;background:linear-gradient(135deg,var(--crimson),var(--crimson-deep));display:flex;align-items:center;justify-content:center;font-family:'Sora',sans-serif;font-size:13px;font-weight:700;color:#fff;cursor:pointer;}

.content{padding:26px 28px;flex:1;}
.screen{display:none;}.screen.on{display:block;}

/* COMPONENTS */
.card{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:20px;box-shadow:var(--shadow);}
.card-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px;}
.card-title{display:flex;align-items:center;gap:9px;font-size:14px;font-weight:700;color:var(--ink);}
.card-icon{width:28px;height:28px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:13px;}
.ci-red{background:var(--crimson-pale);}
.ci-green{background:var(--emerald-pale);}
.ci-blue{background:var(--sapphire-pale);}
.ci-amber{background:var(--amber-pale);}
.ci-violet{background:var(--violet-pale);}
.card-action{font-size:12px;color:var(--crimson);font-weight:600;cursor:pointer;padding:5px 12px;border-radius:8px;border:1.5px solid var(--crimson-mid);transition:all 0.18s;}
.card-action:hover{background:var(--crimson-pale);}

.g4{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin-bottom:20px;}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin-bottom:18px;}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-bottom:18px;}
.mb{margin-bottom:16px;}

/* STAT BOX */
.sbox{background:var(--white);border:1px solid var(--border);border-radius:var(--r);padding:20px;position:relative;overflow:hidden;box-shadow:var(--shadow);}
.sl{font-size:11px;color:var(--ink-light);margin-bottom:10px;text-transform:uppercase;letter-spacing:0.8px;}
.sn{font-family:'Sora',sans-serif;font-size:30px;font-weight:800;letter-spacing:-1.5px;line-height:1;}
.st{font-size:11px;margin-top:8px;font-weight:600;}.st.up{color:var(--emerald);}.st.dn{color:var(--crimson);}
.sbar{position:absolute;bottom:0;left:0;right:0;height:3px;}
.sbar.r{background:linear-gradient(to right,var(--crimson),transparent);}
.sbar.g{background:linear-gradient(to right,var(--emerald),transparent);}
.sbar.b{background:linear-gradient(to right,var(--sapphire),transparent);}
.sbar.o{background:linear-gradient(to right,var(--amber),transparent);}

/* CHIPS */
.chip{font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;display:inline-block;}
.chip.done{background:var(--emerald-pale);color:var(--emerald);}
.chip.wait{background:var(--amber-pale);color:var(--amber);}
.chip.urgent{background:var(--crimson-pale);color:var(--crimson);}
.chip.prog{background:var(--sapphire-pale);color:var(--sapphire);}
.chip.expired{background:var(--fog2);color:var(--ink-light);}

/* BUTTONS */
.btn{background:var(--crimson);color:#fff;border:none;padding:9px 18px;border-radius:9px;font-size:12px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all 0.18s;}
.btn:hover{background:var(--crimson-deep);transform:translateY(-1px);}
.btn:disabled{opacity:0.6;cursor:not-allowed;transform:none;}
.btn.g{background:var(--emerald);}.btn.g:hover{background:#077A4A;}
.btn.b{background:var(--sapphire);}.btn.b:hover{background:#1040A0;}
.btn-ghost{background:none;border:1.5px solid var(--border);color:var(--ink-mid);padding:8px 16px;border-radius:9px;font-size:12px;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all 0.18s;}
.btn-ghost:hover{border-color:var(--crimson);color:var(--crimson);}

/* TABLE */
.tbl{width:100%;border-collapse:collapse;}
.tbl th{font-size:11px;font-weight:700;color:var(--ink-light);text-align:left;padding:9px 14px;border-bottom:2px solid var(--border);background:var(--fog);text-transform:uppercase;letter-spacing:0.5px;}
.tbl td{font-size:12px;padding:11px 14px;border-bottom:1px solid var(--border);color:var(--ink-mid);vertical-align:middle;}
.tbl tr:hover td{background:var(--fog);}
.tbl td.bold{font-weight:700;color:var(--ink);}

/* ACTIVITY */
.act{display:flex;gap:12px;padding:10px 0;border-bottom:1px solid var(--border);}
.act:last-child{border:none;}
.act-dot{width:8px;height:8px;border-radius:50%;margin-top:5px;flex-shrink:0;}
.act-txt{font-size:12.5px;color:var(--ink-mid);line-height:1.5;flex:1;}
.act-txt strong{color:var(--ink);font-weight:600;}
.act-time{font-size:10px;color:var(--ink-light);margin-top:3px;display:block;}

/* INVENTORY GRID */
.inv-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;}
.inv-cell{background:var(--fog);border:1.5px solid var(--border);border-radius:11px;padding:16px;text-align:center;transition:all 0.2s;cursor:pointer;position:relative;}
.inv-cell:hover{border-color:var(--crimson);background:var(--crimson-pale);}
.inv-cell.low{background:var(--amber-pale);border-color:#F0C878;}
.inv-cell.critical{background:var(--crimson-pale);border-color:var(--crimson);animation:critBlink 2s infinite;}
@@keyframes critBlink{0%,100%{border-color:var(--crimson);}50%{border-color:transparent;}}
.inv-type{font-family:'Sora',sans-serif;font-size:18px;font-weight:800;color:var(--ink);}
.inv-units{font-size:11px;color:var(--ink-light);margin:4px 0 2px;}
.inv-exp{font-size:10px;font-weight:600;}
.inv-exp.ok{color:var(--emerald);}
.inv-exp.warn{color:var(--amber);}
.inv-exp.bad{color:var(--crimson);}
.inv-bar{height:4px;background:var(--fog2);border-radius:2px;overflow:hidden;margin-top:8px;}
.inv-fill{height:100%;border-radius:2px;}
.inv-fill.hi{background:var(--emerald);}
.inv-fill.mid{background:var(--amber);}
.inv-fill.lo{background:var(--crimson);}

/* UNIT ROW */
.unit-row{display:flex;align-items:center;gap:10px;padding:10px 13px;border:1.5px solid var(--border);border-radius:10px;cursor:pointer;transition:all 0.18s;background:var(--white);margin-bottom:6px;}
.unit-row:hover{border-color:var(--crimson);background:var(--crimson-pale);}
.unit-blood{width:42px;height:42px;border-radius:10px;background:var(--crimson-pale);color:var(--crimson);display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:800;flex-shrink:0;}
.unit-id{font-size:11px;color:var(--ink-light);margin-top:2px;}
.unit-days{font-size:11px;font-weight:700;}
.unit-days.ok{color:var(--emerald);}
.unit-days.warn{color:var(--amber);}
.unit-days.bad{color:var(--crimson);}

/* DONOR ROW */
.drow{display:flex;align-items:center;gap:10px;padding:10px 13px;border:1.5px solid var(--border);border-radius:10px;cursor:pointer;transition:all 0.18s;background:var(--white);margin-bottom:6px;}
.drow:hover{border-color:var(--sapphire);background:var(--sapphire-pale);}
.d-ava{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,var(--crimson),var(--crimson-deep));color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;}
.d-name{font-size:13px;font-weight:600;}
.d-meta{font-size:11px;color:var(--ink-light);margin-top:2px;}
.d-blood{margin-left:auto;font-size:12px;font-weight:700;color:var(--crimson);background:var(--crimson-pale);padding:3px 9px;border-radius:6px;}
.d-status{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.d-status.on{background:var(--emerald);}
.d-status.pend{background:var(--amber);}
.d-status.off{background:#CCC;}

/* PENDING DONOR */
.pend-card{background:var(--white);border:1.5px solid var(--amber-pale);border-left:4px solid var(--amber);border-radius:12px;padding:14px 16px;display:flex;align-items:center;gap:12px;margin-bottom:8px;}
.pend-ava{width:38px;height:38px;border-radius:10px;background:var(--amber-pale);color:var(--amber);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:700;flex-shrink:0;}
.pend-name{font-size:13px;font-weight:700;}
.pend-meta{font-size:11px;color:var(--ink-light);margin-top:2px;}
.pend-actions{display:flex;gap:6px;margin-left:auto;}

/* REQUEST ROW */
.req-card{background:var(--white);border:1.5px solid var(--border);border-radius:11px;padding:14px 16px;display:flex;align-items:center;gap:12px;margin-bottom:8px;transition:all 0.18s;}
.req-card:hover{border-color:var(--sapphire);}
.req-blood{width:44px;height:44px;border-radius:11px;background:var(--crimson-pale);color:var(--crimson);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:800;flex-shrink:0;}
.req-hosp{font-size:13px;font-weight:700;}
.req-meta{font-size:11px;color:var(--ink-light);margin-top:3px;}

/* AI BOX */
.ai-box{display:flex;gap:10px;background:linear-gradient(135deg,var(--violet-pale),#EEF2FF);border:1px solid #D4C5FF;border-radius:12px;padding:13px 16px;margin-bottom:16px;}
.ai-ico{font-size:18px;flex-shrink:0;margin-top:1px;}
.ai-lbl{font-size:9px;font-weight:700;color:var(--violet);text-transform:uppercase;letter-spacing:1px;margin-bottom:3px;}
.ai-txt{font-size:12px;color:var(--ink-mid);line-height:1.6;}

/* MATCH CARD */
.match-card{background:var(--white);border:1.5px solid var(--border);border-radius:11px;padding:13px 15px;display:flex;align-items:center;gap:11px;margin-bottom:8px;cursor:pointer;transition:all 0.18s;}
.match-card:hover{border-color:var(--violet);box-shadow:0 4px 14px rgba(107,70,193,0.1);}
.match-card.top{border-left:3px solid var(--violet);}
.match-rank{width:24px;height:24px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;flex-shrink:0;}
.rank1{background:linear-gradient(135deg,#FFD700,#FFA500);color:#fff;}
.rank2{background:linear-gradient(135deg,#C0C0C0,#A0A0A0);color:#fff;}
.rank3{background:linear-gradient(135deg,#CD7F32,#A0522D);color:#fff;}
.rankN{background:var(--fog2);color:var(--ink-light);}
.score-wrap{width:90px;}
.score-top{display:flex;justify-content:space-between;font-size:10px;color:var(--ink-light);margin-bottom:3px;}
.score-bar{height:5px;background:var(--fog2);border-radius:3px;overflow:hidden;}
.score-fill{height:100%;border-radius:3px;}
.sf-hi{background:linear-gradient(to right,var(--violet),#8B5CF6);}
.sf-mid{background:linear-gradient(to right,var(--sapphire),#60A5FA);}
.sf-lo{background:linear-gradient(to right,var(--amber),#FCA5A5);}
.notif-btn{background:var(--violet);color:#fff;border:none;padding:6px 13px;border-radius:8px;font-size:11px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;transition:all 0.18s;white-space:nowrap;}
.notif-btn:hover{background:#5B36B0;}

/* TRACKING */
.track-steps{display:flex;flex-direction:column;}
.ts{display:flex;gap:14px;padding:12px 0;position:relative;}
.ts:not(:last-child)::after{content:'';position:absolute;left:17px;top:38px;bottom:0;width:2px;background:var(--border);}
.ts-dot{width:34px;height:34px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;z-index:1;}
.ts-dot.done{background:var(--emerald-pale);border:2px solid var(--emerald);}
.ts-dot.active{background:var(--sapphire-pale);border:2px solid var(--sapphire);animation:blink 2s infinite;}
.ts-dot.wait{background:var(--fog2);border:2px solid var(--border);}
.ts-info{flex:1;padding-top:5px;}
.ts-title{font-size:13px;font-weight:700;}
.ts-sub{font-size:11px;color:var(--ink-light);margin-top:2px;}
.ts-time{font-size:10px;color:var(--ink-light);margin-top:3px;}

/* EXPIRY ALERT */
.exp-alert{display:flex;align-items:center;gap:10px;padding:11px 14px;border-radius:10px;margin-bottom:8px;}
.exp-alert.warn{background:var(--amber-pale);border:1px solid #F4C57A;}
.exp-alert.bad{background:var(--crimson-pale);border:1px solid var(--crimson-mid);}
.exp-alert-ico{font-size:18px;flex-shrink:0;}
.exp-alert-txt{font-size:12px;font-weight:600;}
.exp-alert-txt span{font-size:11px;color:var(--ink-light);display:block;font-weight:400;margin-top:2px;}

/* MODAL */
.overlay{position:fixed;inset:0;background:rgba(15,21,33,0.6);z-index:200;display:flex;align-items:center;justify-content:center;backdrop-filter:blur(5px);opacity:0;pointer-events:none;transition:opacity 0.25s;}
.overlay.open{opacity:1;pointer-events:all;}
.modal{background:var(--white);border-radius:18px;padding:28px;width:480px;max-width:92vw;box-shadow:0 24px 60px rgba(0,0,0,0.2);transform:scale(0.96);transition:transform 0.25s;max-height:90vh;overflow-y:auto;}
.overlay.open .modal{transform:scale(1);}
.modal-hd{display:flex;align-items:center;gap:12px;margin-bottom:18px;padding-bottom:16px;border-bottom:1px solid var(--border);}
.modal-ava{width:48px;height:48px;border-radius:13px;background:linear-gradient(135deg,var(--crimson),var(--crimson-deep));color:#fff;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;flex-shrink:0;}
.modal-close{margin-left:auto;width:28px;height:28px;border-radius:50%;border:1.5px solid var(--border);background:var(--fog);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:13px;transition:all 0.18s;}
.modal-close:hover{background:var(--crimson-pale);border-color:var(--crimson);}
.mf-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px;margin-bottom:14px;}
.mf{background:var(--fog);border-radius:9px;padding:11px 13px;}
.mf-l{font-size:10px;color:var(--ink-light);text-transform:uppercase;letter-spacing:0.8px;margin-bottom:3px;}
.mf-v{font-size:13px;font-weight:700;}
.mf-v.r{color:var(--crimson);}
.mf-v.g{color:var(--emerald);}
.mf-v.o{color:var(--amber);}
/* SMALL MODAL */
.modal-sm{background:var(--white);border-radius:18px;padding:24px;width:440px;max-width:92vw;box-shadow:0 24px 60px rgba(0,0,0,0.2);transform:scale(0.96);transition:transform 0.25s;max-height:90vh;overflow-y:auto;}
.overlay.open .modal-sm{transform:scale(1);}
.modal-hd-sm{display:flex;align-items:center;gap:10px;margin-bottom:18px;padding-bottom:14px;border-bottom:1px solid var(--border);}
.modal-hd-sm span{font-size:22px;}
.modal-hd-sm h2{font-size:15px;font-weight:800;}
.m-lbl{font-size:11px;font-weight:600;color:var(--ink-light);margin:10px 0 4px;}
.m-in{width:100%;border:1.5px solid var(--border);border-radius:9px;padding:9px 12px;font-size:13px;color:var(--ink);font-family:'DM Sans',sans-serif;outline:none;transition:border-color 0.18s;background:var(--fog);}
.m-in:focus{border-color:var(--crimson);background:var(--white);}
.m-row{display:flex;gap:9px;}
.m-sep{font-size:10px;font-weight:700;color:var(--ink-light);text-transform:uppercase;letter-spacing:1.5px;margin:16px 0 4px;padding-bottom:6px;border-bottom:1px solid var(--border);}
.m-btn{width:100%;background:var(--crimson);color:#fff;border:none;padding:11px;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;margin-top:16px;transition:all 0.18s;}
.m-btn:hover:not(:disabled){background:var(--crimson-deep);}
.m-btn:disabled{opacity:0.6;cursor:not-allowed;}
.m-back{text-align:center;margin-top:10px;font-size:12px;color:var(--ink-light);cursor:pointer;}
.m-back:hover{color:var(--ink-mid);}

/* FORM */
.f-g{display:flex;flex-direction:column;gap:5px;margin-bottom:11px;}
.f-l{font-size:12px;font-weight:600;color:var(--ink-mid);}
.f-i{background:var(--fog);border:1.5px solid var(--border);border-radius:9px;padding:9px 12px;font-size:13px;color:var(--ink);font-family:'DM Sans',sans-serif;outline:none;transition:border-color 0.2s;width:100%;}
.f-i:focus{border-color:var(--crimson);background:var(--white);}
.f-s{background:var(--fog);border:1.5px solid var(--border);border-radius:9px;padding:9px 12px;font-size:13px;color:var(--ink);font-family:'DM Sans',sans-serif;outline:none;width:100%;cursor:pointer;}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}

/* CENTER FILTER */
.center-filter{background:var(--fog);border:1.5px solid var(--border);border-radius:8px;padding:5px 12px;font-size:11px;font-weight:600;color:var(--ink-light);cursor:pointer;font-family:'DM Sans',sans-serif;transition:all 0.18s;}
.center-filter:hover{border-color:var(--sapphire);color:var(--sapphire);}
.center-filter.on{background:var(--sapphire-pale);border-color:var(--sapphire);color:var(--sapphire);font-weight:700;}

/* APPOINTMENTS */
.appt-row{display:flex;align-items:center;gap:11px;padding:11px 13px;border:1.5px solid var(--border);border-radius:11px;margin-bottom:7px;background:var(--white);transition:all 0.2s;}
.appt-row.done-row{background:var(--emerald-pale);border-color:var(--emerald-mid);}
.appt-time{font-size:12px;font-weight:700;color:var(--ink-light);width:52px;flex-shrink:0;}
.appt-ava{width:36px;height:36px;border-radius:9px;background:linear-gradient(135deg,var(--crimson),var(--crimson-deep));color:#fff;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;flex-shrink:0;}
.appt-name{font-size:13px;font-weight:700;}
.appt-meta{font-size:11px;color:var(--ink-light);margin-top:2px;}
.btn-donate{background:var(--crimson);color:#fff;border:none;padding:7px 13px;border-radius:8px;font-size:11px;font-weight:700;cursor:pointer;font-family:'DM Sans',sans-serif;white-space:nowrap;transition:all 0.18s;flex-shrink:0;}
.btn-donate:hover:not(:disabled){background:var(--crimson-deep);transform:translateY(-1px);}
.btn-donate:disabled{cursor:default;}

@@media(max-width:900px){
  .sb{transform:translateX(-260px);}
  .sb.open{transform:translateX(0);}
  .main{margin-left:0;}
  .g4{grid-template-columns:1fr 1fr;}
  .inv-grid{grid-template-columns:repeat(4,1fr);}
  .content{padding:16px;}
}
</style>
</head>
<body>

<!-- SIDEBAR -->
<div class="sb" id="sb">
  <div class="sb-logo">
    <div class="sb-logorow">
      <div class="sb-mark"><svg viewBox="0 0 26 26" fill="none" width="22" height="22"><path d="M13 3C13 3 5 11 5 16.5C5 20.6421 8.68629 24 13 24C17.3137 24 21 20.6421 21 16.5C21 11 13 3 13 3Z" fill="white"/></svg></div>
      <div><div class="sb-name">BloodBank Egypt
</div><div class="sb-tag">Admin Console</div></div>
    </div>
    <div class="sb-live"><div class="live-dot"></div>System Live</div>
  </div>

  <div class="sb-nav">
    <div class="sb-sec">Overview</div>
    <div class="sb-item on" onclick="go('dashboard',this)"><div class="sb-ico">📊</div>Dashboard</div>
    <div class="sb-item" onclick="go('requests',this)"><div class="sb-ico">📋</div>Blood Requests<span class="sb-badge o" id="sidebar-pending-requests">@ViewBag.PendingRequests</span></div>

    <div class="sb-sec">Inventory</div>
    <div class="sb-item" onclick="go('inventory',this)"><div class="sb-ico">🏦</div>Blood Inventory</div>
    <div class="sb-item" onclick="go('expiry',this)"><div class="sb-ico">⏳</div>Expiry Management<span class="sb-badge r" id="sidebar-expiry">@ViewBag.ExpiringSoon</span></div>

    <div class="sb-sec">Donors</div>
    <div class="sb-item" onclick="go('donors',this)"><div class="sb-ico">👥</div>Donors<span class="sb-badge g" id="sidebar-donors">@ViewBag.TotalDonors</span></div>
    <div class="sb-item" onclick="go('pending',this)"><div class="sb-ico">⏳</div>Pending Approval<span class="sb-badge o" id="sidebar-pending-donors">0</span></div>
    <div class="sb-item" onclick="go('centers',this)"><div class="sb-ico">🏪</div>Donation Centers</div>

    <div class="sb-sec">System</div>
    <div class="sb-item" onclick="go('tracking',this)"><div class="sb-ico">🔍</div>Unit Tracking</div>
    <div class="sb-item" onclick="go('hospitals',this)"><div class="sb-ico">🏥</div>Hospitals</div>
    <div class="sb-item" onclick="go('settings',this)"><div class="sb-ico">⚙️</div>Settings</div>
  </div>

  <div class="sb-foot">
    <div class="sb-user">
      <div class="sb-ava">SA</div>
      <div><div class="sb-uname">System Admin</div><div class="sb-urole">Admin · Full Access</div></div>
      <span class="sb-logout" onclick="logout()">↩ Logout</span>
    </div>
  </div>
</div>

<!-- MAIN -->
<div class="main">
  <div class="topbar">
    <button style="display:none;width:36px;height:36px;border-radius:10px;border:1.5px solid var(--border);background:var(--white);font-size:18px;cursor:pointer;" id="menuBtn" onclick="toggleSB()">☰</button>
    <div class="tb-title">
      <h1 id="pageTitle">Dashboard</h1>
      <p id="pageSubtitle">@DateTime.Today.ToString("dddd, MMMM d, yyyy")</p>
    </div>
    <div class="tb-actions">
      <div class="icon-btn" onclick="go('requests',null)">🔔<div class="dot" id="notif-dot" style="display: @(ViewBag.PendingRequests > 0 ? "block" : "none");"></div></div>
      <div class="icon-btn" onclick="logout()" title="Logout">↩</div>
      <div class="tb-avatar">SA</div>
    </div>
  </div>

  <div class="content">

    <!-- ══ DASHBOARD ══ -->
    <div id="s-dashboard" class="screen on">

      <!-- STAT CARDS -->
      <div class="g4">
        <div class="sbox" style="cursor:pointer" onclick="go('inventory',null)">
          <div style="position:absolute;top:16px;right:16px;opacity:0.1;">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><rect width="40" height="40" rx="8" fill="#0C9B60"/><polyline points="6,28 14,18 20,22 27,12 34,16" stroke="#0C9B60" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none"/></svg>
          </div>
          <div class="sl">Units in Stock</div>
          <div class="sn">@ViewBag.TotalBloodUnits</div>
          <div class="st up">↑ Safe inventory</div>
          <div class="sbar g"></div>
        </div>
        <div class="sbox" style="cursor:pointer" onclick="go('requests',null)">
          <div style="position:absolute;top:16px;right:16px;opacity:0.1;">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><rect width="40" height="40" rx="8" fill="#D01C2A"/><rect x="10" y="11" width="20" height="3" rx="1.5" fill="#D01C2A"/><rect x="10" y="18" width="14" height="3" rx="1.5" fill="#D01C2A"/><rect x="10" y="25" width="17" height="3" rx="1.5" fill="#D01C2A"/></svg>
          </div>
          <div class="sl">Active Requests</div>
          <div class="sn">@ViewBag.PendingRequests</div>
          <div class="st dn">↓ Action required</div>
          <div class="sbar r"></div>
        </div>
        <div class="sbox" style="cursor:pointer" onclick="go('donors',null)">
          <div style="position:absolute;top:16px;right:16px;opacity:0.1;">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><rect width="40" height="40" rx="8" fill="#1E5FD0"/><circle cx="20" cy="14" r="6" fill="#1E5FD0"/><path d="M6 34c0-7.732 6.268-14 14-14s14 6.268 14 14" stroke="#1E5FD0" stroke-width="3" stroke-linecap="round" fill="none"/></svg>
          </div>
          <div class="sl">Donors Ready</div>
          <div class="sn">@ViewBag.TotalDonors</div>
          <div class="st up">↑ Available now</div>
          <div class="sbar b"></div>
        </div>
        <div class="sbox" style="cursor:pointer" onclick="go('expiry',null)">
          <div style="position:absolute;top:16px;right:16px;opacity:0.1;">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none"><rect width="40" height="40" rx="8" fill="#D47B00"/><circle cx="20" cy="20" r="12" stroke="#D47B00" stroke-width="3" fill="none"/><path d="M20 12v8l5 5" stroke="#D47B00" stroke-width="3" stroke-linecap="round" fill="none"/></svg>
          </div>
          <div class="sl">Expiring Soon</div>
          <div class="sn" style="color:var(--amber)">@ViewBag.ExpiringSoon</div>
          <div class="st dn">↓ Within 7 days</div>
          <div class="sbar o"></div>
        </div>
      </div>

      <!-- ROW 2: Bar Chart + Donut -->
      <div class="g2">
        <!-- BAR CHART -->
        <div class="card">
          <div class="card-head">
            <div class="card-title"><div class="card-icon ci-blue">📈</div>Donations — Last 7 Days</div>
            <span style="font-size:11px;color:var(--ink-light);">March 2026</span>
          </div>
          <div style="display:flex;align-items:flex-end;gap:8px;height:120px;padding-bottom:4px;">
            <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;height:100%;justify-content:flex-end">
              <span style="font-size:10px;color:var(--ink-light);font-weight:600">0</span>
              <div style="width:100%;height:0%;background:linear-gradient(180deg,var(--sapphire),#6BA4F8);border-radius:5px 5px 0 0;"></div>
              <span style="font-size:9px;color:var(--ink-light);">Sun</span>
            </div>
            <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;height:100%;justify-content:flex-end">
              <span style="font-size:10px;color:var(--ink-light);font-weight:600">0</span>
              <div style="width:100%;height:0%;background:linear-gradient(180deg,var(--sapphire),#6BA4F8);border-radius:5px 5px 0 0;"></div>
              <span style="font-size:9px;color:var(--ink-light);">Mon</span>
            </div>
            <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;height:100%;justify-content:flex-end">
              <span style="font-size:10px;color:var(--ink-light);font-weight:600">0</span>
              <div style="width:100%;height:0%;background:linear-gradient(180deg,var(--sapphire),#6BA4F8);border-radius:5px 5px 0 0;"></div>
              <span style="font-size:9px;color:var(--ink-light);">Tue</span>
            </div>
            <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;height:100%;justify-content:flex-end">
              <span style="font-size:10px;color:var(--ink-light);font-weight:600">0</span>
              <div style="width:100%;height:0%;background:linear-gradient(180deg,var(--crimson),#F87A8A);border-radius:5px 5px 0 0;"></div>
              <span style="font-size:9px;color:var(--crimson);font-weight:700">Wed</span>
            </div>
            <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;height:100%;justify-content:flex-end">
              <span style="font-size:10px;color:var(--ink-light);font-weight:600">0</span>
              <div style="width:100%;height:0%;background:linear-gradient(180deg,var(--sapphire),#6BA4F8);border-radius:5px 5px 0 0;"></div>
              <span style="font-size:9px;color:var(--ink-light);">Thu</span>
            </div>
            <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;height:100%;justify-content:flex-end">
              <span style="font-size:10px;color:var(--ink-light);font-weight:600">0</span>
              <div style="width:100%;height:0%;background:linear-gradient(180deg,var(--sapphire),#6BA4F8);border-radius:5px 5px 0 0;"></div>
              <span style="font-size:9px;color:var(--ink-light);">Fri</span>
            </div>
            <div style="flex:1;display:flex;flex-direction:column;align-items:center;gap:4px;height:100%;justify-content:flex-end">
              <span style="font-size:10px;color:var(--emerald);font-weight:700" id="donationCount">0</span>
              <div style="width:100%;height:0%;background:linear-gradient(180deg,var(--emerald),#4ECFA0);border-radius:5px 5px 0 0;"></div>
              <span style="font-size:9px;color:var(--emerald);font-weight:700">Today</span>
            </div>
          </div>
          <div style="margin-top:10px;display:flex;align-items:center;gap:12px;padding-top:10px;border-top:1px solid var(--border);">
            <div style="display:flex;align-items:center;gap:5px;font-size:11px;color:var(--ink-light)"><div style="width:9px;height:9px;border-radius:2px;background:var(--sapphire)"></div>Normal</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:11px;color:var(--crimson)"><div style="width:9px;height:9px;border-radius:2px;background:var(--crimson)"></div>Peak day</div>
            <div style="display:flex;align-items:center;gap:5px;font-size:11px;color:var(--emerald)"><div style="width:9px;height:9px;border-radius:2px;background:var(--emerald)"></div>Today</div>
            <div style="margin-left:auto;font-size:11px;color:var(--ink-light)">Total: <strong style="color:var(--ink)">0</strong></div>
          </div>
        </div>

        <!-- DONUT CHART -->
        <div class="card">
          <div class="card-head">
            <div class="card-title"><div class="card-icon ci-red">🩸</div>Blood Type Distribution</div>
            <span style="font-size:11px;color:var(--ink-light);">Current stock</span>
          </div>
          <div style="display:flex;align-items:center;gap:18px;">
            <div style="position:relative;flex-shrink:0;">
              <svg width="120" height="120" viewBox="0 0 120 120">
                <circle cx="60" cy="60" r="46" fill="none" stroke="#E4E6EE" stroke-width="16"/>
                <text x="60" y="56" text-anchor="middle" font-family="Sora,sans-serif" font-size="15" font-weight="800" fill="#0F1521">0</text>
                <text x="60" y="70" text-anchor="middle" font-family="DM Sans,sans-serif" font-size="9" fill="#8891AA">units</text>
              </svg>
            </div>
            <div style="flex:1;display:flex;flex-direction:column;gap:9px;">
              <div style="display:flex;align-items:center;gap:7px;">
                <div style="width:9px;height:9px;border-radius:50%;background:var(--crimson);flex-shrink:0;"></div>
                <div style="flex:1;font-size:12px;font-weight:600">O+</div>
                <div style="font-size:11px;color:var(--ink-light)">0</div>
                <div style="font-size:11px;font-weight:700;color:var(--crimson)">0%</div>
              </div>
              <div style="display:flex;align-items:center;gap:7px;">
                <div style="width:9px;height:9px;border-radius:50%;background:var(--sapphire);flex-shrink:0;"></div>
                <div style="flex:1;font-size:12px;font-weight:600">A+</div>
                <div style="font-size:11px;color:var(--ink-light)">0</div>
                <div style="font-size:11px;font-weight:700;color:var(--sapphire)">0%</div>
              </div>
              <div style="display:flex;align-items:center;gap:7px;">
                <div style="width:9px;height:9px;border-radius:50%;background:var(--emerald);flex-shrink:0;"></div>
                <div style="flex:1;font-size:12px;font-weight:600">AB+</div>
                <div style="font-size:11px;color:var(--ink-light)">0</div>
                <div style="font-size:11px;font-weight:700;color:var(--emerald)">0%</div>
              </div>
              <div style="display:flex;align-items:center;gap:7px;">
                <div style="width:9px;height:9px;border-radius:50%;background:var(--amber);flex-shrink:0;"></div>
                <div style="flex:1;font-size:12px;font-weight:600">Other</div>
                <div style="font-size:11px;color:var(--ink-light)">0</div>
                <div style="font-size:11px;font-weight:700;color:var(--amber)">0%</div>
              </div>
              <div style="margin-top:2px;padding-top:8px;border-top:1px solid var(--border);display:grid;grid-template-columns:1fr 1fr 1fr;gap:6px;">
                <div style="background:var(--crimson-pale);border-radius:7px;padding:7px;text-align:center;">
                  <div style="font-size:9px;color:var(--ink-light);margin-bottom:2px;">Critical</div>
                  <div style="font-size:15px;font-weight:800;color:var(--crimson);font-family:'Sora',sans-serif;">0</div>
                </div>
                <div style="background:var(--amber-pale);border-radius:7px;padding:7px;text-align:center;">
                  <div style="font-size:9px;color:var(--ink-light);margin-bottom:2px;">Low</div>
                  <div style="font-size:15px;font-weight:800;color:var(--amber);font-family:'Sora',sans-serif;">0</div>
                </div>
                <div style="background:var(--emerald-pale);border-radius:7px;padding:7px;text-align:center;">
                  <div style="font-size:9px;color:var(--ink-light);margin-bottom:2px;">Safe</div>
                  <div style="font-size:15px;font-weight:800;color:var(--emerald);font-family:'Sora',sans-serif;">0</div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- ROW 3: Requests + Activity -->
      <div class="g2">
        <div class="card">
          <div class="card-head"><div class="card-title"><div class="card-icon ci-red">📋</div>Latest Requests</div><div class="card-action" onclick="go('requests',null)">View All</div></div>
          <div style="padding: 20px; text-align: center; color: var(--ink-light); font-size: 13px;">No active requests found</div>
        </div>
        <div class="card">
          <div class="card-head"><div class="card-title"><div class="card-icon ci-amber">⚡</div>Recent Activity</div></div>
          <div style="padding: 20px; text-align: center; color: var(--ink-light); font-size: 13px;">No recent activity</div>
        </div>
      </div>

      <!-- ROW 4: Center Performance + Sparkline -->
      <div class="g2">
        <div class="card">
          <div class="card-head"><div class="card-title"><div class="card-icon ci-blue">🏪</div>Center Performance — Today</div><div class="card-action" onclick="go('centers',null)">View All</div></div>
          <div style="padding: 20px; text-align: center; color: var(--ink-light); font-size: 13px;">No data available</div>
        </div>

        <!-- Sparkline -->
        <div class="card">
          <div class="card-head"><div class="card-title"><div class="card-icon ci-violet">📊</div>Requests — Last 6 Months</div></div>
          <div style="position:relative;height:120px;margin-bottom:8px;">
            <svg width="100%" height="120" viewBox="0 0 380 120" preserveAspectRatio="none">
              <defs>
                <linearGradient id="lineGrad" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#D01C2A" stop-opacity="0.2"/>
                  <stop offset="100%" stop-color="#D01C2A" stop-opacity="0.02"/>
                </linearGradient>
              </defs>
              <line x1="0" y1="30" x2="380" y2="30" stroke="#E4E6EE" stroke-width="1"/>
              <line x1="0" y1="70" x2="380" y2="70" stroke="#E4E6EE" stroke-width="1"/>
              <line x1="0" y1="110" x2="380" y2="110" stroke="#E4E6EE" stroke-width="1"/>
            </svg>
          </div>
          <div style="display:flex;justify-content:space-between;font-size:10px;color:var(--ink-light);margin-bottom:14px;padding:0 2px;">
            <span>Oct</span><span>Nov</span><span>Dec</span><span>Jan</span><span>Feb</span><span style="color:var(--emerald);font-weight:700">Mar</span>
          </div>
          <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;">
            <div style="background:var(--crimson-pale);border-radius:10px;padding:10px;text-align:center;">
              <div style="font-size:9px;color:var(--ink-light);margin-bottom:3px;">This Month</div>
              <div style="font-size:20px;font-weight:800;color:var(--crimson);font-family:'Sora',sans-serif;">0</div>
            </div>
            <div style="background:var(--emerald-pale);border-radius:10px;padding:10px;text-align:center;">
              <div style="font-size:9px;color:var(--ink-light);margin-bottom:3px;">Fulfilled</div>
              <div style="font-size:20px;font-weight:800;color:var(--emerald);font-family:'Sora',sans-serif;">0</div>
            </div>
            <div style="background:var(--sapphire-pale);border-radius:10px;padding:10px;text-align:center;">
              <div style="font-size:9px;color:var(--ink-light);margin-bottom:3px;">Completion</div>
              <div style="font-size:20px;font-weight:800;color:var(--sapphire);font-family:'Sora',sans-serif;">0%</div>
            </div>
          </div>
        </div>
      </div>

    </div>

    <!-- ══ REQUESTS ══ -->
    <div id="s-requests" class="screen">
      <div class="card">
        <div class="card-head"><div class="card-title"><div class="card-icon ci-red">📋</div><span id="requests-title-count">Hospital Requests</span></div></div>
        <table class="tbl">
          <thead><tr><th>Request #</th><th>Hospital</th><th>Blood Type</th><th>Quantity</th><th>Priority</th><th>Status</th><th>Action</th></tr></thead>
          <tbody>
          </tbody>
        </table>
      </div>
    </div>

    <!-- ══ INVENTORY ══ -->
    <div id="s-inventory" class="screen">
      <div class="inv-grid mb" id="inventory-grid">
        <div style="grid-column: 1 / -1; padding: 20px; text-align: center; color: var(--ink-light); font-size: 13px;">No inventory data available</div>
      </div>
      <div style="display:flex;gap:10px;">
        <button class="btn" onclick="sendSMSCampaign(this)">📱 Send SMS to Required Donors</button>
      </div>
    </div>

    <!-- ══ EXPIRY ══ -->
    <div id="s-expiry" class="screen">
      <div class="g3 mb">
        <div class="sbox"><div class="sl">Expiring within 7 days</div><div class="sn" style="color:var(--amber)">@ViewBag.ExpiringSoon</div><div class="st dn">↓ Urgent consumption needed</div><div class="sbar o"></div></div>
        <div class="sbox"><div class="sl">Expiring within 3 days</div><div class="sn" style="color:var(--crimson)">@ViewBag.ExpiringSoon3</div><div class="st dn">↓ Risk of waste</div><div class="sbar r"></div></div>
