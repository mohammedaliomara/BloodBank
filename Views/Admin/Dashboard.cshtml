function addMinistry(){document.getElementById('ministryOverlay').classList.add('open');}
function closeMinistry(){document.getElementById('ministryOverlay').classList.remove('open');}
function submitMinistry(){
  const email=document.getElementById('minEmail').value.trim();
  const pass=document.getElementById('minPass').value;
  const passC=document.getElementById('minPassC').value;
  if(!email){alert('Please enter the email address.');return;}
  if(!pass||pass.length<6){alert('Password must be at least 6 characters.');return;}
  if(pass!==passC){alert('Password and confirmation do not match.');return;}
  const btn=document.getElementById('ministryBtn');
  btn.textContent='⏳ Saving...';btn.disabled=true;
  setTimeout(()=>{
    btn.textContent='✅ Ministry data saved';btn.style.background='var(--emerald)';
    setTimeout(()=>{closeMinistry();btn.textContent='Save Data';btn.style.background='';btn.disabled=false;
      document.getElementById('minEmail').value='';document.getElementById('minPass').value='';document.getElementById('minPassC').value='';
    },1500);
  },1000);
}

window.addEventListener('resize',()=>{
  document.getElementById('menuBtn').style.display=window.innerWidth<900?'flex':'none';
});
window.dispatchEvent(new Event('resize'));
</script>

